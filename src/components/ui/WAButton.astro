---
import type { HTMLAttributes } from "astro/types";

import { siteConfig } from "../../data/site";
import { createWhatsappLink } from "../../lib/whatsapp";
import Icon from "./Icon.astro";

interface Props extends HTMLAttributes<"button"> {
  text?: string;
  message?: string;
  phone?: string;
  variant?: "primary" | "white" | "floating" | "text-link";
  size?: "sm" | "md" | "lg";
  hideIcon?: boolean;
  asButton?: boolean;
}

const {
  text = "Konsultasi via WhatsApp",
  message = siteConfig.waText,
  phone = siteConfig.waNumber,
  variant = "primary",
  size = "md",
  hideIcon = false,
  class: extraClass = "",
  asButton = false,
  ...attributes
} = Astro.props;

const sizeClasses = {
  sm: "h-9 px-4 text-xs gap-1.5",
  md: "h-11 px-5 text-sm gap-2",
  lg: "h-13 px-7 text-sm gap-2.5",
};

const variantClasses = {
  primary:
    "bg-primary text-white shadow-md shadow-primary/15 hover:shadow-lg hover:shadow-primary/20 hover:-translate-y-0.5 hover:brightness-110",
  white:
    "bg-white text-primary shadow-lg shadow-black/10 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-0.5 hover:scale-105",
  floating:
    "bg-primary text-white shadow-xl shadow-primary/20 ring-1 ring-white/20 hover:scale-110 hover:brightness-110 hover:shadow-2xl hover:shadow-primary/30",
  "text-link": "text-base-content/60 hover:text-primary",
};

const iconSizes = {
  sm: 14,
  md: 16,
  lg: 18,
};

const waLink = createWhatsappLink(phone, message);
const iconOnly = variant === "floating";
const buttonClass = `wa-button inline-flex items-center justify-center rounded-xl font-bold transition-all duration-300 ${variantClasses[variant]} ${sizeClasses[size]} ${extraClass} ${iconOnly ? "h-14 w-14 rounded-full p-0" : ""}`;
---

{
  !asButton && (
    <a
      {...attributes}
      href={waLink}
      target="_blank"
      rel="noopener noreferrer"
      class={buttonClass}
      aria-label={iconOnly ? `WhatsApp: ${text}` : text}
    >
      {!hideIcon && <Icon name="mdi:whatsapp" size={iconSizes[size]} class="shrink-0" />}
      {!iconOnly && <span>{text}</span>}
    </a>
  )
}

{
  asButton && (
    <button
      {...attributes}
      type="button"
      class={buttonClass}
      onclick={`window.open('${waLink}', '_blank', 'noopener,noreferrer')`}
      aria-label={text}
    >
      {!hideIcon && <Icon name="mdi:whatsapp" size={iconSizes[size]} class="shrink-0" />}
      {!iconOnly && <span>{text}</span>}
    </button>
  )
}
