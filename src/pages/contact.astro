---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { siteConfig } from "../data/site";
import { contactLocations } from "../data/contact";
import { createWhatsappLink } from "../lib/whatsapp";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
const displayWa = `+${siteConfig.waNumber.replace(/^(\d{2})(\d{3})(\d{4})(\d+)$/, "$1 $2-$3-$4")}`;

const inputClass =
  "block w-full rounded-xl border border-base-200 bg-base-50 px-4 py-3 text-sm outline-none transition-all placeholder:text-base-content/25 focus:border-primary/40 focus:ring-4 focus:ring-primary/5";
---

<MainLayout
  title="Kontak | Magna Maklon"
  description="Hubungi tim Magna untuk konsultasi maklon skincare. Kantor di Indramayu, Jawa Barat."
>
  <main class="overflow-x-hidden">

    <!-- Kontak + Form -->
    <section class="bg-base-100 py-14 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader
          label="Kontak"
          variant="minimal"
          class="mb-8 md:mb-10"
        >
          <span slot="title">Hubungi <span class="text-primary">Tim Magna</span></span>
        </SectionHeader>

        <div class="grid items-start gap-8 lg:grid-cols-5 lg:gap-10">
          <!-- Sidebar info -->
          <aside class="lg:sticky lg:top-24 lg:col-span-2">
            <div class="rounded-2xl border border-base-200/80 bg-white p-6 shadow-sm">
              <p class="text-[11px] font-semibold tracking-[0.2em] text-primary/60 uppercase">Informasi</p>
              <h2 class="mt-2 text-lg font-black text-base-content">Cara Menghubungi Kami</h2>

              <ul class="mt-5 space-y-4">
                <li class="flex items-start gap-3">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <Icon name="mdi:whatsapp" size={18} />
                  </span>
                  <div class="min-w-0 flex-1">
                    <p class="text-xs font-semibold uppercase tracking-wide text-base-content/40">WhatsApp</p>
                    <p class="text-sm font-bold text-base-content/85">{displayWa}</p>
                    <div class="mt-1.5 flex flex-wrap gap-2">
                      <a href={waLink} target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-primary hover:underline">
                        Buka chat
                      </a>
                      <button type="button" id="copyWaBtn" data-number={displayWa} class="text-xs font-semibold text-base-content/45 hover:text-primary">
                        Salin nomor
                      </button>
                    </div>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <Icon name="lucide:mail" size={16} />
                  </span>
                  <div class="min-w-0">
                    <p class="text-xs font-semibold uppercase tracking-wide text-base-content/40">Email</p>
                    <a href={`mailto:${siteConfig.email}`} class="break-all text-sm font-bold text-base-content/85 hover:text-primary">
                      {siteConfig.email}
                    </a>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <Icon name="lucide:clock" size={16} />
                  </span>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wide text-base-content/40">Jam Operasional</p>
                    <p class="text-sm font-bold text-base-content/85">{siteConfig.operationalHours}</p>
                    <p class="mt-0.5 text-xs text-base-content/45">Indramayu, Jawa Barat</p>
                  </div>
                </li>
              </ul>

              <div class="mt-5 rounded-xl bg-primary/5 px-4 py-3 text-xs leading-relaxed text-base-content/55">
                <span class="font-semibold text-base-content/70">Tips:</span> untuk respon tercepat, gunakan WhatsApp. Tim kami biasanya membalas dalam 1×24 jam kerja.
              </div>
            </div>
          </aside>

          <!-- Form -->
          <div class="lg:col-span-3" id="form-konsultasi">
            <div class="rounded-2xl border border-base-200/80 bg-white p-6 shadow-sm md:p-8">
              <div class="mb-6">
                <p class="text-[11px] font-semibold tracking-[0.2em] text-primary/60 uppercase">Konsultasi</p>
                <h2 class="mt-2 text-xl font-black text-base-content md:text-2xl">
                  Form <span class="text-primary">Konsultasi Maklon</span>
                </h2>
              </div>

              <form class="space-y-5" data-wa-number={siteConfig.waNumber} id="consultForm" novalidate>
                <fieldset class="space-y-4">
                  <div>
                    <label for="nama" class="mb-1.5 block text-sm font-semibold">
                      Nama Lengkap <span class="text-error">*</span>
                    </label>
                    <input type="text" id="nama" name="nama" required autocomplete="name" placeholder="Contoh: Budi Santoso" class={inputClass} />
                    <p class="field-error mt-1 hidden text-xs text-error" data-for="nama">Nama wajib diisi.</p>
                  </div>

                  <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                      <label for="wa" class="mb-1.5 block text-sm font-semibold">
                        Nomor WhatsApp <span class="text-error">*</span>
                      </label>
                      <input type="tel" id="wa" name="wa" required autocomplete="tel" inputmode="tel" placeholder="08xx-xxxx-xxxx" class={inputClass} />
                      <p class="mt-1 text-[11px] text-base-content/40">Pastikan nomor aktif untuk dihubungi kembali.</p>
                      <p class="field-error mt-1 hidden text-xs text-error" data-for="wa">Nomor WhatsApp wajib diisi.</p>
                    </div>
                    <div>
                      <label for="email" class="mb-1.5 block text-sm font-semibold">
                        Email <span class="text-[11px] font-normal text-base-content/35">(opsional)</span>
                      </label>
                      <input type="email" id="email" name="email" autocomplete="email" placeholder="contoh@email.com" class={inputClass} />
                    </div>
                  </div>
                </fieldset>

                <fieldset class="space-y-4">
                  <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                      <label for="produk" class="mb-1.5 block text-sm font-semibold">
                        Jenis Produk <span class="text-error">*</span>
                      </label>
                      <select id="produk" name="produk" required class={inputClass}>
                        <option value="" disabled selected>Pilih jenis produk</option>
                        <option value="Skincare">Skincare</option>
                        <option value="Bodycare">Bodycare</option>
                        <option value="Haircare">Haircare</option>
                        <option value="Baby Care">Baby Care</option>
                        <option value="Lainnya">Lainnya</option>
                      </select>
                      <p class="field-error mt-1 hidden text-xs text-error" data-for="produk">Pilih jenis produk.</p>
                    </div>
                    <div>
                      <label for="estimasi" class="mb-1.5 block text-sm font-semibold">
                        Estimasi Produksi <span class="text-[11px] font-normal text-base-content/35">(opsional)</span>
                      </label>
                      <select id="estimasi" name="estimasi" class={inputClass}>
                        <option value="" disabled selected>Pilih estimasi</option>
                        <option value="500-1000 pcs">500 – 1.000 pcs</option>
                        <option value="1000-5000 pcs">1.000 – 5.000 pcs</option>
                        <option value="5000-10000 pcs">5.000 – 10.000 pcs</option>
                        <option value="10000+ pcs">10.000+ pcs</option>
                        <option value="Belum tahu">Belum tahu</option>
                      </select>
                    </div>
                  </div>

                  <div>
                    <label for="pesan" class="mb-1.5 flex items-center justify-between">
                      <span class="text-sm font-semibold">Pesan Tambahan</span>
                      <span class="text-[11px] text-base-content/30" id="char-count">0 / 500</span>
                    </label>
                    <textarea
                      id="pesan" name="pesan" rows={4} maxlength={500}
                      placeholder="Ceritakan ide produk, target pasar, atau pertanyaan Anda..."
                      class={`${inputClass} resize-y leading-relaxed`}
                    ></textarea>
                  </div>
                </fieldset>

                <div class="space-y-3 border-t border-base-200/60 pt-6">
                  <button
                    type="submit"
                    id="submitBtn"
                    class="flex w-full items-center justify-center gap-2.5 rounded-xl bg-primary px-8 py-3.5 text-sm font-bold text-white shadow-md shadow-primary/15 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20 disabled:cursor-not-allowed disabled:opacity-60"
                  >
                    <Icon name="mdi:whatsapp" size={18} />
                    <span id="submitBtnText">Kirim via WhatsApp</span>
                  </button>
                  <p class="text-center text-[11px] text-base-content/40">
                    Dengan mengirim form, Anda akan diarahkan ke WhatsApp dengan pesan yang sudah terisi.
                  </p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Lokasi -->
    <section id="lokasi" class="scroll-mt-24 border-t border-base-200/60 bg-base-200/30 py-14 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader label="Lokasi" variant="minimal" class="mb-8 md:mb-10">
          <span slot="title">Temukan <span class="text-primary">Kami</span></span>
        </SectionHeader>

        <!-- Pill switcher -->
        <div
          class="mx-auto mb-5 flex max-w-md rounded-xl border border-base-200/60 bg-white p-1 shadow-xs"
          id="locationPills"
          role="tablist"
          aria-label="Pilih lokasi"
        >
          {contactLocations.map((loc, idx) => (
            <button
              type="button"
              role="tab"
              aria-selected={idx === 0 ? "true" : "false"}
              aria-controls="locationMapPanel"
              id={`location-tab-${loc.id}`}
              data-map={loc.embedUrl}
              data-maps={loc.mapsUrl}
              data-id={loc.id}
              data-name={loc.name}
              class:list={[
                "location-pill flex flex-1 items-center justify-center gap-2 rounded-lg px-3 py-2.5 text-xs font-bold transition-all sm:text-sm",
                idx === 0 ? "bg-primary text-white shadow-sm" : "text-base-content/55 hover:bg-base-100 hover:text-primary",
              ]}
            >
              <Icon name={loc.icon} size={16} />
              <span class="truncate">{loc.name}</span>
            </button>
          ))}
        </div>

        <!-- Peta -->
        <div class="overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-sm">
          <div class="flex items-center justify-between gap-3 border-b border-base-200/60 px-4 py-3">
            <p class="truncate text-sm font-semibold text-base-content/70">
              <span id="locationMapLabel">{contactLocations[0].name}</span>
            </p>
            <a
              id="locationMapLink"
              href={contactLocations[0].mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex shrink-0 items-center gap-1.5 rounded-lg bg-primary/10 px-3 py-1.5 text-xs font-bold text-primary transition-colors hover:bg-primary hover:text-white"
            >
              <Icon name="lucide:navigation" size={14} />
              Petunjuk Arah
            </a>
          </div>
          <div
            class="relative aspect-[16/10] min-h-[240px] sm:min-h-[320px]"
            id="locationMapPanel"
            role="tabpanel"
            aria-labelledby="location-tab-office"
          >
            <iframe
              id="locationMapFrame"
              src={contactLocations[0].embedUrl}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Peta ${contactLocations[0].name}`}
              class="absolute inset-0 h-full w-full"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

  </main>
</MainLayout>

<script>
  import { createConsultationMessage, createWhatsappLink } from "../lib/whatsapp";

  document.addEventListener("DOMContentLoaded", () => {
    // Salin nomor WA
    const copyBtn = document.getElementById("copyWaBtn");
    copyBtn?.addEventListener("click", async () => {
      const number = copyBtn.getAttribute("data-number") || "";
      try {
        await navigator.clipboard.writeText(number);
        const original = copyBtn.textContent;
        copyBtn.textContent = "Tersalin!";
        setTimeout(() => { copyBtn.textContent = original; }, 2000);
      } catch {
        copyBtn.textContent = "Gagal menyalin";
      }
    });

    // Character counter
    const pesanTextarea = document.getElementById("pesan") as HTMLTextAreaElement | null;
    const charCount = document.getElementById("char-count");
    pesanTextarea?.addEventListener("input", () => {
      const len = pesanTextarea.value.length;
      if (charCount) {
        charCount.textContent = `${len} / 500`;
        charCount.classList.toggle("text-error", len > 450);
        charCount.classList.toggle("text-base-content/30", len <= 450);
      }
    });

    // Form validation + submit
    const form = document.getElementById("consultForm") as HTMLFormElement | null;
    const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement | null;
    const submitBtnText = document.getElementById("submitBtnText");

    const showError = (id: string, show: boolean) => {
      const el = document.querySelector(`.field-error[data-for="${id}"]`);
      const input = document.getElementById(id);
      el?.classList.toggle("hidden", !show);
      input?.classList.toggle("border-error/50", show);
      input?.classList.toggle("ring-2", show);
      input?.classList.toggle("ring-error/10", show);
    };

    const validateForm = () => {
      let valid = true;
      const required = ["nama", "wa", "produk"];
      required.forEach((id) => {
        const field = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
        const empty = !field?.value.trim();
        showError(id, empty);
        if (empty) valid = false;
      });
      return valid;
    };

    ["nama", "wa", "produk"].forEach((id) => {
      document.getElementById(id)?.addEventListener("input", () => showError(id, false));
      document.getElementById(id)?.addEventListener("change", () => showError(id, false));
    });

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!validateForm()) {
        const firstInvalid = form.querySelector(".field-error:not(.hidden)");
        (firstInvalid?.previousElementSibling as HTMLElement)?.focus?.()
          || (firstInvalid?.parentElement?.querySelector("input, select") as HTMLElement)?.focus?.();
        return;
      }

      const waNumber = form.getAttribute("data-wa-number");
      const getValue = (id: string) => {
        const field = document.getElementById(id);
        return field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement
          ? field.value
          : "";
      };

      submitBtn?.setAttribute("disabled", "true");
      if (submitBtnText) submitBtnText.textContent = "Membuka WhatsApp...";

      const message = createConsultationMessage({
        nama: getValue("nama"),
        wa: getValue("wa"),
        email: getValue("email"),
        produk: getValue("produk"),
        estimasi: getValue("estimasi"),
        kategori: "",
        pesan: getValue("pesan"),
      });

      window.open(createWhatsappLink(waNumber || "", message), "_blank", "noopener,noreferrer");

      setTimeout(() => {
        submitBtn?.removeAttribute("disabled");
        if (submitBtnText) submitBtnText.textContent = "Kirim via WhatsApp";
      }, 2000);
    });

    // Location pill switcher
    const pills = document.querySelectorAll<HTMLButtonElement>(".location-pill");
    const mapFrame = document.getElementById("locationMapFrame") as HTMLIFrameElement | null;
    const mapLabel = document.getElementById("locationMapLabel");
    const mapLink = document.getElementById("locationMapLink") as HTMLAnchorElement | null;
    const mapPanel = document.getElementById("locationMapPanel");

    function activateLocation(pill: HTMLButtonElement) {
      const mapUrl = pill.getAttribute("data-map");
      const mapsUrl = pill.getAttribute("data-maps");
      const locId = pill.getAttribute("data-id");
      const locName = pill.getAttribute("data-name");

      if (mapFrame && mapUrl) mapFrame.src = mapUrl;
      if (mapLabel && locName) mapLabel.textContent = locName;
      if (mapLink && mapsUrl) mapLink.href = mapsUrl;
      if (mapFrame && locName) mapFrame.title = `Peta ${locName}`;
      if (mapPanel && locId) mapPanel.setAttribute("aria-labelledby", `location-tab-${locId}`);

      pills.forEach((p) => {
        const isActive = p === pill;
        p.setAttribute("aria-selected", isActive ? "true" : "false");
        p.classList.toggle("bg-primary", isActive);
        p.classList.toggle("text-white", isActive);
        p.classList.toggle("shadow-sm", isActive);
        p.classList.toggle("text-base-content/55", !isActive);
      });
    }

    pills.forEach((pill) => {
      pill.addEventListener("click", () => activateLocation(pill));
    });
  });
</script>
