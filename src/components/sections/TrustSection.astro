---
import SectionHeader from "../ui/SectionHeader.astro";
import Icon from "../ui/Icon.astro";
import { trustPlaceholder } from "../../data/company";
---

<section id="kepercayaan" class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
  <SectionHeader
    tag="Kepercayaan"
    title="Mengapa Brand Lain Percaya pada Kami"
    description="Kami membangun kepercayaan melalui kualitas, konsistensi, dan komitmen terhadap setiap produk yang kami hasilkan."
  />

  <div class="mt-8 grid gap-5 md:grid-cols-3">
    {trustPlaceholder.map((item) => (
      <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
        <div class="card-body items-center text-center p-6">
          <div class="flex h-20 w-20 items-center justify-center rounded-full bg-primary/10 text-4xl text-primary">
            <Icon name={item.icon} size={40} />
          </div>
          <h3 class="card-title mt-4 text-lg">{item.title}</h3>
          <p class="mt-2 text-sm text-base-content/70">{item.desc}</p>
        </div>
      </div>
    ))}
  </div>

  <!-- Stats Row -->
  <div class="mt-8 grid gap-4 rounded-3xl bg-gradient-to-r from-primary/5 to-secondary/5 p-6 md:grid-cols-4">
    <div class="text-center">
      <p class="text-3xl font-black text-primary">500+</p>
      <p class="mt-1 text-sm text-base-content/60">Produk Berhasil Dipasarkan</p>
    </div>
    <div class="text-center">
      <p class="text-3xl font-black text-primary">200+</p>
      <p class="mt-1 text-sm text-base-content/60">Brand Partner</p>
    </div>
    <div class="text-center">
      <p class="text-3xl font-black text-primary">10+</p>
      <p class="mt-1 text-sm text-base-content/60">Tahun Pengalaman</p>
    </div>
    <div class="text-center">
      <p class="text-3xl font-black text-primary">50+</p>
      <p class="mt-1 text-sm text-base-content/60">Tenaga Ahli</p>
    </div>
  </div>
</section>
