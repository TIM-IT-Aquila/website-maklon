---
interface Props {
  label?: string;
  title?: string;
  align?: "center" | "left";
  tone?: "default" | "light";
  class?: string;
}

const {
  label,
  title,
  align = "center",
  tone = "default",
  class: className,
} = Astro.props;
---

<div
  class:list={[
    align === "center" && "reveal-up mx-auto max-w-2xl text-center",
    align === "left" && "reveal-up max-w-none text-left",
    className,
  ]}
>
  {
    label && (
      <div
        class:list={[
          "mb-6 flex items-center gap-3",
          align === "center" ? "justify-center" : "justify-start",
        ]}
      >
        <span class:list={["block h-px w-8", tone === "light" ? "bg-white/30" : "bg-primary/30"]} />
        <span
          class:list={[
            "text-[11px] font-semibold tracking-[0.2em] uppercase",
            tone === "light" ? "text-white/60" : "text-primary/60",
          ]}
        >
          {label}
        </span>
        <span class:list={["block h-px w-8", tone === "light" ? "bg-white/30" : "bg-primary/30"]} />
      </div>
    )
  }

  <h2
    class:list={[
      "text-3xl font-black leading-tight md:text-4xl lg:text-5xl",
      tone === "light" && "text-white",
    ]}
  >
    <slot name="title">{title}</slot>
  </h2>
</div>
