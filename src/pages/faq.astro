---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/ui/Container.astro";
import FAQItem from "../components/ui/FAQItem.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { faqs } from "../data/faqs";
---

<MainLayout
  title="FAQ | Magna"
  description="Pertanyaan yang sering diajukan seputar layanan maklon skincare."
>
  <main class="overflow-hidden bg-base-100">
    <section class="pt-20 pb-14 md:pt-24 md:pb-16">
      <Container maxWidth="3xl">
        <SectionHeader label="FAQ">
          <span slot="title">Pertanyaan <span class="text-primary">Umum</span></span>
        </SectionHeader>

        <div class="mt-10 space-y-3">
          {
            faqs.map((faq, index) => (
              <FAQItem
                question={faq.q}
                answer={faq.a}
                index={index + 1}
                open={index === 0}
              />
            ))
          }
        </div>
      </Container>
    </section>
  </main>
</MainLayout>
