---
import SectionHeader from "../ui/SectionHeader.astro";
import ProductCard from "../cards/ProductCard.astro";
import { products } from "../../data/products";
import { services } from "../../data/services";
import ServiceCard from "../cards/ServiceCard.astro";
---

<section id="produk" class="bg-base-200/50 py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <SectionHeader
      tag="Produk & Layanan"
      title="Produk dan Layanan Maklon"
      description="Berbagai produk dan layanan maklon siap membantu mewujudkan brand kecantikan Anda."
    />

    <!-- Services -->
    <div class="mb-14">
      <h3 class="mb-6 text-xl font-bold">Layanan Maklon</h3>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>

    <!-- Products -->
    <div>
      <h3 class="mb-6 text-xl font-bold">Produk yang Bisa Dibuat</h3>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </div>
</section>