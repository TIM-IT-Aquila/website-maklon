---
import Container from "../components/ui/Container.astro";
import FAQItem from "../components/ui/FAQItem.astro";
import Icon from "../components/ui/Icon.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
import WAButton from "../components/ui/WAButton.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { advantages } from "../data/advantages";
import { services } from "../data/services";
import { processSteps } from "../data/process";
import { products } from "../data/products";
import { faqs } from "../data/faqs";
import { brandPartners, brandPartnersRowTwo } from "../data/brandPartners";
import { categoryImages } from "../data/images";
import { certifications } from "../data/certifications";
import { facilityGalleryItems } from "../data/company";
import { homeComparisonRows, homeHeroSlides } from "../data/home";

const processPreviewSteps = processSteps.slice(0, 4);
const topProducts = products.slice(0, 8);
const categories = categoryImages.slice(0, 6);

---

<MainLayout
  title="Magna – Jasa Skincare Terpercaya"
  description={siteConfig.description}
>
  <main data-home class="overflow-x-hidden">

    <!-- ================================================================== -->
    <!-- 1. HERO — Image Slider                                              -->
    <!-- ================================================================== -->
    <section id="hero" class="relative flex h-[65vh] min-h-[520px] items-center">
      <!-- Background Slides -->
      <div class="absolute inset-0 z-0">
        {homeHeroSlides.map((slide, idx) => (
          <div
            class="hero-slide absolute inset-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000 ease-in-out"
            class:list={{ "opacity-100": idx === 0, "opacity-0": idx !== 0 }}
            style={`background-image: url('${slide.image}')`}
          ></div>
        ))}
        <!-- Dark overlay -->
        <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/55 to-black/65"></div>
      </div>

      <!-- Content -->
      <Container class="relative z-10 w-full">
        <div class="max-w-2xl">
          <div class="relative min-h-[180px] md:min-h-[200px]">
            {homeHeroSlides.map((slide, idx) => (
              <div
                class="hero-text absolute inset-0 transition-opacity duration-1000 ease-in-out"
                class:list={{ "opacity-100": idx === 0, "opacity-0 pointer-events-none": idx !== 0 }}
              >
                <h1 class="text-3xl font-black leading-[1.06] text-white md:text-4xl lg:text-5xl xl:text-6xl">
                  {slide.titleMain}<br />
                  <span class="bg-gradient-to-r from-emerald-300 via-green-200 to-white bg-clip-text text-transparent">
                    {slide.titleAccent}
                  </span>
                </h1>

                <p class="mt-3 max-w-lg text-sm leading-relaxed text-white/55 md:text-base">
                  {slide.description}
                </p>
              </div>
            ))}
          </div>

          <div class="mt-7 flex flex-wrap items-center gap-3">
            <WAButton
              text="Konsultasi Gratis"
              message="Halo, saya ingin konsultasi mengenai maklon skincare."
              variant="white"
              class="rounded-xl shadow-xl shadow-black/20"
            />
            <a href="/outsourcing-flow"
              class="group inline-flex h-11 items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-6 text-xs font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/40 hover:bg-white/10">
              Lihat Alur Maklon
              <Icon name="lucide:arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" />
            </a>
          </div>
        </div>
      </Container>

      <!-- Slide indicators — tengah bawah -->
      <div class="absolute bottom-5 left-1/2 z-10 flex -translate-x-1/2 items-center gap-3">
        {homeHeroSlides.map((_, idx) => (
          <button
            class="hero-dot rounded-full bg-white transition-all duration-500"
            class:list={{ "h-3 w-10 bg-white": idx === 0, "h-3 w-3 bg-white/35 hover:bg-white/55": idx !== 0 }}
            data-slide={idx}
            aria-label={`Slide ${idx + 1}`}
          ></button>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. CATEGORY — Kategori tipografi                                   -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-12 md:py-14">
      <Container>
        <SectionHeader label="Kategori" title="Jelajahi Rangkaian Produk Kami" />

        <div class="mt-8 grid grid-cols-2 gap-3 lg:grid-cols-4 lg:gap-4">
          {categories.map((cat, index) => {
            return (
              <a href={`/products?category=${encodeURIComponent(cat.name)}`}
                class="reveal-up group flex min-h-28 flex-col rounded-2xl bg-primary p-4 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:bg-primary/90 hover:shadow-lg md:min-h-32 md:p-5"
                data-reveal-delay={index * 90}
              >
                <span class="text-xs font-bold tracking-[0.2em] text-white/70">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <div class="mt-auto">
                  <span class="block h-px w-8 bg-white/70 transition-all duration-300 group-hover:w-full"></span>
                  <h3 class="mt-3 text-xl font-black tracking-tight text-white md:text-2xl">
                    {cat.name}
                  </h3>
                </div>
                <span class="mt-3 flex items-center gap-2 text-xs font-bold tracking-wide text-white/85" aria-hidden="true">
                  Lihat produk <Icon name="lucide:arrow-up-right" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" />
                </span>
              </a>
            );
          })}
          </div>
      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 3. STATS — Animated counters                                       -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-primary py-14 md:py-20">
      <!-- Decorative overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/80 via-primary to-primary/90"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <Container class="relative z-10">
        <div class="mb-10 text-center md:mb-12">
          <h2 class="mt-3 font-heading text-3xl font-bold text-white md:text-4xl">
            Wujudkan Brand Anda Bersama Magna
          </h2>
        </div>
        <div class="grid grid-cols-2 gap-5 md:grid-cols-4 md:gap-6">
          {[
            { value: 500, suffix: "+", label: "Formula Siap Pakai" },
            { value: 200, suffix: "+", label: "Brand Partner" },
            { value: 10, suffix: "+", label: "Tahun Pengalaman" },
            { value: 50, suffix: "+", label: "Tenaga Ahli" },
          ].map((stat) => (
            <div class="group relative overflow-hidden rounded-2xl border border-white/15 bg-white/10 p-6 text-center backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:border-white/25 hover:bg-white/15">
              <p class="text-3xl font-black text-white tabular-nums md:text-4xl">
                <span class="stat-counter" data-target={stat.value}>{stat.value}</span>{stat.suffix}
              </p>
              <p class="mt-1.5 text-xs font-semibold tracking-wider text-white/60 uppercase">{stat.label}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 4. LAYANAN — Service cards with image hover overlay                 -->
    <!-- ================================================================== -->
    <section id="layanan" class="bg-base-200/40 py-16 md:py-20">
      <Container>
        <SectionHeader label="Layanan" title="Solusi Lengkap untuk Brand Kecantikan Anda" />

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {services.map((svc) => {
            const waService = createWhatsappLink(siteConfig.waNumber, `Halo, saya tertarik dengan layanan ${svc.title}. Bisa info lebih lanjut?`);
            return (
              <a href={waService} target="_blank" rel="noopener noreferrer"
                class="group relative min-h-72 overflow-hidden rounded-2xl bg-primary shadow-sm transition-all duration-500 hover:-translate-y-1 hover:shadow-xl"
              >
                <img src={svc.image} alt={svc.title} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center bg-black/35 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                  <span class="flex items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-bold text-primary shadow-lg">
                    <Icon name="lucide:message-circle" class="h-4 w-4" />
                    Konsultasi
                  </span>
                </div>
                <div class="absolute inset-x-0 bottom-0 p-6 text-white">
                  <h3 class="text-lg font-bold">{svc.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-white/75 line-clamp-2">{svc.desc}</p>
                </div>
              </a>
            );
          })}
        </div>

      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 5. KEUNGGULAN — Split layout: image left + cards right              -->
    <!-- ================================================================== -->
    <section id="keunggulan" class="bg-base-100 py-16 md:py-20">
      <Container>
        <SectionHeader label="Keunggulan">
          <span slot="title">Kenapa <span class="text-primary">Magna?</span></span>
        </SectionHeader>

        <div class="mt-16 flex flex-col gap-8 lg:items-stretch lg:flex-row">
          <!-- Left: Featured image -->
          <div class="reveal-up relative overflow-hidden rounded-2xl lg:w-[42%]">
            <img src="/assets/hero-home/lab.jpg" alt="Lab Magna" class="h-72 w-full object-cover lg:h-full" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent lg:bg-gradient-to-r lg:from-black/30"></div>
            <div class="absolute bottom-5 left-5 lg:top-5 lg:left-5 lg:bottom-auto">
              <span class="inline-block rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-bold tracking-wider text-white backdrop-blur-md uppercase">Lab R&D Internal</span>
            </div>
          </div>

          <!-- Right: Advantages grid -->
          <div class="grid gap-4 sm:grid-cols-2 lg:w-[58%] lg:grid-cols-6">
            {advantages.map((adv, index) => (
              <div
                class:list={[
                  "reveal-up group flex items-start gap-4 rounded-2xl border border-base-200/70 bg-white p-5 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg lg:col-span-2",
                  index === 4 && "sm:col-span-2",
                  index >= 3 && "lg:col-span-3",
                ]}
              >
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/8 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white group-hover:shadow-lg group-hover:shadow-primary/15">
                  <Icon name={adv.icon} class="h-5 w-5" />
                </div>
                <div class="min-w-0">
                  <h3 class="text-sm font-bold transition-colors duration-300 group-hover:text-primary">{adv.title}</h3>
                  <p class="mt-1 text-xs leading-relaxed text-base-content/50">{adv.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 6. PRODUCT SHOWCASE — Modern hover cards                            -->
    <!-- ================================================================== -->
    <section id="produk" class="bg-base-200/40 py-16 md:py-20">
      <Container>
        <SectionHeader label="Produk">
          <span slot="title">Produk yang Bisa <span class="text-primary">Kami Buat</span></span>
        </SectionHeader>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {topProducts.map((product) => {
            const waProduct = createWhatsappLink(siteConfig.waNumber, `Halo, saya tertarik dengan produk ${product.name}. Bisa info lebih lanjut?`);
            return (
            <div class="reveal-up">
              <!-- Card -->
              <a href={waProduct} target="_blank" rel="noopener noreferrer" class="group relative block aspect-square w-full overflow-hidden rounded-2xl border border-base-200/70 bg-base-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-md">
                <img src={product.image} alt={product.name} class="h-full w-full object-cover transition-all duration-500 group-hover:scale-105" loading="lazy" />
                <span class="absolute right-3 top-3 rounded-lg bg-primary px-3 py-1.5 text-xs font-bold text-white shadow-md shadow-black/20">{product.category}</span>
                <!-- Nama produk di dalam card bawah tengah -->
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent p-4 pt-12">
                  <h3 class="text-center text-sm font-bold text-white drop-shadow-md sm:text-base">{product.name}</h3>
                </div>
                <!-- Overlay hover/click: popup deskripsi -->
                <div class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl bg-black/55 p-4 opacity-0 backdrop-blur-[1px] transition-all duration-300 group-hover:opacity-100">
                  <p class="text-center text-sm leading-relaxed text-white/90">{product.desc}</p>
                  <span class="mt-4 inline-flex items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-bold text-primary shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Konsultasi
                  </span>
                </div>
              </a>
            </div>
            );
          })}
        </div>

        <div class="mt-10 text-center">
          <a href="/products" class="btn btn-outline btn-primary">
            Lihat Semua Produk
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 7. PROCESS — Timeline preview                                       -->
    <!-- ================================================================== -->
    <section id="alur" class="relative overflow-hidden bg-base-100 py-16 md:py-20">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-80 bg-gradient-to-b from-primary/[0.07] to-transparent"></div>
      <Container maxWidth="6xl" class="relative">
        <SectionHeader label="Alur" title="Proses Mudah & Transparan" />

        <div class="relative mt-14 md:mt-20">
          <div class="absolute bottom-8 left-6 top-13 w-[3px] -translate-x-1/2 rounded-full bg-primary md:left-1/2"></div>

          <div class="space-y-8 md:space-y-12">
            {processPreviewSteps.map((step, index) => {
              const isLeft = index % 2 === 0;
              return (
                <article class="relative grid grid-cols-1 md:grid-cols-2">
                  <div class:list={["relative ml-14 md:ml-0", isLeft ? "md:col-start-1 md:pr-14" : "md:col-start-2 md:pl-14"]}>
                    <div class="group relative rounded-2xl border border-base-200 bg-base-100 p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-xl sm:p-6">
                      <span class:list={["absolute top-13 hidden h-[3px] w-14 rounded-full bg-primary md:block", isLeft ? "-right-14" : "-left-14"]} />
                      <div class="flex items-start gap-4">
                        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary group-hover:text-white">
                          <Icon name={step.icon} size={22} />
                        </div>
                        <div class="min-w-0 flex-1">
                          <span class="text-[11px] font-black tracking-[0.18em] text-primary uppercase">Tahap {String(step.step).padStart(2, "0")}</span>
                          <h3 class="mt-1 text-lg font-black text-base-content sm:text-xl">{step.title}</h3>
                        </div>
                      </div>
                      <p class="mt-4 text-sm font-semibold leading-relaxed text-primary/80">{step.desc}</p>
                      <p class="mt-3 text-sm leading-relaxed text-base-content/60">{step.detail}</p>
                    </div>
                  </div>
                  <div class="absolute left-6 top-7 z-10 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full border-4 border-base-100 bg-primary text-sm font-black text-white md:left-1/2">{String(step.step).padStart(2, "0")}</div>
                </article>
              );
            })}

            {processSteps.slice(4, 5).map((step) => (
              <a href="/outsourcing-flow" class="group relative block" aria-label="Lihat tahap kelima dan alur maklon lengkap">
                <article class="relative grid grid-cols-1 md:grid-cols-2">
                  <div class="relative ml-14 md:col-start-1 md:ml-0 md:pr-14">
                    <div class="relative overflow-hidden rounded-2xl border border-base-200 bg-base-100 p-5 shadow-sm sm:p-6">
                      <span class="absolute top-13 -right-14 hidden h-[3px] w-14 rounded-full bg-primary md:block"></span>
                      <div class="blur-sm transition duration-300 group-hover:blur-none">
                        <div class="flex items-start gap-4">
                          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary"><Icon name={step.icon} size={22} /></div>
                          <div><span class="text-[11px] font-black tracking-[0.18em] text-primary uppercase">Tahap {String(step.step).padStart(2, "0")}</span><h3 class="mt-1 text-lg font-black sm:text-xl">{step.title}</h3></div>
                        </div>
                        <p class="mt-4 text-sm font-semibold leading-relaxed text-primary/80">{step.desc}</p>
                      </div>
                      <span class="absolute inset-0 flex items-center justify-center bg-base-100/35 text-sm font-bold text-primary backdrop-blur-[1px] transition-colors group-hover:bg-base-100/15">Lanjutkan ke alur lengkap <Icon name="lucide:arrow-right" class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" /></span>
                    </div>
                  </div>
                  <div class="absolute left-6 top-7 z-10 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full border-4 border-base-100 bg-primary/70 text-sm font-black text-white md:left-1/2">{String(step.step).padStart(2, "0")}</div>
                </article>
              </a>
            ))}
          </div>
        </div>

        
      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 8. FACTORY GALLERY — Image cards w/ overlay                         -->
    <!-- ================================================================== -->
    <section class="bg-base-200/40 py-16 md:py-20">
      <Container>
        <SectionHeader label="Fasilitas">
          <span slot="title">Pabrik <span class="text-primary">Modern</span> & Terstandar</span>
        </SectionHeader>

        <div class="mx-auto mt-12 grid max-w-6xl grid-cols-2 gap-4 lg:grid-cols-4 lg:gap-5">
          {facilityGalleryItems.map((item) => (
            <div
              class:list={[
                "reveal-up group overflow-hidden rounded-2xl border border-base-200/70 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/15 hover:shadow-md",
                item.layout === "featured" && "col-span-2",
                item.layout === "wide" && "col-span-2",
              ]}
            >
              <div
                class:list={[
                  "relative overflow-hidden",
                  item.layout === "featured" && "aspect-[16/10] lg:aspect-[2/1]",
                  item.layout === "square" && "aspect-square",
                  item.layout === "wide" && "aspect-[16/10] lg:aspect-[2/1]",
                ]}
              >
                <img
                  src={item.image}
                  alt={item.label}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-black/15 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 flex items-center gap-3 p-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white/15 text-white backdrop-blur-sm transition-colors duration-300 group-hover:bg-primary">
                    <Icon name={item.icon} class="h-4 w-4" />
                  </div>
                  <h3 class="text-sm font-bold text-white">{item.label}</h3>
                </div>
              </div>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 9. COMPARISON — Premium table                                        -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <Container maxWidth="6xl">
        <SectionHeader label="Perbandingan">
          <span slot="title">Yang Membedakan <span class="text-primary">Kami</span></span>
        </SectionHeader>

        <div class="reveal-up mt-12 overflow-hidden rounded-2xl border-2 border-primary/20 bg-white shadow-[0_8px_30px_-4px_rgba(101,146,135,0.15)]">
          <!-- Header -->
          <div class="flex bg-primary px-8 py-5">
            <div class="w-[34%] text-xs font-bold tracking-[0.12em] text-white/70 uppercase">Aspek</div>
            <div class="w-[33%] text-xs font-bold tracking-[0.12em] text-white uppercase flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-300"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Magna
            </div>
            <div class="w-[33%] text-xs font-bold tracking-[0.12em] text-white/50 uppercase">Maklon Biasa</div>
          </div>
          <!-- Rows -->
          {homeComparisonRows.map((row, i) => (
            <div class="flex items-center border-b border-base-200/60 px-8 py-5 transition-all duration-300 hover:bg-primary/[0.03] hover:shadow-inner last:border-b-0">
              <div class="flex w-[34%] items-center gap-2">
                <span class="flex h-7 w-7 items-center justify-center rounded-full bg-primary/10 text-xs font-bold text-primary">{i + 1}</span>
                <span class="text-sm font-bold text-base-content/80">{row.aspect}</span>
              </div>
              <div class="flex w-[33%] items-center gap-2.5">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/15">
                  <Icon name="lucide:check" class="h-4 w-4 text-primary" />
                </span>
                <span class="text-sm font-bold text-primary">{row.us}</span>
              </div>
              <div class="flex w-[33%] items-center gap-2.5">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-red-50">
                  <Icon name="lucide:x" class="h-4 w-4 text-red-400" />
                </span>
                <span class="text-sm text-base-content/40">{row.them}</span>
              </div>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- ================================================================== -->
    <!-- 10. SERTIFIKASI — Grid gambar sederhana                             -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-primary py-16 md:py-20">
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div class="pointer-events-none absolute -left-32 -top-32 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -right-32 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>

      <Container class="relative">
        <SectionHeader label="Sertifikasi" tone="light" title="Percayalah dengan Kami" />

        <div class="mt-12 grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-5">
          {certifications.map((cert) => (
            <div class="reveal-up group text-center">
              <div class="overflow-hidden rounded-xl border border-white/15 bg-white/10 shadow-sm backdrop-blur-sm transition-all duration-300 group-hover:-translate-y-1 group-hover:border-white/25 group-hover:bg-white/15 group-hover:shadow-lg">
                <img
                  src={cert.image}
                  alt={cert.name}
                  class="aspect-[3/4] w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <h3 class="mt-3 text-sm font-bold text-white">{cert.name}</h3>
            </div>
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/certification" class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-3 text-sm font-bold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white hover:text-primary hover:shadow-lg">
            Lihat Semua Sertifikasi
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </Container>
    </section>

    


    <!-- ================================================================== -->
    <!-- 12. FAQ — Accordion                                                  -->
    <!-- ================================================================== -->
    <section class="bg-base-200/40 py-16 md:py-20">
      <Container maxWidth="3xl">
        <SectionHeader label="FAQ">
          <span slot="title">Pertanyaan <span class="text-primary">Umum</span></span>
        </SectionHeader>

        <div class="mt-16 space-y-3">
          {faqs.slice(0, 6).map((faq, index) => (
            <FAQItem
              question={faq.q}
