---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import CTASection from "../components/sections/CTASection.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);

const contactInfoItems = [
  {
    icon: "mdi:whatsapp",
    label: "WhatsApp",
    value: "+62 853-1490-3325",
    href: waLink,
    hrefTarget: "_blank",
    color: "bg-success/10 text-success",
  },
  {
    icon: "lucide:mail",
    label: "Email",
    value: siteConfig.email,
    href: `mailto:${siteConfig.email}`,
    hrefTarget: "_self",
    color: "bg-blue-100 text-blue-600",
  },
  {
    icon: "lucide:map-pin",
    label: "Alamat",
    value: siteConfig.address,
    href: "https://maps.google.com/?q=Aquila+Magna+Indramayu",
    hrefTarget: "_blank",
    color: "bg-amber-100 text-amber-600",
  },
  {
    icon: "lucide:clock",
    label: "Jam Operasional",
    value: siteConfig.operationalHours,
    href: null,
    hrefTarget: null,
    color: "bg-purple-100 text-purple-600",
  },
];

const locations = [
  {
    id: "office",
    name: "Kantor Pusat",
    address: "Jl. Jati Blok Pulo Seger, Plumbon, Kec. Indramayu, Kabupaten Indramayu, Jawa Barat 45215",
    hours: "Senin – Jumat, 08:00 – 17:00",
    embedUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3965.5148900000000!2d108.32000000000001!3d-6.325000000000001!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMTknMzAuMCJTIDEwOMKwMTknMTIuMCJF!5e0!3m2!1sid!2sid!4v1719700000000",
  },
  {
    id: "factory",
    name: "Pabrik Produksi",
    address: "Kawasan Industri Indramayu, Jawa Barat",
    hours: "Senin – Sabtu, 07:00 – 16:00",
    embedUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3965.6000000000000!2d108.33000000000001!3d-6.315000000000001!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMTgnNTQuMCJTIDEwOMKwMTknNDguMCJF!5e0!3m2!1sid!2sid!4v1719700000000",
  },
  {
    id: "branch",
    name: "Cabang Jakarta",
    address: "Jakarta Pusat, DKI Jakarta",
    hours: "Senin – Jumat, 09:00 – 17:00",
    embedUrl: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.598457548407!2d106.82654237480395!3d-6.184877693800212!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69f43d20d35917%3A0x909b6a19419db25!2sMonas%2C%20Jakarta%20Pusat!5e0!3m2!1sid!2sid!4v1719705600000",
  },
];
---

<MainLayout
  title="Kontak | Aquila Magna Maklon"
  description="Hubungi tim Aquila Magna untuk konsultasi maklon skincare & kosmetik. Kantor di Indramayu, Jawa Barat."
>

  <main class="overflow-x-hidden">

    <!-- ================================================================== -->
    <!-- 1. PAGE HEADER                                                     -->
    <!-- ================================================================== -->
    <section class="relative bg-gradient-to-b from-base-200/30 via-base-100 to-base-100 pb-12 pt-32 md:pb-16 md:pt-40">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary">Hubungi Kami</p>
          <h1 class="mt-3 text-4xl font-black tracking-tight md:text-5xl lg:text-6xl">
            Hubungi Tim Aquila Magna
          </h1>
          <p class="mx-auto mt-4 max-w-xl text-base text-base-content/50 md:mt-5 md:text-lg">
            Konsultasikan kebutuhan maklon skincare Anda bersama tim kami. Kami siap membantu dari formulasi hingga produk siap jual.
          </p>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. CONTACT FORM + INFO — Two column layout                         -->
    <!-- ================================================================== -->
    <section class="bg-base-100 pb-20 md:pb-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-5">

          <!-- LEFT: Consultation Form (3 cols) -->
          <div class="lg:col-span-3">
            <div class="rounded-3xl border border-base-200/80 bg-white p-6 shadow-sm md:p-8 lg:p-10">
              <div class="mb-7">
                <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary">Konsultasi Gratis</p>
                <h2 class="mt-2 text-2xl font-black md:text-3xl">Ceritakan Kebutuhan Anda</h2>
                <p class="mt-1.5 text-sm text-base-content/45">
                  Isi form di bawah — tim kami akan merespon dalam <span class="font-semibold text-base-content/70">1×24 jam</span>.
                </p>
              </div>

              <form class="space-y-5" data-wa-number={siteConfig.waNumber} id="consultForm">
                <!-- Nama -->
                <div>
                  <label for="nama" class="mb-1.5 block text-sm font-semibold">
                    Nama Lengkap <span class="text-error">*</span>
                  </label>
                  <input
                    type="text" id="nama" name="nama" required
                    placeholder="Masukkan nama lengkap Anda"
                    class="block w-full rounded-xl border border-base-200 bg-base-50 px-4 py-3 text-sm outline-none transition-all placeholder:text-base-content/25 focus:border-primary/40 focus:ring-4 focus:ring-primary/5"
                  />
                </div>

                <!-- WhatsApp & Email -->
                <div class="grid gap-4 sm:grid-cols-2">
                  <div>
                    <label for="wa" class="mb-1.5 block text-sm font-semibold">
                      WhatsApp <span class="text-error">*</span>
                    </label>
                    <input
                      type="tel" id="wa" name="wa" required
                      placeholder="0812-3456-7890"
                      class="block w-full rounded-xl border border-base-200 bg-base-50 px-4 py-3 text-sm outline-none transition-all placeholder:text-base-content/25 focus:border-primary/40 focus:ring-4 focus:ring-primary/5"
                    />
                  </div>
                  <div>
                    <label for="email" class="mb-1.5 block text-sm font-semibold">Email</label>
                    <input
                      type="email" id="email" name="email"
                      placeholder="contoh@email.com"
                      class="block w-full rounded-xl border border-base-200 bg-base-50 px-4 py-3 text-sm outline-none transition-all placeholder:text-base-content/25 focus:border-primary/40 focus:ring-4 focus:ring-primary/5"
                    />
                  </div>
                </div>

                <!-- Produk & MOQ/Budget -->
                <div class="grid gap-4 sm:grid-cols-2">
                  <div>
                    <label for="produk" class="mb-1.5 block text-sm font-semibold">
                      Jenis Produk <span class="text-error">*</span>
                    </label>
                    <select id="produk" name="produk" required
                      class="block w-full rounded-xl border border-base-200 bg-base-50 px-4 py-3 text-sm outline-none transition-all focus:border-primary/40 focus:ring-4 focus:ring-primary/5">
                      <option value="" disabled selected>Pilih jenis produk</option>
                      <option value="Skincare">Skincare</option>
                      <option value="Bodycare">Bodycare</option>
                      <option value="Haircare">Haircare</option>
                      <option value="Parfum">Parfum / Fragrance</option>
                      <option value="Makeup">Makeup / Kosmetik</option>
                      <option value="Baby Care">Baby Care</option>
                      <option value="Lainnya">Lainnya</option>
                    </select>
                  </div>
                  <div>
                    <label for="estimasi" class="mb-1.5 block text-sm font-semibold">Estimasi / Budget</label>
                    <select id="estimasi" name="estimasi"
                      class="block w-full rounded-xl border border-base-200 bg-base-50 px-4 py-3 text-sm outline-none transition-all focus:border-primary/40 focus:ring-4 focus:ring-primary/5">
                      <option value="" disabled selected>Pilih estimasi</option>
                      <option value="500-1000 pcs">500 – 1.000 pcs</option>
                      <option value="1000-5000 pcs">1.000 – 5.000 pcs</option>
                      <option value="5000-10000 pcs">5.000 – 10.000 pcs</option>
                      <option value="10000+ pcs">10.000+ pcs</option>
                      <option value="Belum tahu">Belum tahu</option>
                    </select>
                  </div>
                </div>

                <!-- Pesan -->
                <div>
                  <label for="pesan" class="mb-1.5 flex items-center justify-between">
                    <span class="text-sm font-semibold">Pesan</span>
                    <span class="text-[11px] text-base-content/30">Opsional</span>
                  </label>
                  <textarea
                    id="pesan" name="pesan" rows={4}
                    placeholder="Ceritakan tentang ide atau kebutuhan produk Anda..."
                    class="block w-full rounded-xl border border-base-200 bg-base-50 px-4 py-3 text-sm leading-relaxed outline-none transition-all resize-y placeholder:text-base-content/25 focus:border-primary/40 focus:ring-4 focus:ring-primary/5"
                  ></textarea>
                  <p class="mt-1 text-right text-[11px] text-base-content/30" id="char-count">0 / 500 karakter</p>
                </div>

                <!-- Submit -->
                <button type="submit"
                  class="group relative flex w-full items-center justify-center gap-2.5 overflow-hidden rounded-xl bg-primary px-8 py-3.5 text-sm font-bold text-white shadow-md shadow-primary/15 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20"
                >
                  <Icon name="mdi:whatsapp" size={18} class="relative z-10" />
                  <span class="relative z-10">Kirim via WhatsApp</span>
                </button>
              </form>
            </div>
          </div>

          <!-- RIGHT: Contact Info Cards (2 cols) -->
          <div class="lg:col-span-2">
            <div class="space-y-4">
              {contactInfoItems.map((item) => {
                const content = (
                  <div class="flex items-start gap-4">
                    <div class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-xl ${item.color}`}>
                      <Icon name={item.icon} size={22} />
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-bold text-base-content">{item.label}</p>
                      <p class="mt-0.5 text-sm text-base-content/55 leading-relaxed break-words">{item.value}</p>
                    </div>
                  </div>
                );

                if (item.href) {
                  return (
                    <a
                      href={item.href}
                      target={item.hrefTarget ?? "_blank"}
                      rel={item.hrefTarget === "_blank" ? "noopener noreferrer" : undefined}
                      class="block rounded-2xl border border-base-200/80 bg-white p-5 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md hover:border-primary/20"
                    >
                      {content}
                    </a>
                  );
                }

                return (
                  <div class="rounded-2xl border border-base-200/80 bg-white p-5 shadow-sm">
                    {content}
                  </div>
                );
              })}
            </div>

            <!-- Quick WhatsApp CTA -->
            <div class="mt-6 rounded-2xl bg-primary/5 border border-primary/10 p-5 text-center">
              <p class="text-sm font-semibold text-primary">Butuh jawaban cepat?</p>
              <p class="mt-1 text-xs text-base-content/45">Tim kami standby via WhatsApp selama jam operasional.</p>
              <a
                href={waLink}
                target="_blank" rel="noopener noreferrer"
                class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white shadow-md shadow-primary/15 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20"
              >
                <Icon name="mdi:whatsapp" size={18} />
                Chat WhatsApp Sekarang
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. LOCATIONS — Cards (left) + Interactive Map (right)              -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/30 pb-20 md:pb-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <!-- Section header -->
        <div class="mb-10 md:mb-14">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary">Lokasi</p>
          <h2 class="mt-2 text-3xl font-black md:text-4xl">Temukan Kami</h2>
          <p class="mt-2 text-sm text-base-content/50 md:text-base">Kantor, pabrik, dan cabang kami siap melayani Anda.</p>
        </div>

        <div class="grid gap-8 lg:grid-cols-5">
          <!-- LEFT: Location Cards -->
          <div class="space-y-3 lg:col-span-2" id="locationCards">
            {locations.map((loc, idx) => (
              <button
                type="button"
                data-map={loc.embedUrl}
                data-id={loc.id}
                class:list={[
                  "location-card group w-full rounded-2xl border p-5 text-left transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md",
                  idx === 0 ? "border-primary/30 bg-white shadow-sm" : "border-base-200/60 bg-white/70",
                ]}
              >
                <div class="flex items-start gap-4">
                  <div
                    class:list={[
                      "mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl transition-colors",
                      idx === 0 ? "bg-primary/10 text-primary" : "bg-base-200/80 text-base-content/40 group-hover:bg-primary/8 group-hover:text-primary",
                    ]}
                  >
                    <Icon name={loc.id === "office" ? "lucide:building-2" : loc.id === "factory" ? "lucide:factory" : "lucide:map-pin"} size={20} />
                  </div>
                  <div>
                    <p
                      class:list={[
                        "text-sm font-bold transition-colors",
                        idx === 0 ? "text-primary" : "text-base-content/80 group-hover:text-primary",
                      ]}
                    >
                      {loc.name}
                    </p>
                    <p class="mt-0.5 text-xs leading-relaxed text-base-content/45">{loc.address}</p>
                    <div class="mt-2 inline-flex items-center gap-1 text-[11px] text-base-content/35">
                      <Icon name="lucide:clock" size={11} />
                      {loc.hours}
                    </div>
                  </div>
                </div>
              </button>
            ))}
          </div>

          <!-- RIGHT: Interactive Map -->
          <div class="lg:col-span-3">
            <div class="overflow-hidden rounded-3xl border border-base-200/60 bg-white shadow-sm">
              <div class="relative h-[350px] md:h-[420px] lg:h-[480px]" id="locationMap">
                <iframe
                  id="locationMapFrame"
                  src={locations[0].embedUrl}
                  width="100%" height="100%" style="border:0;"
                  allowfullscreen="" loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Peta Lokasi"
                  class="absolute inset-0 h-full w-full"
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. CTA BANNER                                                      -->
    <!-- ================================================================== -->
    <CTASection
      title="Siap Memulai Brand Skincare Anda?"
      description="Konsultasikan ide produk Anda sekarang dan mulai bangun brand skincare bersama partner maklon yang tepat."
      buttonText="Konsultasi via WhatsApp"
    />

  </main>
</MainLayout>

<!-- ==================================================================== -->
<!-- Client-side: form submission + interactive map switching              -->
<!-- ==================================================================== -->
<script>
  import { createConsultationMessage, createWhatsappLink } from "../lib/whatsapp";

  document.addEventListener('DOMContentLoaded', function () {

    // --- Character counter ---
    const pesanTextarea = document.getElementById('pesan') as HTMLTextAreaElement | null;
    const charCount = document.getElementById('char-count');
    if (pesanTextarea && charCount) {
      pesanTextarea.addEventListener('input', () => {
        const len = pesanTextarea.value.length;
        charCount.textContent = `${len} / 500 karakter`;
        charCount.style.color = len > 450 ? '#c76b6b' : '';
      });
    }

    // --- Form submission ---
    const form = document.getElementById('consultForm');
    if (form) {
      const waNumber = form.getAttribute('data-wa-number');
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        const getValue = (id: string) => {
          const field = document.getElementById(id);
          return field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement ? field.value : '';
        };
        const fields = {
          nama: getValue('nama'),
          wa: getValue('wa'),
          email: getValue('email'),
          produk: getValue('produk'),
          estimasi: getValue('estimasi'),
          kategori: '',
          pesan: getValue('pesan'),
        };
        const message = createConsultationMessage(fields);
        window.open(createWhatsappLink(waNumber || '', message), '_blank', 'noopener,noreferrer');
      });
    }

    // --- Interactive location card → map switching ---
    const cards = document.querySelectorAll('.location-card');
    const mapFrame = document.getElementById('locationMapFrame') as HTMLIFrameElement | null;

    cards.forEach((card) => {
      card.addEventListener('click', function () {
        const btn = card as HTMLElement;
        const mapUrl = btn.getAttribute('data-map');
        if (mapFrame && mapUrl) {
          mapFrame.src = mapUrl;
        }

        // Reset all cards to default state
        cards.forEach((c) => {
          c.classList.remove('border-primary/30', 'bg-white');
          c.classList.add('border-base-200/60', 'bg-white/70');
          const iconWrap = c.querySelector('.flex.h-10.w-10');
          if (iconWrap) {
            iconWrap.classList.remove('bg-primary/10', 'text-primary');
            iconWrap.classList.add('bg-base-200/80', 'text-base-content/40');
          }
          const nameEl = c.querySelector('p.text-sm');
          if (nameEl) {
            nameEl.classList.remove('text-primary');
            nameEl.classList.add('text-base-content/80');
          }
        });

        // Activate clicked card
        btn.classList.remove('border-base-200/60', 'bg-white/70');
        btn.classList.add('border-primary/30', 'bg-white');
        const activeIcon = btn.querySelector('.flex.h-10.w-10');
        if (activeIcon) {
          activeIcon.classList.remove('bg-base-200/80', 'text-base-content/40');
          activeIcon.classList.add('bg-primary/10', 'text-primary');
        }
        const activeName = btn.querySelector('p.text-sm');
        if (activeName) {
          activeName.classList.remove('text-base-content/80');
          activeName.classList.add('text-primary');
        }
      });
    });
  });
</script>
