---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/ui/Container.astro";
import Icon from "../components/ui/Icon.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { siteConfig } from "../data/site";
import { contactLocations } from "../data/contact";
import { createWhatsappLink } from "../lib/whatsapp";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
const displayWa = `+${siteConfig.waNumber.replace(/^(\d{2})(\d{3})(\d{4})(\d+)$/, "$1 $2-$3-$4")}`;

const inputClass =
  "block w-full rounded-xl border border-base-200 bg-white px-4 py-3 text-sm outline-none transition-all placeholder:text-base-content/30 focus:border-primary/50 focus:ring-4 focus:ring-primary/5";

const contactItems = [
  {
    icon: "lucide:clock",
    label: "Jam Operasional",
    value: siteConfig.operationalHours,
    href: null,
    external: false,
    action: null,
  },
];
---

<MainLayout
  title="Kontak | Magna Maklon"
  description="Hubungi tim Magna untuk konsultasi maklon skincare. Kantor di Indramayu, Jawa Barat."
  showGlobalCta={false}
>
  <main data-contact class="overflow-x-hidden bg-base-100">
    <!-- Kontak + Form -->
    <section class="py-12 md:py-16">
      <Container maxWidth="6xl">
        <SectionHeader label="Kontak" class="mb-10">
          <span slot="title">Hubungi <span class="text-primary">Tim Magna</span></span>
        </SectionHeader>

        <div class="grid gap-6 lg:grid-cols-12 lg:gap-8">
          <!-- Info kontak -->
          <aside class="lg:col-span-4">
            <div class="space-y-3">
              {
                contactItems.map((item) => (
                  <div class="rounded-2xl border border-base-200/80 bg-white p-4 shadow-sm">
                    <div class="flex items-start gap-3">
                      <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                        <Icon name={item.icon} size={18} />
                      </span>
                      <div class="min-w-0 flex-1">
                        <p class="text-[11px] font-semibold uppercase tracking-wider text-base-content/40">
                          {item.label}
                        </p>
                        {item.href ? (
                          <a
                            href={item.href}
                            target={item.external ? "_blank" : undefined}
                            rel={item.external ? "noopener noreferrer" : undefined}
                            class="mt-0.5 block break-all text-sm font-bold text-base-content hover:text-primary"
                          >
                            {item.value}
                          </a>
                        ) : (
                          <p class="mt-0.5 text-sm font-bold text-base-content">{item.value}</p>
                        )}
                        {item.label === "Jam Operasional" && (
                          <p class="mt-1 text-xs font-bold text-error">Sabtu - Minggu: Libur</p>
                        )}
                      </div>
                    </div>
                  </div>
                ))
              }


            </div>
          </aside>

          <!-- Form -->
          <div class="lg:col-span-8" id="form-konsultasi">
            <div class="rounded-2xl border border-base-200/80 bg-white p-5 shadow-sm md:p-7">
              <div class="mb-6 border-b border-base-200/70 pb-5">
                <h2 class="text-lg font-black text-base-content md:text-xl">
                  Form <span class="text-primary">Konsultasi Maklon</span>
                </h2>
                <p class="mt-1 text-sm text-base-content/50">
                  Isi data berikut — pesan akan terkirim otomatis ke WhatsApp kami.
                </p>
              </div>

              <form
                class="space-y-6"
                data-wa-number={siteConfig.waNumber}
                id="consultForm"
                novalidate
              >
                <div class="grid gap-4 sm:grid-cols-2">
                  <div class="sm:col-span-2">
                    <label
                      for="nama"
                      class="mb-1.5 block text-sm font-semibold text-base-content/80"
                    >
                      Nama Lengkap <span class="text-error">*</span>
                    </label>
                    <input
                      type="text"
                      id="nama"
                      name="nama"
                      required
                      autocomplete="name"
                      placeholder="Contoh: Budi Santoso"
                      class={inputClass}
                    />
                    <p class="field-error mt-1 hidden text-xs text-error" data-for="nama">
                      Nama wajib diisi.
                    </p>
                  </div>

                  <div>
                    <label for="wa" class="mb-1.5 block text-sm font-semibold text-base-content/80">
                      Nomor WhatsApp <span class="text-error">*</span>
                    </label>
                    <input
                      type="tel"
                      id="wa"
                      name="wa"
                      required
                      autocomplete="tel"
                      inputmode="tel"
                      placeholder="08xx-xxxx-xxxx"
                      class={inputClass}
                    />
                    <p class="field-error mt-1 hidden text-xs text-error" data-for="wa">
                      Nomor WhatsApp wajib diisi.
                    </p>
                  </div>

                  <div>
                    <label
                      for="email"
                      class="mb-1.5 block text-sm font-semibold text-base-content/80"
                    >
                      Email
                      <span class="text-[11px] font-normal text-base-content/35">(opsional)</span>
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      autocomplete="email"
                      placeholder="contoh@email.com"
                      class={inputClass}
                    />
                  </div>

                  <div>
                    <label
                      for="produk"
                      class="mb-1.5 block text-sm font-semibold text-base-content/80"
                    >
                      Jenis Produk <span class="text-error">*</span>
                    </label>
                    <select id="produk" name="produk" required class={inputClass}>
                      <option value="" disabled selected>Pilih jenis produk</option>
                      <option value="Skincare">Skincare</option>
                      <option value="Bodycare">Bodycare</option>
                      <option value="Haircare">Haircare</option>
                      <option value="Baby Care">Baby Care</option>
                      <option value="Lainnya">Lainnya</option>
                    </select>
                    <p class="field-error mt-1 hidden text-xs text-error" data-for="produk">
                      Pilih jenis produk.
                    </p>
                  </div>

                  <div>
                    <label
                      for="estimasi"
                      class="mb-1.5 block text-sm font-semibold text-base-content/80"
                    >
                      Estimasi Produksi
                      <span class="text-[11px] font-normal text-base-content/35">(opsional)</span>
                    </label>
                    <select id="estimasi" name="estimasi" class={inputClass}>
                      <option value="" disabled selected>Pilih estimasi</option>
                      <option value="500-1000 pcs">500 – 1.000 pcs</option>
                      <option value="1000-5000 pcs">1.000 – 5.000 pcs</option>
                      <option value="5000-10000 pcs">5.000 – 10.000 pcs</option>
                      <option value="10000+ pcs">10.000+ pcs</option>
                      <option value="Belum tahu">Belum tahu</option>
                    </select>
                  </div>

                  <div>
                    <label
                      for="statusMerek"
                      class="mb-1.5 block text-sm font-semibold text-base-content/80"
                    >
                      Status Merek <span class="text-error">*</span>
                    </label>
                    <select id="statusMerek" name="statusMerek" required class={inputClass}>
                      <option value="" disabled selected>Pilih status merek</option>
                      <option value="Sudah punya merek">Sudah punya merek</option>
                      <option value="Belum punya merek">Belum punya merek</option>
                    </select>
                    <p class="field-error mt-1 hidden text-xs text-error" data-for="statusMerek">
                      Pilih status merek.
                    </p>
                  </div>

                  <div class="sm:col-span-2">
                    <label for="pesan" class="mb-1.5 flex items-center justify-between">
                      <span class="text-sm font-semibold text-base-content/80">Pesan Tambahan</span>
                      <span class="text-[11px] text-base-content/35" id="char-count">0 / 500</span>
                    </label>
                    <textarea
                      id="pesan"
                      name="pesan"
                      rows={4}
                      maxlength={500}
                      placeholder="Ceritakan ide produk, target pasar, atau pertanyaan Anda..."
                      class={`${inputClass} resize-y leading-relaxed`}></textarea>
                  </div>
                </div>

                <div class="border-t border-base-200/70 pt-5">
                  <button
                    type="submit"
                    id="submitBtn"
                    class="flex w-full items-center justify-center gap-2.5 rounded-xl bg-primary px-8 py-3.5 text-sm font-bold text-white shadow-md shadow-primary/15 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto sm:min-w-[220px]"
                  >
                    <Icon name="mdi:whatsapp" size={18} />
                    <span id="submitBtnText">Kirim via WhatsApp</span>
                  </button>
                  <p class="mt-3 text-xs text-base-content/40">
                    Dengan mengirim form, Anda akan diarahkan ke WhatsApp dengan pesan yang sudah
                    terisi.
                  </p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Lokasi -->
    <section
      id="lokasi"
      class="scroll-mt-24 border-t border-base-200/60 bg-base-200/30 py-12 md:py-16"
    >
      <Container maxWidth="6xl">
        <div class="overflow-hidden rounded-2xl border border-base-200/80 bg-white shadow-sm">
          <!-- Tab lokasi — full width, rapi di mobile -->
          <div
            class="hidden grid-cols-2 gap-1 border-b border-base-200/70 bg-base-50/60 p-1.5"
            id="locationPills"
            role="tablist"
            aria-label="Pilih lokasi"
          >
            {
              contactLocations.map((loc, idx) => (
                <button
                  type="button"
                  role="tab"
                  aria-selected={idx === 0 ? "true" : "false"}
                  aria-controls="locationMapPanel"
                  id={`location-tab-${loc.id}`}
                  data-map={loc.embedUrl}
                  data-maps={loc.mapsUrl}
                  data-id={loc.id}
                  data-name={loc.name}
                  data-address={loc.address}
                  data-hours={loc.hours}
                  data-icon={loc.icon}
                  class:list={[
                    "location-pill flex flex-col items-center justify-center gap-1.5 rounded-xl px-2 py-3 text-center transition-all sm:flex-row sm:gap-2 sm:px-4 sm:py-3",
                    idx === 0
                      ? "bg-primary text-white shadow-sm"
                      : "bg-white text-base-content/55 hover:bg-primary/5 hover:text-primary",
                  ]}
                >
                  <Icon name={loc.icon} size={18} class="shrink-0" />
                  <span class="text-[11px] font-bold leading-tight sm:hidden">{loc.shortName}</span>
                  <span class="hidden text-sm font-bold leading-tight sm:inline">{loc.name}</span>
                </button>
              ))
            }
          </div>

          <div class="flex flex-col lg:grid lg:grid-cols-5">
            <!-- Peta — tampil dulu di mobile -->
            <div class="order-1 lg:order-2 lg:col-span-5">
              <div
                class="relative aspect-[16/11] w-full min-h-[220px] sm:aspect-[16/10] sm:min-h-[280px] lg:min-h-[340px] lg:aspect-auto lg:h-full"
                id="locationMapPanel"
                role="tabpanel"
                aria-labelledby="location-tab-office"
              >
                <iframe
                  id="locationMapFrame"
                  src={contactLocations[0].embedUrl}
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`Peta ${contactLocations[0].name}`}
                  class="absolute inset-0 h-full w-full"></iframe>
              </div>
            </div>

            <!-- Detail alamat -->
            <div
              class="hidden order-2 border-t border-base-200/70 p-4 sm:p-5 lg:order-1 lg:col-span-2 lg:border-r lg:border-t-0"
            >
              <div class="flex items-start gap-3">
                <span
                  id="locationIconWrap"
                  class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary"
                >
                  <Icon name={contactLocations[0].icon} size={20} />
                </span>
                <div class="min-w-0 flex-1">
                  <p class="text-[11px] font-semibold uppercase tracking-wider text-primary/60">
                    Lokasi
                  </p>
                  <h3
                    id="locationName"
                    class="mt-1 text-base font-bold text-base-content sm:text-lg"
                  >
                    {contactLocations[0].name}
                  </h3>
                </div>
              </div>

              <div class="mt-4 space-y-3">
                <div class="flex items-start gap-2.5">
                  <Icon name="lucide:map-pin" size={16} class="mt-0.5 shrink-0 text-primary/70" />
                  <p id="locationAddress" class="text-sm leading-relaxed text-base-content/65">
                    {contactLocations[0].address}
                  </p>
                </div>
                <div class="flex items-start gap-2.5">
                  <Icon name="lucide:clock" size={16} class="mt-0.5 shrink-0 text-primary/70" />
                  <p id="locationHours" class="text-sm text-base-content/65">
                    {contactLocations[0].hours}
                  </p>
                </div>
              </div>

              <a
                id="locationMapLink"
                href={contactLocations[0].mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3 text-sm font-bold text-white shadow-sm shadow-primary/15 transition-all hover:bg-primary/90"
              >
                <Icon name="lucide:navigation" size={16} />
                Buka di Google Maps
              </a>
            </div>
          </div>
        </div>
      </Container>
    </section>
  </main>
</MainLayout>

<style>
  @media (min-width: 768px) {
    .location-header {
      margin-left: auto;
      margin-right: auto;
      max-width: 42rem;
      text-align: center;
    }

    .location-header :global(> div:first-child) {
      justify-content: center;
    }
  }
</style>

<script>
  import { createConsultationMessage, createWhatsappLink } from "../lib/whatsapp";

  document.addEventListener("DOMContentLoaded", () => {
    const root = document.querySelector<HTMLElement>("[data-contact]");
    if (!root) return;

    const pesanTextarea = root.querySelector("#pesan") as HTMLTextAreaElement | null;
    const charCount = root.querySelector("#char-count");
    pesanTextarea?.addEventListener("input", () => {
      const len = pesanTextarea.value.length;
      if (charCount) {
        charCount.textContent = `${len} / 500`;
        charCount.classList.toggle("text-error", len > 450);
        charCount.classList.toggle("text-base-content/35", len <= 450);
      }
    });

    const form = root.querySelector("#consultForm") as HTMLFormElement | null;
    const submitBtn = root.querySelector("#submitBtn") as HTMLButtonElement | null;
    const submitBtnText = root.querySelector("#submitBtnText");

    const showError = (id: string, show: boolean) => {
      const el = root.querySelector(`.field-error[data-for="${id}"]`);
      const input = root.querySelector(`#${id}`);
      el?.classList.toggle("hidden", !show);
      input?.classList.toggle("border-error/50", show);
      input?.classList.toggle("ring-2", show);
      input?.classList.toggle("ring-error/10", show);
    };

    const validateForm = () => {
      let valid = true;
      ["nama", "wa", "produk", "statusMerek"].forEach((id) => {
        const field = root.querySelector(`#${id}`) as HTMLInputElement | HTMLSelectElement | null;
        const empty = !field?.value.trim();
        showError(id, empty);
        if (empty) valid = false;
      });
      return valid;
    };

    ["nama", "wa", "produk", "statusMerek"].forEach((id) => {
      root.querySelector(`#${id}`)?.addEventListener("input", () => showError(id, false));
      root.querySelector(`#${id}`)?.addEventListener("change", () => showError(id, false));
    });

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!validateForm()) {
        const firstInvalid = form.querySelector(".field-error:not(.hidden)");
        const invalidField =
          (firstInvalid?.parentElement?.querySelector("input, select") as HTMLElement | null) ??
          (firstInvalid?.previousElementSibling as HTMLElement | null);
        invalidField?.focus();
        return;
      }

      const waNumber = form.getAttribute("data-wa-number");
      const getValue = (id: string) => {
        const field = root.querySelector(`#${id}`);
        return field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
          ? field.value
          : "";
      };

      submitBtn?.setAttribute("disabled", "true");
      if (submitBtnText) submitBtnText.textContent = "Membuka WhatsApp...";

      const message = createConsultationMessage({
        nama: getValue("nama"),
        wa: getValue("wa"),
        email: getValue("email"),
        produk: getValue("produk"),
        estimasi: getValue("estimasi"),
        statusMerek: getValue("statusMerek"),
        pesan: getValue("pesan"),
      });

      window.open(createWhatsappLink(waNumber || "", message), "_blank", "noopener,noreferrer");

      setTimeout(() => {
        submitBtn?.removeAttribute("disabled");
        if (submitBtnText) submitBtnText.textContent = "Kirim via WhatsApp";
      }, 2000);
    });

    const pills = root.querySelectorAll<HTMLButtonElement>(".location-pill");
    const mapFrame = root.querySelector("#locationMapFrame") as HTMLIFrameElement | null;
    const mapLink = root.querySelector("#locationMapLink") as HTMLAnchorElement | null;
    const mapPanel = root.querySelector("#locationMapPanel");
    const locationName = root.querySelector("#locationName");
    const locationAddress = root.querySelector("#locationAddress");
    const locationHours = root.querySelector("#locationHours");
    const locationIconWrap = root.querySelector("#locationIconWrap");

    function activateLocation(pill: HTMLButtonElement) {
      const mapUrl = pill.getAttribute("data-map");
      const mapsUrl = pill.getAttribute("data-maps");
      const locId = pill.getAttribute("data-id");
      const locName = pill.getAttribute("data-name");
      const locAddress = pill.getAttribute("data-address");
      const locHours = pill.getAttribute("data-hours");

      if (mapFrame && mapUrl) mapFrame.src = mapUrl;
      if (mapLink && mapsUrl) mapLink.href = mapsUrl;
      if (mapFrame && locName) mapFrame.title = `Peta ${locName}`;
      if (mapPanel && locId) mapPanel.setAttribute("aria-labelledby", `location-tab-${locId}`);
      if (locationName && locName) locationName.textContent = locName;
      if (locationAddress && locAddress) locationAddress.textContent = locAddress;
      if (locationHours && locHours) locationHours.textContent = locHours;
      if (locationIconWrap) {
        const iconInPill = pill.querySelector("svg");
        locationIconWrap.innerHTML = "";
        if (iconInPill) {
          const clone = iconInPill.cloneNode(true) as SVGElement;
          clone.setAttribute("width", "20");
          clone.setAttribute("height", "20");
          locationIconWrap.appendChild(clone);
        }
      }

      pills.forEach((p) => {
        const isActive = p === pill;
        p.setAttribute("aria-selected", isActive ? "true" : "false");
        p.classList.toggle("bg-primary", isActive);
        p.classList.toggle("text-white", isActive);
        p.classList.toggle("shadow-sm", isActive);
        p.classList.toggle("bg-white", !isActive);
        p.classList.toggle("text-base-content/55", !isActive);
        p.classList.toggle("hover:bg-primary/5", !isActive);
        p.classList.toggle("hover:text-primary", !isActive);
      });
    }

    pills.forEach((pill) => {
      pill.addEventListener("click", () => activateLocation(pill));
    });
  });
</script>
