---
import Icon from "../ui/Icon.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { visionMission } from "../../data/company";
---

<section id="visimisi" class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
  <SectionHeader
    label="Visi & Misi"
    variant="minimal"
    title="Komitmen Kami untuk Brand Kecantikan"
  />

  <div class="mt-8 grid gap-5 md:grid-cols-2">
    <!-- Vision -->
    <div class="card rounded-3xl border border-secondary/30 bg-secondary/10 shadow-sm backdrop-blur-sm h-full">
      <div class="card-body p-8 flex flex-col h-full">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/20 text-3xl">
          <Icon name="lucide:telescope" size={32} />
        </div>
        <h3 class="card-title mt-4 text-2xl">Visi</h3>
        <div class="mt-3">
          <p class="text-lg leading-relaxed text-base-content/80">
            {visionMission.vision}
          </p>
        </div>
        <div class="mt-auto border-t border-secondary/20 pt-4">
          <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-primary">Fokus Kami</p>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Kualitas Produk</span>
            <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Kemitraan Terpercaya</span>
            <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Inovasi Formula</span>
            <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-sm text-base-content/70">Kepuasan Brand</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Mission -->
    <div class="card rounded-3xl border border-secondary/30 bg-secondary/10 shadow-sm backdrop-blur-sm h-full">
      <div class="card-body p-8 flex flex-col h-full">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/20 text-3xl">
          <Icon name="lucide:target" size={32} />
        </div>
        <h3 class="card-title mt-4 text-2xl">Misi</h3>
        <ul class="mt-3 space-y-3">
          {visionMission.missions.map((mission) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/20 text-xs text-primary">
                <Icon name="lucide:check" size={12} />
              </span>
              <span class="text-base text-base-content/80">{mission}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
