---
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { advantages } from "../data/advantages";
import { factoryStats } from "../data/factory";
import { certifications } from "../data/certifications";
import { services } from "../data/services";
import { processSteps } from "../data/process";
import { testimonials } from "../data/testimonials";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
const waLinkCta = createWhatsappLink(
  siteConfig.waNumber,
  "Halo, saya ingin konsultasi maklon skincare.",
);
--->

<MainLayout
  title="Aquila Maklon – Jasa Maklon Skincare & Kosmetik Terpercaya"
  description={siteConfig.description}
>
  <main>
    <!-- =================================================================== -->
    <!-- 1. HERO — Full-width image banner with overlay                      -->
    <!-- =================================================================== -->
    <section class="relative flex min-h-[90vh] items-center overflow-hidden">
      <!-- Background gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/90 via-primary/80 to-secondary/70"></div>
      <!-- Subtle pattern overlay -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 40px 40px;"></div>
      <!-- Decorative blobs -->
      <div class="pointer-events-none absolute -right-32 -top-32 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -left-32 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>

      <div class="relative mx-auto w-full max-w-7xl px-4 py-24 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <span class="inline-block animate-pulse rounded-full border border-white/20 bg-white/10 px-5 py-2 text-xs font-semibold tracking-widest text-white/90 backdrop-blur-sm">
            ✨ Partner Maklon Profesional
          </span>

          <h1 class="mt-6 text-4xl font-black leading-tight text-white md:text-6xl lg:text-7xl">
            Wujudkan Brand Skincare & Kosmetik Sendiri
          </h1>
          <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-white/80 md:text-xl">
            Kami membantu proses maklon mulai dari konsultasi konsep, formulasi, sample produk, desain kemasan, legalitas BPOM/Halal, produksi massal, hingga produk siap jual.
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href={waLink}
              target="_blank"
              class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white bg-white px-10 text-base text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="mr-2"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Konsultasi via WhatsApp
            </a>
            <a
              href="/alur-maklon"
              class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white/30 bg-white/10 px-10 text-base text-white backdrop-blur-sm transition-all duration-300 hover:border-white/50 hover:bg-white/20"
            >
              Lihat Alur Maklon
            </a>
          </div>

          <!-- Trust badges row -->
          <div class="mt-12 flex flex-wrap items-center justify-center gap-6">
            <div class="flex items-center gap-2 text-white/70">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <span class="text-sm font-medium">BPOM Terdaftar</span>
            </div>
            <div class="flex items-center gap-2 text-white/70">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <span class="text-sm font-medium">Sertifikat Halal</span>
            </div>
            <div class="flex items-center gap-2 text-white/70">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <span class="text-sm font-medium">CPKB Standard</span>
            </div>
            <div class="flex items-center gap-2 text-white/70">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <span class="text-sm font-medium">ISO 9001:2015</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- =================================================================== -->
    <!-- 2. KEUNGGULAN (Advantages)                                          -->
    <!-- =================================================================== -->
    <section class="relative overflow-hidden bg-base-100 py-20">
      <div class="pointer-events-none absolute -right-60 -top-60 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Keunggulan</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Mengapa Memilih Aquila Maklon?</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Kami memberikan solusi terlengkap untuk brand kecantikan Anda dengan layanan profesional dari awal hingga akhir.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {advantages.map((adv) => (
            <div class="group card border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5">
              <div class="card-body items-center text-center p-8">
                <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/10 text-4xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-secondary/20">
                  {adv.icon}
                </div>
                <h3 class="card-title mt-4 text-xl">{adv.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-base-content/70">{adv.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 text-center">
          <a href="/tentang-kami" class="btn btn-soft rounded-full px-8 transition-all duration-300 hover:shadow-md">
            Pelajari Tentang Kami
          </a>
        </div>
      </div>
    </section>

    <!-- =================================================================== -->
    <!-- 3. STATISTIK BRAND (Numbers / Stats)                               -->
    <!-- =================================================================== -->
    <section class="relative bg-gradient-to-r from-primary to-secondary py-20">
      <div class="pointer-events-none absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 75% 75%, white 1px, transparent 1px); background-size: 30px 30px;"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="inline-block rounded-full border border-white/20 bg-white/10 px-5 py-1.5 text-xs font-semibold tracking-widest text-white/90 backdrop-blur-sm">BRAND STATISTICS</span>
          <h2 class="mt-4 text-3xl font-black text-white md:text-4xl lg:text-5xl">Aquila Maklon dalam Angka</h2>
          <p class="mt-3 text-white/70 md:text-lg">Ribuan produk telah dipercayakan kepada kami oleh brand-brand dari seluruh Indonesia.</p>
        </div>

        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          {factoryStats.map((stat) => (
            <div class="group text-center transition-all duration-500 hover:-translate-y-1">
              <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-2xl bg-white/10 backdrop-blur-sm transition-all duration-500 group-hover:bg-white/20 group-hover:scale-110">
                <span class="text-4xl font-black text-white drop-shadow-lg">{stat.value}</span>
              </div>
              <p class="mt-4 text-sm font-semibold text-white/80">{stat.label}</p>
              <div class="mx-auto mt-2 h-1 w-12 rounded-full bg-white/20 transition-all duration-500 group-hover:w-20 group-hover:bg-white/40"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- =================================================================== -->
    <!-- 4. SERTIFIKASI (Certifications)                                     -->
    <!-- =================================================================== -->
    <section class="bg-base-100 py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Sertifikasi</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Terpercaya dengan Legalitas Lengkap</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Setiap produk yang kami hasilkan didukung dengan legalitas dan sertifikasi resmi.
          </p>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
          {certifications.map((cert) => (
            <div class="group card border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5">
              <div class="card-body items-center text-center p-6">
                <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/10 text-3xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-secondary/20">
                  {cert.icon}
                </div>
                <h3 class="card-title mt-4 text-sm">{cert.name}</h3>
                <p class="mt-2 text-xs leading-relaxed text-base-content/60">{cert.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 text-center">
          <a href="/sertifikasi" class="btn btn-soft rounded-full px-8">Lihat Detail Sertifikasi</a>
        </div>
      </div>
    </section>

    <!-- =================================================================== -->
    <!-- 5. LAYANAN KAMI (Services)                                          -->
    <!-- =================================================================== -->
    <section class="relative overflow-hidden bg-base-200/50 py-20">
      <div class="pointer-events-none absolute -left-60 -bottom-60 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Layanan Kami</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Solusi Maklon untuk Brand Kecantikan</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Berbagai layanan maklon siap membantu Anda mewujudkan produk kecantikan impian.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {services.map((svc) => {
            const waService = createWhatsappLink(
              siteConfig.waNumber,
              `Halo, saya ingin konsultasi maklon untuk ${svc.title}.`,
            );
            return (
              <div class="group card border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5">
                <div class="card-body p-8">
                  <div class="mb-3 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/10 text-3xl transition-all duration-500 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-secondary/20">
                    {svc.icon}
                  </div>
                  <h3 class="card-title text-xl">{svc.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-base-content/70">{svc.desc}</p>
                  <div class="mt-4 rounded-xl bg-base-200/60 px-4 py-3">
                    <p class="text-xs font-semibold uppercase tracking-wider text-primary">Contoh produk:</p>
                    <p class="mt-1 text-sm text-base-content/60">{svc.examples}</p>
                  </div>
                  <div class="card-actions mt-5">
                    <a
                      href={waService}
                      target="_blank"
                      class="btn btn-primary btn-sm rounded-full w-full text-white transition-all duration-300 group-hover:shadow-md"
                    >
                      Konsultasikan {svc.title}
                    </a>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <div class="mt-12 text-center">
          <a href="/layanan" class="btn btn-soft rounded-full px-8">Lihat Semua Layanan</a>
        </div>
      </div>
    </section>

    <!-- =================================================================== -->
    <!-- 6. ALUR MAKLON (Process)                                            -->
    <!-- =================================================================== -->
    <section class="bg-base-100 py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Alur Maklon</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Bagaimana Cara Kerjanya?</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Proses maklon yang mudah, transparan, dan terstruktur — dari konsultasi hingga produk jadi.
          </p>
        </div>

        <div class="mt-14 relative">
          <!-- Connecting line (desktop) -->
          <div class="absolute left-1/2 top-0 hidden h-full w-0.5 -translate-x-1/2 bg-gradient-to-b from-primary via-secondary to-primary/20 md:block"></div>

          <div class="grid gap-8 md:grid-cols-2 md:gap-12">
            {processSteps.slice(0, 6).map((step, idx) => (
              <div class={`group relative flex items-start gap-5 ${idx % 2 === 0 ? "md:text-right md:flex-row-reverse" : ""}`}>
                <!-- Step number badge -->
                <div class="relative z-10 flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-primary to-secondary text-lg font-bold text-white shadow-lg transition-all duration-500 group-hover:scale-110 group-hover:shadow-xl">
                  {step.step}
                </div>
                <!-- Content -->
                <div class={`flex-1 rounded-2xl border border-base-200 bg-base-100 p-6 shadow-sm transition-all duration-500 group-hover:-translate-y-1 group-hover:border-primary/20 group-hover:shadow-lg ${idx % 2 === 0 ? "md:mr-8" : "md:ml-8"}`}>
                  <h3 class="text-lg font-bold">{step.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-base-content/70">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-14 text-center">
          <a href="/alur-maklon" class="btn btn-primary rounded-full px-10 text-white shadow-lg transition-all duration-300 hover:shadow-xl hover:scale-105">
            Lihat Alur Lengkap (9 Tahap)
          </a>
        </div>
      </div>
    </section>

    <!-- =================================================================== -->
    <!-- 7. REVIEW / TESTIMONIAL                                             -->
    <!-- =================================================================== -->
    <section class="relative overflow-hidden bg-base-200/50 py-20">
      <div class="pointer-events-none absolute -right-60 -top-60 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">Testimonial</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Apa Kata Brand Partner Kami?</h2>
          <p class="mt-4 text-base-content/70 md:text-lg">
            Mereka sudah merasakan kemudahan dan kualitas layanan maklon kami.
          </p>
        </div>

        <div class="mt-14 grid gap-8 md:grid-cols-3">
          {testimonials.map((item) => (
            <div class="group card border border-base-200 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5">
              <div class="card-body p-7">
                <!-- Stars -->
                <div class="flex items-center gap-1">
                  {[...Array(item.rating)].map(() => <span class="text-lg text-amber-400">★</span>)}
                  {[...Array(5 - item.rating)].map(() => <span class="text-lg text-base-300">★</span>)}
                </div>
                <!-- Quote -->
                <div class="relative mt-4">
                  <svg class="absolute -left-1 -top-2 h-6 w-6 text-primary/15" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                  <p class="text-sm italic leading-relaxed text-base-content/70 pl-6">"{item.text}"</p>
                </div>
                <!-- Author -->
                <div class="mt-5 border-t border-base-200 pt-5">
                  <div class="flex items-center gap-3">
                    <div class="flex h-11 w-11 items-center justify-center rounded-full bg-gradient-to-br from-primary to-secondary text-sm font-bold text-white shadow-md">
                      {item.name.charAt(0)}
                    </div>
                    <div>
                      <p class="text-sm font-bold">{item.name}</p>
                      <p class="text-xs text-primary font-medium">{item.brand}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- =================================================================== -->
    <!-- 8. BANNER CTA (Premium)                                             -->
    <!-- =================================================================== -->
    <section class="relative overflow-hidden py-24">
      <!-- Gradient background -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-secondary"></div>
      <!-- Decorative elements -->
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 50% 50%, white 1px, transparent 1px); background-size: 50px 50px;"></div>

      <div class="relative mx-auto max-w-5xl px-4 text-center lg:px-8">
        <!-- Floating icon -->
        <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm animate-bounce">
          <span class="text-5xl">🚀</span>
        </div>

        <h2 class="text-4xl font-black text-white md:text-5xl lg:text-6xl leading-tight">
          Siap Membuat Produk <br class="hidden sm:block" />
          <span class="text-white/90">Brand Kamu Sendiri?</span>
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-lg text-white/75 md:text-xl leading-relaxed">
          Konsultasikan ide produk kamu sekarang dan mulai bangun brand skincare bersama partner maklon yang tepat. Tim kami siap mendampingi dari awal hingga produk siap jual!
        </p>

        <!-- CTA Buttons -->
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href={waLinkCta}
            target="_blank"
            class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white bg-white px-10 text-base text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl"
          >
