---
import Icon from "../components/ui/Icon.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { processSteps } from "../data/process";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Alur Maklon | Magna"
  description="Proses maklon yang terstruktur dari konsultasi hingga produk siap dikirim."
>
  <main class="overflow-hidden bg-base-100">
    <section class="relative py-16 md:py-24">
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-80 bg-gradient-to-b from-primary/[0.07] to-transparent"
      >
      </div>

      <div class="relative mx-auto max-w-6xl px-4 lg:px-8">
        <SectionHeader label="9 Tahap Terarah" title="Proses Maklon dari Ide hingga Siap Jual" />

        <div class="relative mt-14 md:mt-20">
          <div
            class="absolute bottom-8 left-6 top-13 w-[3px] -translate-x-1/2 rounded-full bg-primary md:left-1/2"
          >
          </div>

          <div class="space-y-8 md:space-y-12">
            {
              processSteps.map((step, index) => {
                const isLeft = index % 2 === 0;
                const isFinal = index === processSteps.length - 1;

                return (
                  <article class="relative grid grid-cols-1 md:grid-cols-2">
                    <div
                      class:list={[
                        "relative ml-14 md:ml-0",
                        isLeft ? "md:col-start-1 md:pr-14" : "md:col-start-2 md:pl-14",
                      ]}
                    >
                      <div
                        class:list={[
                          "group relative rounded-2xl border bg-base-100 p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl sm:p-6",
                          isFinal
                            ? "border-primary/30 bg-primary/[0.03]"
                            : "border-base-200 hover:border-primary/30",
                        ]}
                      >
                        <span
                          class:list={[
                            "absolute top-13 hidden h-[3px] w-14 rounded-full bg-primary md:block",
                            isLeft ? "-right-14" : "-left-14",
                          ]}
                        />

                        <div class="flex items-start gap-4">
                          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary group-hover:text-white">
                            <Icon name={step.icon} size={22} />
                          </div>
                          <div class="min-w-0 flex-1">
                            <div class="flex flex-wrap items-center gap-2">
                              <span class="text-[11px] font-black tracking-[0.18em] text-primary uppercase">
                                Tahap {String(step.step).padStart(2, "0")}
                              </span>
                              {isFinal && (
                                <span class="badge badge-primary badge-sm">Siap Jual</span>
                              )}
                            </div>
                            <h2 class="mt-1 text-lg font-black text-base-content sm:text-xl">
                              {step.title}
                            </h2>
                          </div>
                        </div>

                        <p class="mt-4 text-sm font-semibold leading-relaxed text-primary/80">
                          {step.desc}
                        </p>
                        <p class="mt-3 text-sm leading-relaxed text-base-content/60">
                          {step.detail}
                        </p>
                      </div>
                    </div>

                    <div class="absolute left-6 top-7 z-10 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full border-4 border-base-100 bg-primary text-sm font-black text-white md:left-1/2">
                      {String(step.step).padStart(2, "0")}
                    </div>
                  </article>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
