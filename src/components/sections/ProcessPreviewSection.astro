---
import SectionHeader from "../ui/SectionHeader.astro";
import { processSteps } from "../../data/process";
---

<section class="bg-base-200/50 py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <SectionHeader
      tag="Alur Maklon"
      title="Bagaimana Cara Kerjanya?"
      description="Proses maklon yang mudah dan terstruktur dari konsultasi hingga produk jadi."
    />

    <div class="mt-10 grid gap-6 md:grid-cols-4">
      {processSteps.slice(0, 4).map((step) => (
        <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="card-body items-center text-center p-6">
            <div class="flex h-14 w-14 items-center justify-center rounded-full bg-primary text-lg font-bold text-white shadow-md">
              {step.step}
            </div>
            <h3 class="card-title mt-4 text-lg">{step.title}</h3>
            <p class="mt-2 text-sm text-base-content/70">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="/alur-maklon" class="btn btn-soft rounded-full px-8">
        Lihat Alur Lengkap
      </a>
    </div>
  </div>
</section>