---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import WAButton from "../components/ui/WAButton.astro";
import { visionMission, ourStory, coreValues } from "../data/company";
import { factoryImages, companyImages } from "../data/images";
import { certifications } from "../data/certifications";

const topCerts = certifications.slice(0, 4);

const metrics = [
  { value: "10+", label: "Tahun Pengalaman" },
  { value: "200+", label: "Brand Partner" },
  { value: "500+", label: "Formula Siap Pakai" },
  { value: "50+", label: "Tenaga Ahli" },
];

const facilityItems = [
  { label: "Laboratorium R&D", icon: "lucide:flask-conical", image: factoryImages.labResearch },
  { label: "Lini Produksi", icon: "lucide:factory", image: factoryImages.productionLine },
  { label: "Quality Control Lab", icon: "lucide:microscope", image: factoryImages.qualityControl },
  { label: "Gudang Bahan Baku", icon: "lucide:warehouse", image: factoryImages.bahanBaku },
];
---

<MainLayout
  title="Tentang Perusahaan | Magna"
  description="Mengenal lebih dekat Magna — mitra maklon skincare terpercaya di Indonesia dengan fasilitas berstandar CPKB."
>
  <main class="overflow-x-hidden">

    <!-- ================================================================== -->
    <!-- 1. HERO COMPANY — Full-width image, premium overlay                 -->
    <!-- ================================================================== -->
    <section class="relative flex min-h-[85vh] items-end pb-20 md:items-center md:pb-0">
      <!-- Background -->
      <div class="absolute inset-0 z-0">
        <img
          src={factoryImages.productionLine}
          alt="Magna Facility"
          class="h-full w-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/65 via-black/45 to-black/75 md:bg-gradient-to-r md:from-black/70 md:via-black/45 md:to-black/50"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 mx-auto w-full max-w-7xl px-4 pb-6 md:pb-0 lg:px-8">
        <div class="max-w-2xl">
          <div class="reveal-up mb-6 inline-flex items-center gap-2.5 rounded-full border border-white/12 bg-white/6 px-5 py-2.5 backdrop-blur-lg">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            <span class="text-[11px] font-bold tracking-[0.16em] text-white/70 uppercase">Sejak 2015</span>
          </div>

          <h1 class="reveal-up text-4xl font-black leading-[1.08] text-white md:text-5xl lg:text-6xl xl:text-7xl">
            Mitra Maklon<br />
            <span class="bg-gradient-to-r from-emerald-300 via-green-200 to-white bg-clip-text text-transparent">
              Skincare
            </span>
          </h1>

          <p class="reveal-up mt-5 max-w-lg text-sm leading-relaxed text-white/50 md:text-base lg:text-lg">
            Dari formulasi, produksi, legalitas BPOM & Halal, hingga produk siap jual —
            <span class="font-semibold text-white/75">kami dampingi penuh</span>.
          </p>

          <div class="reveal-up mt-8 flex flex-wrap items-center gap-4">
            <WAButton
              text="Konsultasi Gratis"
              message="Halo, saya ingin konsultasi maklon skincare."
              variant="white"
              size="lg"
              class="rounded-xl shadow-xl shadow-black/20"
            />
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2">
        <span class="flex animate-bounce flex-col items-center gap-1 text-white/30">
          <span class="text-[10px] font-semibold tracking-[0.2em] uppercase">Scroll</span>
          <Icon name="lucide:chevron-down" class="h-4 w-4" />
        </span>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. ABOUT COMPANY — Split layout: text + image + metrics             -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center gap-8 lg:flex-row lg:gap-14">
          <!-- LEFT: Image -->
          <div class="reveal-up relative w-full overflow-hidden rounded-3xl lg:w-[45%]">
            <img
              src={companyImages.labTeam}
              alt="Tim Magna"
              class="h-[340px] w-full object-cover md:h-[480px] lg:h-[560px]"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            <!-- Floating stat badge -->
            <div class="absolute bottom-6 left-6 rounded-2xl border border-white/15 bg-white/10 px-5 py-3 backdrop-blur-lg">
              <span class="text-2xl font-black text-white">10+</span>
              <span class="ml-2 text-xs font-medium text-white/70">Tahun Berkarya</span>
            </div>
          </div>

          <!-- RIGHT: Text -->
          <div class="lg:w-[55%]">
            <div class="reveal-up mb-5 flex items-center gap-3">
              <span class="block h-px w-10 bg-primary/40"></span>
              <span class="text-[11px] font-semibold tracking-[0.2em] text-primary/60 uppercase">Tentang Kami</span>
            </div>

            <h2 class="reveal-up text-3xl font-black md:text-4xl lg:text-5xl leading-tight">
              Hadir untuk Membantu <span class="text-primary">Brand Owner</span>
            </h2>

            <p class="reveal-up mt-5 text-base leading-relaxed text-base-content/50 md:text-lg">
              {ourStory.paragraphs[0]}
            </p>
            <p class="reveal-up mt-4 text-base leading-relaxed text-base-content/50 md:text-lg">
              {ourStory.paragraphs[1]}
            </p>
            <p class="reveal-up mt-4 text-base leading-relaxed text-base-content/50 md:text-lg">
              {ourStory.paragraphs[2]}
            </p>

            <!-- Inline metrics -->
            <div class="reveal-up mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
              {metrics.map((m) => (
                <div class="rounded-2xl border border-base-200/60 bg-base-200/30 p-4 text-center transition-all duration-300 hover:border-primary/15 hover:bg-primary/[0.03]">
                  <span class="text-2xl font-black text-primary">{m.value}</span>
                  <p class="mt-1 text-[11px] font-medium text-base-content/40">{m.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. VISION · MISSION · VALUES — Unified premium cards                -->
    <!-- ================================================================== -->
    <section class="bg-base-200/40 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">

        <!-- Vision + Mission row -->
        <div class="grid gap-6 lg:grid-cols-2">
          <!-- Vision Card -->
          <div class="reveal-up group relative overflow-hidden rounded-3xl border-2 border-primary/15 bg-white p-8 shadow-[0_8px_30px_-4px_rgba(101,146,135,0.12)] transition-all duration-500 hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-[0_12px_40px_-6px_rgba(101,146,135,0.25)] md:p-10">
            <div class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-primary/[0.03] transition-all duration-500 group-hover:scale-150 group-hover:bg-primary/[0.06]"></div>
            <div class="flex items-start gap-5">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-primary/8 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white group-hover:shadow-lg group-hover:shadow-primary/20">
                <Icon name="lucide:eye" class="h-6 w-6" />
              </div>
              <div>
                <span class="text-[10px] font-bold tracking-[0.2em] text-primary/40 uppercase">Visi</span>
                <h3 class="mt-1 text-xl font-bold">Arah Kami</h3>
                <p class="mt-3 text-base leading-relaxed text-base-content/55 italic">
                  "{visionMission.vision}"
                </p>
              </div>
            </div>
          </div>

          <!-- Mission Card -->
          <div class="reveal-up group relative overflow-hidden rounded-3xl border-2 border-primary/15 bg-white p-8 shadow-[0_8px_30px_-4px_rgba(101,146,135,0.12)] transition-all duration-500 hover:-translate-y-1.5 hover:border-primary/30 hover:shadow-[0_12px_40px_-6px_rgba(101,146,135,0.25)] md:p-10">
            <div class="absolute -left-8 -bottom-8 h-24 w-24 rounded-full bg-primary/[0.03] transition-all duration-500 group-hover:scale-150 group-hover:bg-primary/[0.06]"></div>
            <div class="flex items-start gap-5">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-primary/8 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white group-hover:shadow-lg group-hover:shadow-primary/20">
                <Icon name="lucide:target" class="h-6 w-6" />
              </div>
              <div>
                <span class="text-[10px] font-bold tracking-[0.2em] text-primary/40 uppercase">Misi</span>
                <h3 class="mt-1 text-xl font-bold">Komitmen Kami</h3>
                <ul class="mt-3 space-y-2.5">
                  {visionMission.missions.map((m: string, i: number) => (
                    <li class="flex items-start gap-3 group/mission">
                      <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10 text-[10px] font-bold text-primary transition-all duration-300 group-hover/mission:bg-primary group-hover/mission:text-white">{i + 1}</span>
                      <span class="text-sm leading-relaxed text-base-content/55">{m}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Core Values - Premium Green Marquee -->
        <div class="reveal-up mt-16">
          <div class="text-center mb-10">
            <span class="text-[10px] font-bold tracking-[0.2em] text-primary/40 uppercase">Nilai Kami</span>
            <h2 class="mt-2 text-3xl font-black md:text-4xl">Prinsip yang <span class="text-primary">Kami Pegang</span></h2>
          </div>

          <!-- Background hijau dengan animasi marquee -->
          <div class="relative overflow-hidden rounded-3xl bg-primary py-12 md:py-16">
            <!-- Decorative -->
            <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 30px 30px;"></div>
            <div class="pointer-events-none absolute -left-20 -top-20 h-[300px] w-[300px] rounded-full bg-white/5 blur-3xl"></div>
            <div class="pointer-events-none absolute -right-20 -bottom-20 h-[300px] w-[300px] rounded-full bg-white/5 blur-3xl"></div>

            <div class="overflow-hidden">
              <div class="flex animate-scroll-left gap-6" style="--scroll-speed: 20s; width: max-content;">
                {[...coreValues, ...coreValues, ...coreValues].map((val, i) => (
                  <div
                    class="group flex w-[240px] shrink-0 flex-col items-center rounded-2xl border border-white/15 bg-white/10 p-7 text-center backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:border-white/25 hover:bg-white/15 hover:shadow-xl hover:shadow-black/10"
                    style="animation-delay: 0s"
                  >
                    <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10 text-white transition-all duration-500 group-hover:bg-white group-hover:text-primary group-hover:shadow-lg">
                      <Icon name={val.icon} class="h-6 w-6" />
                    </div>
                    <h3 class="mt-4 text-base font-bold text-white">{val.title}</h3>
                    <p class="mt-2 text-xs leading-relaxed text-white/50">{val.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. FACILITIES — Gallery + Certification strip                       -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="reveal-up mx-auto max-w-2xl text-center">
          <div class="mb-6 flex items-center justify-center gap-3">
            <span class="block h-px w-8 bg-primary/30"></span>
            <span class="text-[11px] font-semibold tracking-[0.2em] text-primary/60 uppercase">Fasilitas</span>
            <span class="block h-px w-8 bg-primary/30"></span>
          </div>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl leading-tight">
            Manufacturing <span class="text-primary">Excellence</span>
          </h2>
          <p class="mt-5 text-base leading-relaxed text-base-content/50 md:text-lg max-w-xl mx-auto">
            Didukung fasilitas produksi berstandar CPKB dengan teknologi modern dan tim berpengalaman.
          </p>
        </div>

        <!-- Asymmetric gallery: 1 large + 3 small -->
        <div class="mt-12 grid gap-5 lg:grid-cols-2">
          <!-- Large featured image (first) -->
          <div class="reveal-up group relative overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg lg:row-span-2">
            <div class="relative h-full min-h-[360px] overflow-hidden">
              <img src={facilityItems[0].image} alt={facilityItems[0].label} class="h-full w-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/15 to-transparent"></div>
              <div class="absolute bottom-6 left-6 flex items-center gap-3">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/15 text-white backdrop-blur-md">
                  <Icon name={facilityItems[0].icon} class="h-5 w-5" />
                </div>
                <span class="text-base font-bold text-white drop-shadow-md">{facilityItems[0].label}</span>
              </div>
            </div>
          </div>

          {facilityItems.slice(1).map((item) => (
            <div class="reveal-up group relative overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg">
              <div class="relative h-44 overflow-hidden">
                <img src={item.image} alt={item.label} class="h-full w-full object-cover transition-all duration-700 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-transparent"></div>
                <div class="absolute bottom-4 left-4 flex items-center gap-2.5">
                  <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/15 text-white backdrop-blur-sm">
                    <Icon name={item.icon} class="h-4 w-4" />
                  </div>
                  <span class="text-sm font-bold text-white drop-shadow-md">{item.label}</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Certification strip -->
        <div class="reveal-up mt-10 overflow-hidden rounded-2xl border border-base-200/50 bg-base-200/30 p-6">
          <p class="mb-4 text-center text-[10px] font-bold tracking-[0.2em] text-base-content/30 uppercase">Diakui & Tersertifikasi</p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            {topCerts.map((cert) => (
              <div class="flex items-center gap-3 rounded-xl border border-base-200/50 bg-white px-5 py-3 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/15 hover:shadow-md">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/8 text-primary">
                  <Icon name={cert.icon} class="h-5 w-5" />
                </div>
                <div>
                  <p class="text-sm font-bold">{cert.name}</p>
                  <p class="text-[10px] text-base-content/35">{cert.number}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-5 text-center">
            <a href="/sertifikasi" class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary transition-colors hover:underline">
              Lihat Semua Sertifikasi
              <Icon name="lucide:arrow-right" class="h-3 w-3" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. FINAL CTA — Clean, strong conversion                             -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-20 md:py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0a1a15] via-primary to-emerald-950"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
      <!-- Decorative blurs -->
      <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-32 -left-32 h-80 w-80 rounded-full bg-white/5 blur-3xl"></div>

      <div class="reveal-up relative mx-auto max-w-3xl px-4 text-center lg:px-8">
        <div class="mx-auto mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-5 py-2 backdrop-blur-xl">
          <span class="h-2 w-2 animate-pulse rounded-full bg-amber-400"></span>
          <span class="text-xs font-bold tracking-[0.15em] text-white/70 uppercase">Konsultasi Gratis — Tanpa Komitmen</span>
        </div>

        <h2 class="text-4xl font-black text-white md:text-5xl lg:text-6xl leading-tight">
          Siap Wujudkan Brand Impian Anda?
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-white/55 md:text-lg">
          Mulai dari <span class="font-semibold text-white/80">konsultasi gratis</span> — tim kami siap mendampingi dari nol sampai produk jadi.
        </p>

        <div class="mt-9 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <WAButton
            text="Konsultasi via WhatsApp"
            message="Halo, saya ingin konsultasi maklon skincare."
            variant="white"
            size="lg"
            class="rounded-xl shadow-2xl shadow-black/20"
          />
          <a href="/layanan"
            class="inline-flex h-14 items-center gap-2 rounded-xl border-2 border-white/20 bg-white/5 px-10 text-base font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/35 hover:bg-white/8">
            Lihat Layanan Kami
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          {["BPOM", "Halal MUI", "500+ Formula", "Respon < 1 jam"].map((b) => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/6 px-4 py-2 text-xs font-medium text-white/60 backdrop-blur-sm">
              <Icon name="lucide:shield-check" class="h-3.5 w-3.5 text-emerald-300/50" />
              {b}
            </span>
          ))}
        </div>
      </div>
    </section>

  </main>
</MainLayout>

<style is:global>
  .reveal-up {
    will-change: transform, opacity;
  }
</style>

<script>
  // Scroll reveal animations
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const delay = parseInt(el.dataset.revealDelay || "0");
        el.style.transition = `all 0.6s cubic-bezier(0.16, 1, 0.3, 1) ` + delay + 'ms';
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
        revealObserver.unobserve(el);
      }
    });
  }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });

  document.querySelectorAll(".reveal-up").forEach((el, i) => {
    const htmlEl = el as HTMLElement;
    htmlEl.style.opacity = "0";
    htmlEl.style.transform = "translateY(24px)";
    if (!htmlEl.dataset.revealDelay) htmlEl.dataset.revealDelay = String(i * 50);
    revealObserver.observe(htmlEl);
  });
</script>
