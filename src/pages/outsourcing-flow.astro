---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { processSteps } from "../data/process";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
const waConsultLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin memulai proses maklon.");
---

<MainLayout
  title="Alur Maklon | Aquila Maklon"
  description="Proses maklon yang terstruktur dari konsultasi hingga produk siap dikirim."
>
  <main>
    <!-- ================================================================== -->
    <!-- SECTION HEADER                                                     -->
    <!-- ================================================================== -->
    <section class="bg-base-100 pb-4 pt-16 lg:pb-6 lg:pt-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-base-200/40 px-5 py-2">
            <Icon name="lucide:git-branch" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">ALUR PROSES MAKLON</span>
          </div>
          <h1 class="mt-5 text-3xl font-black tracking-tight md:text-4xl lg:text-5xl">
            9 Tahap <span class="text-primary">Proses Maklon</span>
          </h1>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Dari ide hingga produk siap jual — setiap langkah didampingi tim profesional kami.
          </p>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- ZIGZAG TIMELINE — Alternating left/right + center line              -->
    <!-- ================================================================== -->
    <section class="bg-base-100 pb-20 lg:pb-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">

        {/* Desktop: zigzag with center line */}
        <div class="relative hidden lg:block">
          {/* Center vertical line */}
          <div class="absolute left-1/2 top-0 h-full w-0.5 -translate-x-1/2 bg-primary/12"></div>

          <div class="space-y-12">
            {processSteps.map(function(step, i) {
              const isLeft = i % 2 === 0;
              const isFinal = step.step === 9;

              if (isFinal) {
                // Final step — centered
                return (
                  <div id={`step-${step.step}`}
                    class="flow-step relative flex justify-center"
                    style="opacity:0;transform:translateY(30px)">
                    <div class="flex flex-col items-center">
                      {/* Step number on center line */}
                      <div class="relative z-10 flex h-16 w-16 items-center justify-center rounded-full bg-secondary text-xl font-black text-white shadow-xl ring-8 ring-secondary/10">
                        {step.step}
                      </div>
                      {/* Card */}
                      <div class="mt-4 w-full max-w-lg rounded-2xl border-2 border-secondary/20 bg-gradient-to-br from-secondary/[0.03] to-base-100 p-6 text-center shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
                        <h3 class="text-lg font-bold text-base-content">{step.title}</h3>
                        <p class="mt-2 text-sm leading-relaxed text-base-content/65">{step.detail}</p>
                        <span class="mt-3 inline-flex items-center gap-1 rounded-full bg-secondary/10 px-3 py-1 text-xs font-semibold text-secondary">
                          <Icon name="lucide:trophy" size={12} />
                          Tahap Akhir
                        </span>
                      </div>
                    </div>
                  </div>
                );
              }

              return (
                <div id={`step-${step.step}`}
                  class={`flow-step relative flex items-center ${isLeft ? 'justify-start' : 'justify-end'}`}
                  style="opacity:0;transform:translateY(30px)">
                  {/* Step number — on center line */}
                  <div class="absolute left-1/2 z-10 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full bg-primary text-base font-black text-white shadow-lg ring-4 ring-primary/10">
                    {step.step}
                  </div>
                  {/* Horizontal connector from center to card */}
                  <div class={`absolute top-1/2 h-0.5 w-[calc(50%-2rem)] -translate-y-1/2 bg-primary/15 ${isLeft ? 'left-[calc(50%+2rem)]' : 'right-[calc(50%+2rem)]'}`}></div>
                  {/* Card */}
                  <div class={`w-full max-w-md rounded-2xl border border-base-200/50 bg-base-100 p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md hover:border-primary/20 ${isLeft ? 'mr-[calc(50%+3rem)]' : 'ml-[calc(50%+3rem)]'}`}>
                    <h3 class="text-base font-bold text-base-content">{step.title}</h3>
                    <p class="mt-1.5 text-sm leading-relaxed text-base-content/60">{step.detail}</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        {/* Mobile: simple vertical timeline */}
        <div class="lg:hidden">
          <div class="space-y-0">
            {processSteps.map(function(step, i) {
              const isFinal = step.step === 9;
              return (
                <div id={`step-m-${step.step}`}
                  class="flow-step group relative flex gap-4"
                  style="opacity:0;transform:translateY(30px)">
                  {/* Timeline column */}
                  <div class="flex shrink-0 flex-col items-center">
                    <div class={`z-10 flex h-10 w-10 items-center justify-center rounded-full ${isFinal ? 'bg-secondary' : 'bg-primary'} text-sm font-black text-white shadow-md`}>
                      {step.step}
                    </div>
                    {!isFinal && <div class="mt-1 h-full min-h-[16px] w-0.5 bg-primary/12"></div>}
                  </div>
                  {/* Content */}
                  <div class={`flex-1 rounded-xl border border-base-200/50 bg-base-100 p-4 shadow-sm transition-all duration-300 hover:border-primary/15 ${isFinal ? 'border-secondary/20 bg-secondary/[0.02]' : ''}`}>
                    <h3 class="text-sm font-bold text-base-content">{step.title}</h3>
                    <p class="mt-1 text-xs leading-relaxed text-base-content/60">{step.detail}</p>
                    {isFinal && (
                      <span class="mt-2 inline-flex items-center gap-1 rounded-full bg-secondary/10 px-2 py-0.5 text-[10px] font-semibold text-secondary">
                        <Icon name="lucide:trophy" size={10} />
                        Tahap Akhir
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        {/* Bottom CTA */}
        <div class="mt-14 text-center lg:mt-20">
          <p class="text-sm text-base-content/50">Tertarik memulai proses maklon?</p>
          <a href={waConsultLink} target="_blank" rel="noopener noreferrer"
            class="mt-3 inline-flex h-11 items-center gap-2 rounded-full bg-primary px-6 text-sm font-semibold text-white shadow-md shadow-primary/15 transition-all duration-300 hover:scale-105 hover:shadow-lg">
            <Icon name="mdi:whatsapp" size={16} />
            Mulai Konsultasi
          </a>
        </div>

      </div>
    </section>

    <!-- ================================================================== -->
    <!-- CTA PREMIUM BANNER                                                 -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-secondary"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image:radial-gradient(circle at 50% 50%, white 1px, transparent 1px);background-size:50px 50px"></div>

      <div class="relative mx-auto max-w-7xl px-4 text-center lg:px-8">
        <h2 class="text-4xl font-black leading-tight text-white md:text-5xl lg:text-6xl">
          Siap Memulai <span class="text-white/90">Proses Maklon?</span>
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-white/75 md:text-xl">
          Konsultasikan ide produk Anda sekarang. Tim kami siap mendampingi dari tahap awal hingga produk siap jual — tanpa ribet.
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={waLink} target="_blank" rel="noopener noreferrer"
            class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white bg-white px-10 text-base text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl">
            <Icon name="mdi:whatsapp" class="mr-2 h-5 w-5" />
            Konsultasi via WhatsApp
          </a>
          <a href="/layanan"
            class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white/30 bg-white/10 px-10 text-base text-white backdrop-blur-sm transition-all duration-300 hover:border-white/50 hover:bg-white/20">
            Lihat Layanan Kami
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .flow-step {
    overflow: visible !important;
  }
</style>

<!-- Staggered scroll reveal animation -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const steps = document.querySelectorAll('.flow-step');
    if (!steps.length) return;

    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            const el = entry.target;
            const idx = Array.from(steps).indexOf(el);
            el.style.transition = `opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${idx * 0.1}s, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1) ${idx * 0.1}s`;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    steps.forEach(function (el) {
      observer.observe(el);
    });
  });
</script>