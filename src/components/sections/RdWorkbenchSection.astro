---
import Icon from "../ui/Icon.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import WAButton from "../ui/WAButton.astro";
import { siteConfig } from "../../data/site";
import { rdStats } from "../../data/research-development";

type LabStatus = "in_progress" | "passed" | "pending";
type SampleStatus = "revision" | "improved" | "approved";

interface ActiveIngredient {
  id: "retinol" | "niacinamide" | "hyaluronicAcid";
  label: string;
  min: number;
  max: number;
  step: number;
  defaultValue: number;
  unit: string;
}

interface TextureOption {
  id: string;
  label: string;
  modifier: { acne: number; brightening: number; antiAging: number };
}

interface FragranceOption {
  id: string;
  label: string;
}

interface LabTestItem {
  id: string;
  name: string;
  status: LabStatus;
  updatedAt: string;
}

interface SampleItem {
  id: string;
  version: string;
  note: string;
  status: SampleStatus;
  selectable: boolean;
}

interface WorkbenchConfig {
  ingredients: ActiveIngredient[];
  textures: TextureOption[];
  fragrances: FragranceOption[];
  labTests: LabTestItem[];
  samples: SampleItem[];
}

const labStatusBadge: Record<LabStatus, { label: string; class: string }> = {
  in_progress: { label: "In Progress", class: "badge-warning" },
  passed: { label: "Passed", class: "badge-success" },
  pending: { label: "Pending", class: "badge-ghost" },
};

const sampleStatusBadge: Record<SampleStatus, { label: string; class: string }> = {
  revision: { label: "Revisi", class: "badge-error badge-outline" },
  improved: { label: "Diperbaiki", class: "badge-info badge-outline" },
  approved: { label: "Approved", class: "badge-success" },
};

const workbenchConfig: WorkbenchConfig = {
  ingredients: [
    { id: "retinol", label: "Retinol", min: 0, max: 2, step: 0.1, defaultValue: 0.3, unit: "%" },
    { id: "niacinamide", label: "Niacinamide", min: 0, max: 10, step: 0.5, defaultValue: 5, unit: "%" },
    { id: "hyaluronicAcid", label: "Hyaluronic Acid", min: 0, max: 3, step: 0.1, defaultValue: 1.2, unit: "%" },
  ],
  textures: [
    { id: "gel", label: "Gel", modifier: { acne: 8, brightening: 4, antiAging: 2 } },
    { id: "cream", label: "Cream", modifier: { acne: 4, brightening: 6, antiAging: 10 } },
    { id: "water", label: "Water-based", modifier: { acne: 10, brightening: 8, antiAging: 3 } },
  ],
  fragrances: [
    { id: "none", label: "Fragrance-free" },
    { id: "rose", label: "Rose" },
    { id: "green-tea", label: "Green Tea" },
  ],
  labTests: [
    { id: "stability", name: "Stability Test", status: "passed", updatedAt: "08 Jul 2026" },
    { id: "patch", name: "Patch Test", status: "in_progress", updatedAt: "09 Jul 2026" },
    { id: "microbe", name: "Microbe Test", status: "pending", updatedAt: "Menunggu sample" },
  ],
  samples: [
    { id: "v1", version: "Sampel V1.0", note: "Tekstur lengket, absorbasi lambat", status: "revision", selectable: true },
    { id: "v1.1", version: "Sampel V1.1", note: "Perbaikan formula — tekstur lebih ringan", status: "improved", selectable: true },
    { id: "v1.2", version: "Sampel V1.2", note: "Final approval — siap scale-up", status: "approved", selectable: true },
  ],
};

const defaultState = {
  retinol: 0.3,
  niacinamide: 5,
  hyaluronicAcid: 1.2,
  texture: "gel",
  fragrance: "none",
  selectedSample: "v1.2",
};
---

<section
  id="rd-workbench"
  class="relative overflow-hidden bg-gradient-to-b from-base-200/80 via-base-100 to-base-200/60 pt-20 pb-16 lg:pt-24"
  data-rd-workbench
>
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <SectionHeader label="Research & Development" variant="minimal">
          <span slot="title">
            Active Formula <span class="text-primary">Workbench</span>
          </span>
        </SectionHeader>
        <p class="mt-3 text-sm leading-relaxed text-base-content/55 md:text-base">
          Atur konsentrasi bahan aktif, simulasikan efikasi, dan pantau progres uji lab serta feedback sampel secara real-time.
        </p>

        <div class="mt-5 flex flex-wrap items-center justify-center gap-2">
          {rdStats.slice(0, 3).map((stat) => (
            <span class="rounded-full border border-base-200 bg-white/80 px-3 py-1 text-xs font-medium text-base-content/60 shadow-sm">
              <strong class="text-primary">{stat.value}</strong> {stat.label}
            </span>
          ))}
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3 lg:gap-8">
        <!-- Kolom 1 & 2: Active Formula Workbench -->
        <div class="space-y-6 lg:col-span-2">
          <div class="rounded-2xl border border-base-200 bg-white/90 p-5 shadow-sm backdrop-blur-sm lg:p-6">
            <div class="mb-5 flex items-center gap-2">
              <Icon name="lucide:flask-conical" size={18} class="text-primary" />
              <h2 class="text-base font-bold text-base-content">Kustomisasi Bahan Aktif</h2>
            </div>

            <fieldset class="fieldset rounded-xl border border-base-200 bg-base-200/20 p-4">
              <legend class="fieldset-legend text-sm font-semibold text-primary">
                Konsentrasi Bahan Aktif
              </legend>
              <div class="grid gap-5 sm:grid-cols-2">
                {workbenchConfig.ingredients.map((ingredient) => (
                  <div class="form-control" data-ingredient-wrap={ingredient.id}>
                    <div class="label py-0">
                      <span class="label-text font-medium">{ingredient.label}</span>
                      <span
                        class="badge badge-ghost badge-sm font-mono"
                        data-ingredient-value={ingredient.id}
                      >
                        {ingredient.defaultValue}{ingredient.unit}
                      </span>
                    </div>
                    <input
                      type="range"
                      min={ingredient.min}
                      max={ingredient.max}
                      step={ingredient.step}
                      value={ingredient.defaultValue}
                      class="range range-primary range-sm mt-2"
                      data-ingredient-slider={ingredient.id}
                      aria-label={`Slider ${ingredient.label}`}
                    />
                    <div class="mt-1 flex justify-between text-[10px] text-base-content/40">
                      <span>{ingredient.min}{ingredient.unit}</span>
                      <span>{ingredient.max}{ingredient.unit}</span>
                    </div>
                  </div>
                ))}
              </div>
            </fieldset>

            <fieldset class="fieldset mt-5 rounded-xl border border-base-200 bg-base-200/20 p-4">
              <legend class="fieldset-legend text-sm font-semibold text-primary">
                Karakteristik Produk
              </legend>
              <div class="grid gap-4 sm:grid-cols-2">
                <label class="form-control">
                  <span class="label-text mb-1 font-medium">Tekstur</span>
                  <select class="select select-bordered w-full" data-texture-select>
                    {workbenchConfig.textures.map((texture) => (
                      <option value={texture.id} selected={texture.id === defaultState.texture}>
                        {texture.label}
                      </option>
                    ))}
                  </select>
                </label>
                <label class="form-control">
                  <span class="label-text mb-1 font-medium">Wewangian</span>
                  <select class="select select-bordered w-full" data-fragrance-select>
                    {workbenchConfig.fragrances.map((fragrance) => (
                      <option value={fragrance.id} selected={fragrance.id === defaultState.fragrance}>
                        {fragrance.label}
                      </option>
                    ))}
                  </select>
                </label>
              </div>
            </fieldset>
          </div>

          <!-- Efficacy Target -->
          <div class="rounded-2xl border border-base-200 bg-white/90 p-5 shadow-sm backdrop-blur-sm lg:p-6">
            <div class="mb-4 flex items-center justify-between gap-3">
              <div class="flex items-center gap-2">
                <Icon name="lucide:activity" size={18} class="text-secondary" />
                <h2 class="text-base font-bold text-base-content">Efficacy Target</h2>
              </div>
              <span class="badge badge-outline badge-sm text-base-content/50">Simulasi live</span>
            </div>

            <div class="space-y-4">
              <div>
                <div class="mb-1 flex justify-between text-sm">
                  <span class="font-medium text-base-content/70">Acne Care</span>
                  <span class="font-mono text-xs font-bold text-primary" data-efficacy-value="acne">0%</span>
                </div>
                <progress class="progress progress-primary h-3 w-full" value="0" max="100" data-efficacy-bar="acne"></progress>
              </div>
              <div>
                <div class="mb-1 flex justify-between text-sm">
                  <span class="font-medium text-base-content/70">Brightening</span>
                  <span class="font-mono text-xs font-bold text-secondary" data-efficacy-value="brightening">0%</span>
                </div>
                <progress class="progress progress-secondary h-3 w-full" value="0" max="100" data-efficacy-bar="brightening"></progress>
              </div>
              <div>
                <div class="mb-1 flex justify-between text-sm">
                  <span class="font-medium text-base-content/70">Anti-Aging</span>
                  <span class="font-mono text-xs font-bold text-accent" data-efficacy-value="antiAging">0%</span>
                </div>
                <progress class="progress progress-accent h-3 w-full" value="0" max="100" data-efficacy-bar="antiAging"></progress>
              </div>
            </div>
          </div>
        </div>

        <!-- Kolom 3: Lab Status & Sample Feedback -->
        <div class="space-y-6 lg:col-span-1">
          <div class="rounded-2xl border border-base-200 bg-white/90 p-5 shadow-sm backdrop-blur-sm lg:p-6">
            <div class="mb-4 flex items-center gap-2">
              <Icon name="lucide:microscope" size={18} class="text-primary" />
              <h2 class="text-base font-bold text-base-content">Lab Status</h2>
            </div>

            <ul class="list rounded-xl border border-base-200 bg-base-100">
              {workbenchConfig.labTests.map((test) => (
                <li class="list-row items-center gap-3 px-4 py-3">
                  <Icon
                    name={
                      test.status === "passed"
                        ? "lucide:check-circle"
                        : test.status === "in_progress"
                          ? "lucide:loader-circle"
                          : "lucide:clock"
                    }
                    size={18}
                    class:list={[
                      test.status === "passed" && "text-success",
                      test.status === "in_progress" && "text-warning",
                      test.status === "pending" && "text-base-content/35",
                    ]}
                  />
                  <div class="list-col-grow min-w-0">
                    <p class="text-sm font-semibold">{test.name}</p>
                    <p class="text-[11px] text-base-content/45">{test.updatedAt}</p>
                  </div>
                  <span class={`badge badge-sm ${labStatusBadge[test.status].class}`}>
                    {labStatusBadge[test.status].label}
                  </span>
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-2xl border border-base-200 bg-white/90 p-5 shadow-sm backdrop-blur-sm lg:p-6">
            <div class="mb-4 flex items-center gap-2">
              <Icon name="lucide:messages-square" size={18} class="text-secondary" />
              <h2 class="text-base font-bold text-base-content">Sample Feedback Loop</h2>
            </div>

            <div class="space-y-2" data-sample-list>
              {workbenchConfig.samples.map((sample) => (
                <label
                  class="card cursor-pointer border border-base-200 bg-base-100 transition-all duration-200 has-[:checked]:border-primary has-[:checked]:bg-primary/5 has-[:checked]:shadow-md hover:border-primary/30"
                  data-sample-card={sample.id}
                >
                  <input
                    type="radio"
                    name="sample-version"
                    value={sample.id}
                    class="radio radio-primary radio-sm ml-4 mt-4"
                    checked={sample.id === defaultState.selectedSample}
                    data-sample-input
                  />
                  <div class="card-body gap-1 p-4 pt-2">
                    <div class="flex items-center justify-between gap-2">
                      <p class="text-sm font-bold">{sample.version}</p>
                      <span class={`badge badge-xs ${sampleStatusBadge[sample.status].class}`}>
                        {sampleStatusBadge[sample.status].label}
                      </span>
                    </div>
                    <p class="text-xs leading-relaxed text-base-content/55">{sample.note}</p>
                  </div>
                </label>
              ))}
            </div>

            <p class="mt-3 text-[11px] text-base-content/45" data-selected-sample-label>
              Sampel aktif: Sampel V1.2 — Final approval
            </p>

            <div class="mt-5 flex flex-col gap-2">
              <button type="button" class="btn btn-soft btn-primary w-full rounded-xl" data-btn-revision>
                <Icon name="lucide:rotate-ccw" size={16} />
                Minta Revisi Sampel Baru
              </button>
              <button type="button" class="btn btn-primary w-full rounded-xl shadow-lg shadow-primary/25" data-btn-approve>
                <Icon name="lucide:badge-check" size={16} />
                Approve Formula
              </button>
            </div>

            <WAButton
              text="Konsultasi R&D via WhatsApp"
              message="Halo, saya ingin konsultasi pengembangan formula R&D."
              variant="ghost"
              size="sm"
              class="mt-3 w-full rd-wa-consult"
            />
          </div>
        </div>
      </div>
    </div>

  <script type="application/json" id="rd-workbench-config" set:html={JSON.stringify(workbenchConfig)}></script>
  <script type="application/json" id="rd-workbench-state" set:html={JSON.stringify(defaultState)}></script>
  <script type="application/json" id="rd-wa-phone" set:html={JSON.stringify(siteConfig.waNumber)}></script>
</section>

<script>
  import { createWhatsappLink } from "../../lib/whatsapp";

  interface TextureModifier {
    acne: number;
    brightening: number;
    antiAging: number;
  }

  interface WorkbenchConfigClient {
    ingredients: { id: string; label: string; max: number }[];
    textures: { id: string; label: string; modifier: TextureModifier }[];
    fragrances: { id: string; label: string }[];
    samples: { id: string; version: string; note: string }[];
  }

  interface FormulaState {
    retinol: number;
    niacinamide: number;
    hyaluronicAcid: number;
    texture: string;
    fragrance: string;
    selectedSample: string;
  }

  interface EfficacyScores {
    acne: number;
    brightening: number;
    antiAging: number;
  }

  const root = document.querySelector<HTMLElement>("[data-rd-workbench]");
  if (!root) throw new Error("R&D workbench root not found");

  const config = JSON.parse(
    document.getElementById("rd-workbench-config")?.textContent ?? "{}",
  ) as WorkbenchConfigClient;
  const state = JSON.parse(
    document.getElementById("rd-workbench-state")?.textContent ?? "{}",
  ) as FormulaState;
  const waPhone = JSON.parse(document.getElementById("rd-wa-phone")?.textContent ?? '""') as string;

  function clamp(value: number, min = 0, max = 100): number {
    return Math.min(max, Math.max(min, value));
  }

  function calculateEfficacy(formula: FormulaState): EfficacyScores {
    const retinolWeight = (formula.retinol / 2) * 55;
    const niacinamideWeight = (formula.niacinamide / 10) * 60;
    const haWeight = (formula.hyaluronicAcid / 3) * 25;

    const texture =
      config.textures.find((item) => item.id === formula.texture)?.modifier ?? {
        acne: 0,
        brightening: 0,
        antiAging: 0,
      };

    const fragranceBoost =
      formula.fragrance === "green-tea" ? { acne: 6, brightening: 4, antiAging: 2 } : { acne: 0, brightening: 0, antiAging: 0 };

    return {
      acne: clamp(
        retinolWeight * 0.35 + niacinamideWeight * 0.45 + haWeight * 0.1 + texture.acne + fragranceBoost.acne,
      ),
      brightening: clamp(
        niacinamideWeight * 0.7 + haWeight * 0.2 + retinolWeight * 0.15 + texture.brightening + fragranceBoost.brightening,
      ),
      antiAging: clamp(
        retinolWeight * 0.85 + niacinamideWeight * 0.2 + haWeight * 0.15 + texture.antiAging + fragranceBoost.antiAging,
      ),
    };
  }

  const els = {
    sliders: root.querySelectorAll<HTMLInputElement>("[data-ingredient-slider]"),
    textureSelect: root.querySelector<HTMLSelectElement>("[data-texture-select]"),
    fragranceSelect: root.querySelector<HTMLSelectElement>("[data-fragrance-select]"),
    sampleInputs: root.querySelectorAll<HTMLInputElement>("[data-sample-input]"),
    selectedSampleLabel: root.querySelector<HTMLElement>("[data-selected-sample-label]"),
    btnRevision: root.querySelector<HTMLButtonElement>("[data-btn-revision]"),
    btnApprove: root.querySelector<HTMLButtonElement>("[data-btn-approve]"),
    waBtn: root.querySelector<HTMLAnchorElement>(".rd-wa-consult"),
  };

  function readStateFromDom(): void {
    els.sliders.forEach((slider) => {
      const key = slider.dataset.ingredientSlider as keyof Pick<
        FormulaState,
        "retinol" | "niacinamide" | "hyaluronicAcid"
      >;
      state[key] = Number(slider.value);
      const badge = root.querySelector<HTMLElement>(`[data-ingredient-value="${key}"]`);
      if (badge) {
        const unit = key === "niacinamide" ? "%" : "%";
        badge.textContent = `${slider.value}${unit}`;
      }
    });
    if (els.textureSelect) state.texture = els.textureSelect.value;
    if (els.fragranceSelect) state.fragrance = els.fragranceSelect.value;
    const selected = root.querySelector<HTMLInputElement>("[data-sample-input]:checked");
    if (selected) state.selectedSample = selected.value;
  }

  function updateEfficacyUI(scores: EfficacyScores): void {
    (["acne", "brightening", "antiAging"] as const).forEach((key) => {
      const value = Math.round(scores[key]);
      const bar = root.querySelector<HTMLProgressElement>(`[data-efficacy-bar="${key}"]`);
      const label = root.querySelector<HTMLElement>(`[data-efficacy-value="${key}"]`);
      if (bar) bar.value = value;
      if (label) label.textContent = `${value}%`;
    });
  }

  function updateSampleLabel(): void {
    const sample = config.samples.find((item) => item.id === state.selectedSample);
    if (els.selectedSampleLabel && sample) {
      els.selectedSampleLabel.textContent = `Sampel aktif: ${sample.version} — ${sample.note}`;
    }
  }

  function buildFormulaSummary(): string {
    const texture = config.textures.find((t) => t.id === state.texture)?.label ?? state.texture;
    const fragrance = config.fragrances.find((f) => f.id === state.fragrance)?.label ?? state.fragrance;
    const sample = config.samples.find((s) => s.id === state.selectedSample);
    const efficacy = calculateEfficacy(state);

    return [
      "Halo, saya ingin konsultasi pengembangan formula R&D.",
      "",
      "— Konfigurasi Formula —",
      `Retinol: ${state.retinol}%`,
      `Niacinamide: ${state.niacinamide}%`,
      `Hyaluronic Acid: ${state.hyaluronicAcid}%`,
      `Tekstur: ${texture}`,
      `Wewangian: ${fragrance}`,
      "",
      "— Efficacy Target (simulasi) —",
      `Acne Care: ${Math.round(efficacy.acne)}%`,
      `Brightening: ${Math.round(efficacy.brightening)}%`,
      `Anti-Aging: ${Math.round(efficacy.antiAging)}%`,
      "",
      sample ? `Sampel referensi: ${sample.version} — ${sample.note}` : "",
    ]
      .filter(Boolean)
      .join("\n");
  }

  function updateUI(): void {
    readStateFromDom();
    updateEfficacyUI(calculateEfficacy(state));
    updateSampleLabel();
  }

  root.addEventListener("input", (event) => {
    const target = event.target as HTMLElement;
    if (target.matches("[data-ingredient-slider]")) updateUI();
  });

  root.addEventListener("change", (event) => {
    const target = event.target as HTMLElement;
    if (
      target.matches("[data-texture-select], [data-fragrance-select], [data-sample-input]")
    ) {
      updateUI();
    }
  });

  els.btnRevision?.addEventListener("click", () => {
    const message = `${buildFormulaSummary()}\n\nAksi: Minta revisi sampel baru`;
    window.open(createWhatsappLink(waPhone, message), "_blank", "noopener,noreferrer");
  });

  els.btnApprove?.addEventListener("click", () => {
    const message = `${buildFormulaSummary()}\n\nAksi: Approve formula untuk tahap produksi`;
    window.open(createWhatsappLink(waPhone, message), "_blank", "noopener,noreferrer");
  });

  if (els.waBtn instanceof HTMLAnchorElement) {
    els.waBtn.addEventListener("click", (event) => {
      event.preventDefault();
      window.open(createWhatsappLink(waPhone, buildFormulaSummary()), "_blank", "noopener,noreferrer");
    });
  }

  updateUI();
</script>
