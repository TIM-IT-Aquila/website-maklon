---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { certifications, legalServices } from "../data/certifications";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);

// Alur legalitas — compact 5 steps
const legalSteps = [
  { step: "01", icon: "lucide:clipboard-check", title: "Konsultasi & Assessment", desc: "Identifikasi kebutuhan legalitas dan tentukan jenis sertifikasi yang diperlukan untuk produk Anda." },
  { step: "02", icon: "lucide:file-text", title: "Persiapan Dokumen Teknis", desc: "Tim legal menyiapkan formulasi, COA, spesifikasi, dan dokumen pendukung lainnya." },
  { step: "03", icon: "lucide:send", title: "Pendaftaran ke Lembaga", desc: "Pengajuan ke BPOM, MUI, Kemenkumham, atau lembaga berwenang lainnya." },
  { step: "04", icon: "lucide:search-check", title: "Audit & Verifikasi", desc: "Proses audit fasilitas, sampel, dan dokumen oleh lembaga terkait." },
  { step: "05", icon: "lucide:badge-check", title: "Sertifikat Terbit", desc: "Sertifikat resmi terbit — produk legal dan siap dipasarkan di seluruh Indonesia." },
];
---

<MainLayout
  title="Sertifikasi | Aquila Maklon"
  description="Sertifikasi & legalitas produk maklon: BPOM, Halal, CPKB, ISO, dan HKI — lengkap, transparan, terpercaya."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. SECTION HEADER + CERTIFICATE CARDS                              -->
    <!-- ================================================================== -->
    <section class="bg-base-100 pt-16 pb-4 lg:pt-24 lg:pb-6">
      <div class="mx-auto max-w-5xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-base-200/40 px-5 py-2">
            <Icon name="lucide:award" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">SERTIFIKAT & LISENSI RESMI</span>
          </div>
          <h1 class="mt-5 text-3xl font-black md:text-4xl lg:text-5xl tracking-tight">
            Sertifikasi <span class="text-primary">Resmi</span> yang Kami Miliki
          </h1>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Setiap sertifikat adalah bukti komitmen terhadap standar tertinggi industri kosmetik Indonesia.
          </p>
        </div>
      </div>
    </section>

    <!-- Certificate Cards — Museum Gallery Grid -->
    <section class="bg-base-100 pb-20 lg:pb-28">
      <div class="mx-auto max-w-6xl px-4 lg:px-8">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {certifications.map((cert, i) => (
            <div
              class="cert-card group flex flex-col overflow-hidden rounded-3xl border border-base-200/80 bg-base-100 shadow-sm transition-all duration-500 hover:-translate-y-1.5 hover:shadow-xl hover:border-primary/20"
              style="opacity:0;transform:translateY(30px)"
            >
              {/* Certificate Image — museum frame style */}
              <div class="relative overflow-hidden bg-base-200/30 p-4 pb-0">
                {/* Frame border */}
                <div class="relative overflow-hidden rounded-2xl border-[6px] border-base-100 bg-base-100 shadow-inner">
                  <div class="aspect-[3/4] overflow-hidden">
                    <img
                      src={cert.image}
                      alt={`Sertifikat ${cert.name}`}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  {/* Glossy overlay */}
                  <div class="absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent pointer-events-none"></div>
                </div>
                {/* Ornamental corner accents */}
                <div class="absolute left-5 top-5 h-4 w-4 rounded-br-md border-l-2 border-t-2 border-primary/30"></div>
                <div class="absolute right-5 top-5 h-4 w-4 rounded-bl-md border-r-2 border-t-2 border-primary/30"></div>
                <div class="absolute bottom-1 left-5 h-4 w-4 rounded-tr-md border-l-2 border-b-2 border-primary/30"></div>
                <div class="absolute bottom-1 right-5 h-4 w-4 rounded-tl-md border-r-2 border-b-2 border-primary/30"></div>
              </div>

              {/* Details */}
              <div class="flex flex-1 flex-col p-5">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="badge badge-soft badge-primary px-2.5 py-1.5 text-[10px] font-bold tracking-wider">
                    {cert.name}
                  </span>
                  <span class="text-[11px] font-medium text-base-content/35 tracking-wider">
                    {cert.year}
                  </span>
                </div>
                <h3 class="mt-2 text-sm font-bold text-base-content leading-snug">
                  {cert.fullName}
                </h3>
                <div class="mt-1 flex items-center gap-1.5">
                  <Icon name="lucide:hash" size={11} class="text-base-content/25" />
                  <span class="text-[11px] font-mono text-base-content/40 tracking-wide">{cert.number}</span>
                </div>
                <p class="mt-2.5 flex-1 text-xs leading-relaxed text-base-content/50 line-clamp-3">
                  {cert.desc}
                </p>
                {/* Hover accent line */}
                <div class="mt-3 h-0.5 w-0 rounded-full bg-gradient-to-r from-primary to-secondary transition-all duration-700 group-hover:w-20"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. LAYANAN LEGALITAS — Auto-sliding Marquee                       -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/40 py-20 lg:py-28">
      <div class="pointer-events-none absolute -left-60 bottom-0 h-[400px] w-[400px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute -right-40 top-0 h-[350px] w-[350px] rounded-full bg-secondary/[0.03] blur-3xl"></div>

      <div class="mx-auto max-w-5xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-base-200/40 px-5 py-2">
            <Icon name="lucide:scale" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">LAYANAN LEGALITAS</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Kami Bantu Proses Legalitas Anda</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Tim legal profesional mendampingi setiap tahap pengurusan dokumen dan sertifikasi produk.
          </p>
        </div>

        <!-- Row 1 — slide left -->
        <div class="mt-12 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
          <div class="flex animate-scroll-left gap-4" style="--scroll-speed:25s">
            {[...legalServices, ...legalServices].map((svc) => (
              <div class="group w-72 shrink-0 rounded-2xl border border-base-200 bg-base-100 p-6 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/15 hover:shadow-lg">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-primary/10 to-secondary/10 transition-all duration-500 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-secondary/20">
                  <Icon name={svc.icon} size={24} />
                </div>
                <h4 class="text-base font-bold text-base-content">{svc.title}</h4>
                <p class="mt-2 text-sm leading-relaxed text-base-content/55">{svc.desc}</p>
                <div class="mt-4 h-1 w-full rounded-full bg-base-200 overflow-hidden">
                  <div class="h-full w-0 rounded-full bg-gradient-to-r from-primary to-secondary transition-all duration-700 group-hover:w-full"></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Row 2 — slide right -->
        <div class="mt-4 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
          <div class="flex animate-scroll-right gap-4" style="--scroll-speed:30s">
            {[...legalServices].reverse().map((svc) => (
              <div class="group w-72 shrink-0 rounded-2xl border border-base-200 bg-base-100 p-6 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-secondary/15 hover:shadow-lg">
                <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-secondary/10 to-primary/10 transition-all duration-500 group-hover:scale-110 group-hover:from-secondary/20 group-hover:to-primary/20">
                  <Icon name={svc.icon} size={24} />
                </div>
                <h4 class="text-base font-bold text-base-content">{svc.title}</h4>
                <p class="mt-2 text-sm leading-relaxed text-base-content/55">{svc.desc}</p>
                <div class="mt-4 h-1 w-full rounded-full bg-base-200 overflow-hidden">
                  <div class="h-full w-0 rounded-full bg-gradient-to-r from-secondary to-primary transition-all duration-700 group-hover:w-full"></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. ALUR LEGALITAS — Timeline simpel & elegan                      -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-20 lg:py-28">
      <div class="mx-auto max-w-5xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-base-200/40 px-5 py-2">
            <Icon name="lucide:git-branch" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">ALUR LEGALITAS</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Proses Pengurusan Legalitas</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Alur jelas dan transparan dalam setiap tahap pengurusan sertifikasi produk Anda.
          </p>
        </div>

        {/* Desktop: Zig-zag timeline */}
        <div class="mt-14 hidden lg:block">
          <div class="relative">
            <div class="absolute left-1/2 top-0 h-full w-0.5 -translate-x-1/2 bg-gradient-to-b from-primary/20 via-primary to-secondary/30 rounded-full"></div>
            <div class="space-y-0">
              {legalSteps.map((item, i) => {
                const isLeft = i % 2 === 0;
                return (
                  <div class={`timeline-step relative flex items-center ${isLeft ? '' : 'justify-end'}`} style="min-height:130px;opacity:0;transform:translateY(24px)">
                    {/* Center dot */}
                    <div class="absolute left-1/2 top-1/2 z-10 -translate-x-1/2 -translate-y-1/2">
                      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-primary to-secondary text-base font-black text-white shadow-lg transition-all duration-500 hover:scale-125 hover:shadow-xl">
                        {item.step}
                      </div>
                    </div>

                    {isLeft ? (
                      <div class="mr-[calc(50%+40px)] group w-full max-w-md text-right">
                        <div class="relative rounded-2xl border border-base-200 bg-base-100 p-5 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg">
                          <div class="absolute -right-2 top-1/2 h-4 w-4 -translate-y-1/2 rotate-45 border-r border-t border-base-200 bg-base-100"></div>
                          <span class="text-[10px] font-bold tracking-[0.3em] text-primary">{item.step}</span>
                          <h3 class="mt-1 text-base font-bold text-base-content">{item.title}</h3>
                          <p class="mt-1.5 text-sm leading-relaxed text-base-content/55">{item.desc}</p>
                        </div>
                      </div>
                    ) : (
                      <div class="ml-[calc(50%+40px)] group w-full max-w-md">
                        <div class="relative rounded-2xl border border-base-200 bg-base-100 p-5 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg">
                          <div class="absolute -left-2 top-1/2 h-4 w-4 -translate-y-1/2 rotate-45 border-b border-l border-base-200 bg-base-100"></div>
                          <span class="text-[10px] font-bold tracking-[0.3em] text-primary">{item.step}</span>
                          <h3 class="mt-1 text-base font-bold text-base-content">{item.title}</h3>
                          <p class="mt-1.5 text-sm leading-relaxed text-base-content/55">{item.desc}</p>
                        </div>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        {/* Mobile: vertical timeline */}
        <div class="mt-12 lg:hidden">
          <div class="relative">
            {legalSteps.map((item, i) => (
              <div class="group relative flex gap-4 pb-6">
                {i < legalSteps.length - 1 && (
                  <div class="absolute left-[23px] top-12 h-full w-0.5 bg-gradient-to-b from-primary/30 to-transparent"></div>
                )}
                <div class="relative z-10 flex h-[46px] w-[46px] shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-primary to-secondary text-sm font-black text-white shadow-md transition-all duration-500 group-hover:scale-110">
                  {item.step}
                </div>
                <div class="flex-1 rounded-xl border border-base-200 bg-base-100 px-4 py-3.5 shadow-sm transition-all duration-500 group-hover:-translate-x-0.5 group-hover:border-primary/15">
                  <h4 class="text-sm font-bold text-base-content">{item.title}</h4>
                  <p class="mt-1 text-sm leading-relaxed text-base-content/55">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. CTA PREMIUM BANNER                                             -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-secondary"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image:radial-gradient(circle at 50% 50%, white 1px, transparent 1px);background-size:50px 50px"></div>

      <div class="relative mx-auto max-w-5xl px-4 text-center lg:px-8">
        <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm animate-bounce">
          <Icon name="lucide:shield-check" size={48} class="text-white" />
        </div>
        <h2 class="text-4xl font-black text-white md:text-5xl lg:text-6xl leading-tight">
          Butuh Bantuan <span class="text-white/90">Legalitas Produk?</span>
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-lg text-white/75 md:text-xl leading-relaxed">
          Konsultasikan kebutuhan legalitas produk Anda dengan tim kami. Kami siap mendampingi dari awal hingga sertifikat terbit.
        </p>
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={waLink} target="_blank" rel="noopener noreferrer"
            class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white bg-white px-10 text-base text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl">
            <Icon name="mdi:whatsapp" class="mr-2 h-5 w-5" />
            Konsultasi via WhatsApp
          </a>
          <a href="/layanan"
            class="btn btn-lg h-14 min-h-14 rounded-full border-2 border-white/30 bg-white/10 px-10 text-base text-white backdrop-blur-sm transition-all duration-300 hover:border-white/50 hover:bg-white/20">
            Lihat Layanan Kami
          </a>
        </div>
        <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-sm text-white/60">
          <span class="flex items-center gap-1.5"><Icon name="lucide:check" size={14} /> Gratis Konsultasi</span>
          <span class="flex items-center gap-1.5"><Icon name="lucide:shield" size={14} /> Proses Transparan</span>
          <span class="flex items-center gap-1.5"><Icon name="lucide:check" size={14} /> Pendampingan Penuh</span>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<script>
  // Staggered reveal animation for cert cards & timeline steps
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const delay = parseFloat(el.dataset.delay || "0");
          setTimeout(() => {
            el.style.transition = "opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1)";
            el.style.opacity = "1";
            el.style.transform = "translateY(0)";
          }, delay);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: "0px 0px -30px 0px" }
  );

  // Certificate cards
  document.querySelectorAll(".cert-card").forEach((el, i) => {
    el.setAttribute("data-delay", String(i * 80));
    observer.observe(el);
  });

  // Timeline steps
  document.querySelectorAll(".timeline-step").forEach((el, i) => {
    el.setAttribute("data-delay", String(i * 100));
    observer.observe(el);
  });
</script>
