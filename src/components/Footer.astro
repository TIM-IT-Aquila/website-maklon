---
import { siteConfig } from "../data/site";
import { navItems } from "../data/nav";
import Container from "./ui/Container.astro";
import Icon from "./ui/Icon.astro";
import WAButton from "./ui/WAButton.astro";

const currentYear = new Date().getFullYear();
const companyNavItems = navItems.find((item) => item.id === "company")?.children ?? [];
const serviceNavItems = navItems.find((item) => item.id === "services")?.children ?? [];
---

<footer class="border-t border-base-300 bg-base-200/50">
  <Container class="py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
      <!-- Brand Premium -->
      <div class="lg:col-span-1">
        <a
          href="/"
          class="group flex items-center gap-3 transition-all duration-500 hover:opacity-85"
        >
          <img src={siteConfig.logo} alt={siteConfig.name} class="h-10 w-auto" />
          <div class="leading-tight"></div>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-base-content/70">
          {siteConfig.description}
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">
          Halaman
        </h4>
        <ul class="space-y-2.5">
          {
            navItems
              .filter((item) => item.href)
              .map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-sm font-semibold text-base-content/70 transition-colors hover:text-primary"
                  >
                    {item.label}
                  </a>
                </li>
              ))
          }
        </ul>
      </div>

      <!-- Perusahaan -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">
          Perusahaan
        </h4>
        <ul class="space-y-2.5">
          {
            companyNavItems.map((child) => (
              <li>
                <a
                  href={child.href}
                  class="text-sm font-semibold text-base-content/70 transition-colors hover:text-primary"
                >
                  {child.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">
          Layanan
        </h4>
        <ul class="space-y-2.5">
          {
            serviceNavItems.map((child) => (
              <li>
                <a
                  href={child.href}
                  class="text-sm font-semibold text-base-content/70 transition-colors hover:text-primary"
                >
                  {child.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Kontak & CTA -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">
          Kontak
        </h4>
        
        <div class="mt-6">
          <a
            href={`https://www.instagram.com/${siteConfig.Instagram}/`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-xl font-bold transition-all duration-300 bg-primary text-white shadow-md shadow-primary/15 hover:shadow-lg hover:shadow-primary/20 hover:-translate-y-0.5 hover:brightness-110 h-9 px-4 text-xs gap-1.5 w-full"
          >
            <Icon name="mdi:instagram" size={14} class="shrink-0" />
            <span>Instagram</span>
          </a>
        </div>
        <div class="mt-6">
          <WAButton text="Konsultasi Gratis" variant="primary" size="sm" class="w-full rounded-full" />
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-base-300 pt-6 text-center text-sm text-base-content/40">
      &copy; {currentYear}
      {siteConfig.name}. All rights reserved.
    </div>
  </Container>
</footer>
