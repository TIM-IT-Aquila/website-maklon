---
import Icon from "../components/ui/Icon.astro";
import PageHero from "../components/ui/PageHero.astro";
import WAButton from "../components/ui/WAButton.astro";
import { siteConfig } from "../data/site";
import {
  legalPillars,
  bureaucracySteps,
  bureaucracyAffirmation,
  brandCheckWaMessage,
  uploadDocumentFields,
  vaultDocuments,
  badgeVariantClass,
  vaultStatusBadge,
  defaultActivePillarId,
  patenBrandHero,
} from "../data/paten-brand-legal";
import { MAX_UPLOAD_SIZE_MB } from "../lib/paten-brand-legal";
import MainLayout from "../layouts/MainLayout.astro";

const currentStep = bureaucracySteps.find((step) => step.status === "current");
const defaultPillar = legalPillars.find((p) => p.id === defaultActivePillarId) ?? legalPillars[0];
---

<MainLayout
  title="Pendaftaran Merek & HKI | Magna"
  description="Portal legalitas brand skincare â€” pantau status HAKI, BPOM, Halal, progres birokrasi, dan brankas dokumen legalitas Anda."
>
  <main class="overflow-hidden">
    <section
      id="paten-brand-legal"
      class="relative overflow-hidden bg-base-100"
      data-paten-brand-legal
    >
      <PageHero
        image={patenBrandHero.image}
        alt={patenBrandHero.alt}
        titleMain="Legalitas Brand"
        titleAccent="Aman & Terpercaya"
      >
        <p
          slot="description"
          class="mt-3 max-w-lg text-sm leading-relaxed text-white/55 md:text-base"
        >
          Kami mengurus HAKI, izin edar BPOM, dan sertifikasi halal — Anda fokus membangun dan
          memasarkan brand skincare Anda.
        </p>
      </PageHero>

      <div class="relative mx-auto max-w-7xl px-4 pb-16 pt-10 lg:px-8 lg:pb-20">
        <div class="space-y-8">
          <!-- 1. Tiga Pilar Legalitas — DaisyUI Stats -->
          <div>
            <div class="mb-4 flex items-center justify-center gap-2">
              <Icon name="lucide:scale" size={18} class="text-info" />
              <h2 class="text-base font-bold text-base-content">
                3 Pilar Legalitas yang Kami Urus
              </h2>
            </div>

            <div
              class="stats stats-vertical w-full overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm lg:stats-horizontal"
            >
              {
                legalPillars.map((pillar, index) => (
                  <button
                    type="button"
                    class:list={[
                      "stat cursor-pointer border-slate-100 text-left transition-all duration-300 hover:bg-info/[0.03]",
                      index < legalPillars.length - 1 && "border-b lg:border-b-0 lg:border-r",
                      pillar.id === defaultActivePillarId &&
                        "bg-info/[0.04] ring-2 ring-inset ring-info/20",
                    ]}
                    data-pillar-tab={pillar.id}
                    aria-pressed={pillar.id === defaultActivePillarId}
                  >
                    <div class="stat-figure text-info">
                      <Icon name={pillar.icon} size={22} />
                    </div>
                    <div class="stat-title text-xs font-medium text-base-content/50">
                      {pillar.shortTitle}
                    </div>
                    <div class="stat-value text-2xl text-primary">{pillar.statValue}</div>
                    <div class="stat-desc text-xs">{pillar.statDesc}</div>
                    <span class={`badge badge-xs mt-2 ${badgeVariantClass[pillar.badgeVariant]}`}>
                      {pillar.statusLabel}
                    </span>
                  </button>
                ))
              }
            </div>

            <!-- Detail pilar aktif -->
            <div
              class="mt-4 rounded-2xl border border-info/15 bg-gradient-to-br from-info/[0.04] to-primary/[0.03] p-5 shadow-sm lg:p-6"
              data-pillar-detail
            >
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-base font-bold text-base-content" data-pillar-title>
                    {defaultPillar.title}
                  </h3>
                  <p
                    class="mt-2 max-w-2xl text-sm leading-relaxed text-base-content/55"
                    data-pillar-desc
                  >
                    {defaultPillar.description}
                  </p>
                </div>
                <span
                  class={`badge shrink-0 ${badgeVariantClass[defaultPillar.badgeVariant]}`}
                  data-pillar-badge
                >
                  {defaultPillar.statusLabel}
                </span>
              </div>
              <ul class="mt-4 grid gap-2 sm:grid-cols-2" data-pillar-services>
                {
                  defaultPillar.services.map((service) => (
                    <li class="flex items-center gap-2 rounded-lg border border-white/60 bg-white/70 px-3 py-2 text-sm text-base-content/65">
                      <Icon name="lucide:check" size={14} class="shrink-0 text-primary" />
                      {service}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <!-- Cek Nama Merek — interaktif -->
          <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm lg:p-6">
            <div class="mb-4 flex items-center gap-2">
              <Icon name="lucide:search" size={18} class="text-primary" />
              <h2 class="text-base font-bold text-base-content">Cek Ketersediaan Nama Merek</h2>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row">
              <input
                type="text"
                placeholder="Contoh: GlowSkin, PureAura, DermaLab..."
                class="input input-bordered flex-1 bg-slate-50/50"
                data-brand-name-input
                maxlength="60"
              />
              <button
                type="button"
                class="btn btn-info btn-soft rounded-xl sm:shrink-0"
                data-btn-simulate-check
              >
                <Icon name="lucide:scan-search" size={16} />
                Simulasi Cek Nama
              </button>
            </div>
            <p class="mt-3 hidden text-sm font-medium" data-brand-check-result></p>
            <p class="mt-2 text-[11px] text-base-content/45">
              Simulasi ini memberi gambaran awal. Untuk hasil resmi DJKI, gunakan tombol WhatsApp di
              bawah.
            </p>
          </div>

          <!-- 2. Linimasa Birokrasi -->
          <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm lg:p-6">
            <div class="mb-2 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <div class="flex items-center gap-2">
                <Icon name="lucide:route" size={18} class="text-info" />
                <h2 class="text-base font-bold text-base-content">Linimasa Birokrasi</h2>
              </div>
              {
                currentStep && (
                  <span class="badge badge-info badge-outline text-xs">
                    Tahap aktif: {currentStep.title}
                  </span>
                )
              }
            </div>

            <p
              class="mb-5 rounded-xl border border-primary/15 bg-primary/[0.04] px-4 py-3 text-sm font-medium leading-relaxed text-base-content/70"
            >
              <Icon name="lucide:heart-handshake" size={16} class="mr-1.5 inline text-primary" />
              {bureaucracyAffirmation}
            </p>

            <!-- Desktop steps -->
            <ol class="steps hidden w-full lg:steps-horizontal">
              {
                bureaucracySteps.map((step) => (
                  <li
                    class:list={[
                      "step cursor-pointer text-left transition-opacity hover:opacity-90",
                      step.status === "completed" && "step-primary",
                      step.status === "current" && "step-info",
                    ]}
                    data-content={String(step.step)}
                    data-step-id={step.id}
                    role="button"
                    tabindex="0"
                  >
                    <div class="mt-2 max-w-[150px]">
                      <p class="text-xs font-bold text-base-content">{step.title}</p>
                      <p class="mt-0.5 text-[10px] leading-relaxed text-base-content/45">
                        {step.description}
                      </p>
                    </div>
                  </li>
                ))
              }
            </ol>

            <!-- Mobile steps -->
            <ol class="steps steps-vertical w-full lg:hidden">
              {
                bureaucracySteps.map((step) => (
                  <li
                    class:list={[
                      "step cursor-pointer text-left",
                      step.status === "completed" && "step-primary",
                      step.status === "current" && "step-info",
                    ]}
                    data-content={String(step.step)}
                    data-step-id={step.id}
                    role="button"
                    tabindex="0"
                  >
                    <div class="mt-1 pb-3">
                      <p class="text-sm font-bold text-base-content">{step.title}</p>
                      <p class="mt-0.5 text-xs leading-relaxed text-base-content/50">
                        {step.description}
                      </p>
                      {step.status === "current" && (
                        <span class="badge badge-info badge-xs mt-2">Sedang berjalan</span>
                      )}
                    </div>
                  </li>
                ))
              }
            </ol>

            <!-- Step detail panel -->
            <div
              class="mt-5 rounded-xl border border-slate-200 bg-slate-50/50 p-4"
              data-step-detail
            >
              <div class="flex items-start gap-3">
                <div
                  class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-info/10"
                >
                  <Icon name={currentStep?.icon ?? "lucide:route"} size={16} class="text-info" />
                </div>
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-info/70">
                    Tahap Saat Ini
                  </p>
                  <p class="text-sm font-bold text-base-content" data-step-detail-title>
                    {currentStep?.title}
                  </p>
                  <p
                    class="mt-1 text-xs leading-relaxed text-base-content/55"
                    data-step-detail-desc
                  >
                    {currentStep?.description}
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- 3. Upload + Brankas -->
          <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm lg:p-6">
              <div class="mb-4 flex items-center gap-2">
                <Icon name="lucide:upload" size={18} class="text-primary" />
                <h2 class="text-base font-bold text-base-content">Upload Dokumen Syarat</h2>
              </div>

              <fieldset class="fieldset rounded-xl border border-slate-200 bg-slate-50/40 p-4">
                <legend class="fieldset-legend text-sm font-semibold text-info">Berkas Wajib</legend
                >
                <div class="space-y-4">
                  {
                    uploadDocumentFields.map((field) => (
                      <label class="form-control" data-upload-field={field.id}>
                        <span class="label-text font-medium">{field.label}</span>
                        <input
                          type="file"
                          class="file-input file-input-bordered file-input-sm w-full bg-white"
                          accept={field.accept}
                          data-upload-input={field.id}
                          data-max-mb={field.maxSizeMb}
                        />
                        <span class="label">
                          <span class="label-text-alt text-base-content/45">{field.hint}</span>
                        </span>
                        <p
                          class="text-[11px] font-medium text-base-content/50"
                          data-upload-status={field.id}
                        >
                          Belum ada file dipilih
                        </p>
                      </label>
                    ))
                  }
                </div>
              </fieldset>

              <p class="mt-3 text-[11px] text-base-content/45">
                Maks. <strong>{MAX_UPLOAD_SIZE_MB} MB</strong> per file · PDF, JPG, PNG
              </p>

              <button
                type="button"
                class="btn btn-info btn-soft btn-sm mt-4 rounded-xl"
                data-btn-submit-docs
              >
                <Icon name="lucide:send" size={15} />
                Kirim Dokumen untuk Review
              </button>
            </div>

            <div class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm lg:p-6">
              <div class="mb-4 flex items-center gap-2">
                <Icon name="lucide:folder-lock" size={18} class="text-primary" />
                <h2 class="text-base font-bold text-base-content">Brankas Dokumen Legalitas</h2>
              </div>

              <ul class="list rounded-xl border border-slate-200 bg-slate-50/30">
                {
                  vaultDocuments.map((doc) => (
                    <li class="list-row items-center gap-3 px-4 py-3">
                      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-info/10">
                        <Icon name="lucide:file-text" size={16} class="text-info" />
                      </div>
                      <div class="list-col-grow min-w-0">
                        <p class="truncate text-sm font-semibold">{doc.name}</p>
                        <p class="text-[11px] text-base-content/45">
                          {doc.fileType} · {doc.sizeLabel} · {doc.issuedAt}
                        </p>
                      </div>
                      <div class="flex flex-col items-end gap-1.5 sm:flex-row sm:items-center">
                        <span class={`badge badge-xs ${vaultStatusBadge[doc.status].class}`}>
                          {vaultStatusBadge[doc.status].label}
                        </span>
                        <button
                          type="button"
                          class="btn btn-outline btn-soft btn-xs gap-1 rounded-lg"
                          data-vault-download={doc.id}
                          data-doc-name={doc.name}
                          disabled={doc.status === "processing"}
                        >
                          <Icon name="lucide:download" size={13} />
                          Unduh
                        </button>
                      </div>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <!-- CTA utama -->
          <div
            class="rounded-2xl border border-primary/20 bg-gradient-to-br from-primary/10 via-white to-info/5 p-8 text-center shadow-md"
          >
            <Icon name="lucide:message-circle" size={32} class="mx-auto text-primary" />
            <h2 class="mt-4 text-xl font-black text-base-content md:text-2xl">
              Siap Melindungi Merek Anda?
            </h2>
            <p class="mx-auto mt-2 max-w-lg text-sm text-base-content/55">
              Cek ketersediaan nama merek secara gratis — tim legal kami siap membantu dari awal
              hingga sertifikat terbit.
            </p>
            <WAButton
              text="Cek Ketersediaan Nama Merek Anda Gratis via WhatsApp"
              message={brandCheckWaMessage}
              variant="primary"
              size="lg"
              class="mt-6 shadow-lg shadow-primary/25 mp-cta-brand-check"
            />
          </div>
        </div>
      </div>

      <script
        is:inline
        type="application/json"
        id="mp-pillars"
        set:html={JSON.stringify(legalPillars)}
      />
      <script
        is:inline
        type="application/json"
        id="mp-steps"
        set:html={JSON.stringify(bureaucracySteps)}
      />
      <script
        is:inline
        type="application/json"
        id="mp-upload-fields"
        set:html={JSON.stringify(uploadDocumentFields)}
      />
      <script
        is:inline
        type="application/json"
        id="mp-wa-phone"
        set:html={JSON.stringify(siteConfig.waNumber)}
      />
      <script
        is:inline
        type="application/json"
        id="mp-brand-wa-msg"
        set:html={JSON.stringify(brandCheckWaMessage)}
      />
    </section>
  </main>
</MainLayout>

<script>
  import { createWhatsappLink } from "../lib/whatsapp";
  import { formatUploadSize, isFileWithinLimit } from "../lib/paten-brand-legal";
  import type { LegalPillar, BureaucracyStep } from "../lib/paten-brand-legal";

  interface UploadFieldConfig {
    id: string;
    label: string;
    maxSizeMb: number;
  }

  const root = document.querySelector<HTMLElement>("[data-paten-brand-legal]") as HTMLElement;

  const pillars = JSON.parse(
    document.getElementById("mp-pillars")?.textContent ?? "[]",
  ) as LegalPillar[];
  const steps = JSON.parse(
    document.getElementById("mp-steps")?.textContent ?? "[]",
  ) as BureaucracyStep[];
  const uploadFields = JSON.parse(
    document.getElementById("mp-upload-fields")?.textContent ?? "[]",
  ) as UploadFieldConfig[];
  const waPhone = JSON.parse(document.getElementById("mp-wa-phone")?.textContent ?? '""') as string;
  const brandWaBase = JSON.parse(
    document.getElementById("mp-brand-wa-msg")?.textContent ?? '""',
  ) as string;

  const uploadState: Record<string, { name: string; size: number } | null> = {};

  let activePillarId = pillars[0]?.id ?? "haki";

  function renderPillarDetail(pillarId: string): void {
    const pillar = pillars.find((p) => p.id === pillarId);
    if (!pillar) return;

    const titleEl = root.querySelector<HTMLElement>("[data-pillar-title]");
    const descEl = root.querySelector<HTMLElement>("[data-pillar-desc]");
    const badgeEl = root.querySelector<HTMLElement>("[data-pillar-badge]");
    const servicesEl = root.querySelector<HTMLElement>("[data-pillar-services]");

    if (titleEl) titleEl.textContent = pillar.title;
    if (descEl) descEl.textContent = pillar.description;
    const badgeClasses: Record<string, string> = {
      success: "badge badge-success shrink-0",
      warning: "badge badge-warning shrink-0",
      info: "badge badge-info shrink-0",
    };
    if (badgeEl) {
      badgeEl.textContent = pillar.statusLabel;
      badgeEl.className = badgeClasses[pillar.badgeVariant] ?? "badge shrink-0";
    }
    if (servicesEl) {
      servicesEl.innerHTML = pillar.services
        .map(
          (s) =>
            `<li class="flex items-center gap-2 rounded-lg border border-white/60 bg-white/70 px-3 py-2 text-sm text-base-content/65">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-primary"><path d="M20 6 9 17l-5-5"/></svg>
              ${s}
            </li>`,
        )
        .join("");
    }

    root.querySelectorAll<HTMLButtonElement>("[data-pillar-tab]").forEach((tab) => {
      const isActive = tab.dataset.pillarTab === pillarId;
      tab.setAttribute("aria-pressed", String(isActive));
      tab.classList.toggle("bg-info/[0.04]", isActive);
      tab.classList.toggle("ring-2", isActive);
      tab.classList.toggle("ring-inset", isActive);
      tab.classList.toggle("ring-info/20", isActive);
    });
  }

  root.querySelectorAll<HTMLButtonElement>("[data-pillar-tab]").forEach((tab) => {
    tab.addEventListener("click", () => {
      activePillarId = tab.dataset.pillarTab ?? activePillarId;
      renderPillarDetail(activePillarId);
    });
  });

  function renderStepDetail(stepId: string): void {
    const step = steps.find((s) => s.id === stepId);
    if (!step) return;

    const titleEl = root.querySelector<HTMLElement>("[data-step-detail-title]");
    const descEl = root.querySelector<HTMLElement>("[data-step-detail-desc]");

    if (titleEl) titleEl.textContent = step.title;
    if (descEl) descEl.textContent = step.description;
  }

  root.querySelectorAll<HTMLElement>("[data-step-id]").forEach((el) => {
    const handler = () => renderStepDetail(el.dataset.stepId ?? "");
    el.addEventListener("click", handler);
    el.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        handler();
      }
    });
  });

  const brandInput = root.querySelector<HTMLInputElement>("[data-brand-name-input]");
  const brandResult = root.querySelector<HTMLElement>("[data-brand-check-result]");

  root
    .querySelector<HTMLButtonElement>("[data-btn-simulate-check]")
    ?.addEventListener("click", () => {
      const name = brandInput?.value.trim();
      if (!brandResult) return;

      if (!name) {
        brandResult.textContent = "Masukkan nama merek terlebih dahulu.";
        brandResult.className = "mt-3 text-sm font-medium text-warning";
        brandResult.classList.remove("hidden");
        return;
      }

      brandResult.textContent = "Memeriksa database...";
      brandResult.className = "mt-3 text-sm font-medium text-base-content/50";
      brandResult.classList.remove("hidden");

      window.setTimeout(() => {
        const likelyAvailable = name.length >= 4 && !/^(test|demo|admin)$/i.test(name);
        brandResult.textContent = likelyAvailable
          ? `"${name}" — kemungkinan tersedia untuk diajukan. Konfirmasi resmi via WhatsApp.`
          : `"${name}" — perlu verifikasi lebih lanjut. Hubungi tim kami via WhatsApp.`;
        brandResult.className = `mt-3 text-sm font-medium ${likelyAvailable ? "text-success" : "text-info"}`;
      }, 700);
    });

  const ctaBtn = root.querySelector<HTMLAnchorElement>(".mp-cta-brand-check");
  ctaBtn?.addEventListener("click", (event) => {
    const name = brandInput?.value.trim();
    if (!name) return;
    event.preventDefault();
    const message = `${brandWaBase}\n\nNama merek yang ingin dicek: ${name}`;
    window.open(createWhatsappLink(waPhone, message), "_blank", "noopener,noreferrer");
  });

  function updateUploadStatus(id: string, file: File | null, maxMb: number): void {
    const statusEl = root.querySelector<HTMLElement>(`[data-upload-status="${id}"]`);
    if (!statusEl) return;

    if (!file) {
      uploadState[id] = null;
      statusEl.textContent = "Belum ada file dipilih";
      statusEl.classList.remove("text-error", "text-success");
      return;
    }

    const withinLimit = isFileWithinLimit(file.size, maxMb);
    uploadState[id] = withinLimit ? { name: file.name, size: file.size } : null;
    statusEl.textContent = withinLimit
      ? `${file.name} (${formatUploadSize(file.size)}) — siap diunggah`
      : `File terlalu besar. Maksimal ${maxMb} MB.`;
    statusEl.classList.toggle("text-success", withinLimit);
    statusEl.classList.toggle("text-error", !withinLimit);
  }

  root.querySelectorAll<HTMLInputElement>("[data-upload-input]").forEach((input) => {
    input.addEventListener("change", () => {
      const id = input.dataset.uploadInput ?? "";
      const maxMb = Number(input.dataset.maxMb ?? 5);
      updateUploadStatus(id, input.files?.[0] ?? null, maxMb);
    });
  });

  function buildUploadSummary(): string {
    return uploadFields
      .map((field) => {
        const uploaded = uploadState[field.id];
        return uploaded
          ? `${field.label}: ${uploaded.name} (${formatUploadSize(uploaded.size)})`
          : `${field.label}: belum diunggah`;
      })
      .join("\n");
  }

  root.querySelector<HTMLButtonElement>("[data-btn-submit-docs]")?.addEventListener("click", () => {
    const message = [
      "Halo, saya ingin mengirim dokumen syarat legalitas brand.",
      "",
      buildUploadSummary(),
    ].join("\n");
    window.open(createWhatsappLink(waPhone, message), "_blank", "noopener,noreferrer");
  });

  root.querySelectorAll<HTMLButtonElement>("[data-vault-download]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const docName = btn.dataset.docName ?? "dokumen";
      const message = `Halo, saya ingin mengunduh ${docName} dari brankas dokumen legalitas.`;
      window.open(createWhatsappLink(waPhone, message), "_blank", "noopener,noreferrer");
    });
  });

  renderPillarDetail(activePillarId);
</script>
