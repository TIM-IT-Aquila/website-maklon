---
import Icon from "../components/ui/Icon.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import MainLayout from "../layouts/MainLayout.astro";
import WAButton from "../components/ui/WAButton.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { advantages } from "../data/advantages";
import { services } from "../data/services";
import { processSteps } from "../data/process";
import { products } from "../data/products";
import { faqs } from "../data/faqs";
import { brandPartners, brandPartnersRowTwo } from "../data/brandPartners";
import { categoryImages, factoryImages, processImages, productImages, heroImages } from "../data/images";
import { certifications } from "../data/certifications";
import TestimonialSection from "../components/sections/TestimonialSection.astro";

const processPreviewSteps = processSteps.slice(0, 5);
const topProducts = products.slice(0, 8);
const categories = categoryImages.slice(0, 6);

const heroSlides = [
  {
    image: heroImages.skincareLab,
    titleMain: "Laboratorium Modern",
    titleAccent: "untuk Formulasi Presisi",
    description: "Teknologi riset terkini dan tim ahli R&D siap mengembangkan formula unik untuk brand kecantikan Anda.",
  },
  {
    image: heroImages.skincareProduction,
    titleMain: "Produksi Berkualitas",
    titleAccent: "Standar CPKB & GMP",
    description: "Setiap tahap produksi diawasi ketat agar produk skincare premium Anda aman, konsisten, dan siap dipasarkan.",
  },
  {
    image: heroImages.packagingReady,
    titleMain: "Siap Dikemas & Kirim",
    titleAccent: "Langsung Distribusi",
    description: "Produk jadi dengan kemasan rapi dan legal — siap dikirim ke seluruh Indonesia tanpa repot urusan logistik.",
  },
  {
    image: heroImages.labResearch,
    titleMain: "Riset & Inovasi",
    titleAccent: "500+ Formula Siap Pakai",
    description: "Pilih dari ratusan formula teruji atau kustomisasi sesuai kebutuhan — dari konsultasi hingga produk siap jual.",
  },
];

const galleryItems = [
  { label: "Laboratorium R&D", image: factoryImages.labResearch, icon: "lucide:flask-conical", layout: "featured" as const },
  { label: "Ruang QC", image: factoryImages.qualityControl, icon: "lucide:microscope", layout: "square" as const },
  { label: "Lini Produksi", image: factoryImages.productionLine, icon: "lucide:factory", layout: "square" as const },
  { label: "Area Pengemasan", image: factoryImages.packagingArea, icon: "lucide:package", layout: "square" as const },
  { label: "Ruang Sampling", image: factoryImages.samplingRoom, icon: "lucide:beaker", layout: "square" as const },
  { label: "Gudang Bahan Baku", image: factoryImages.bahanBaku, icon: "lucide:warehouse", layout: "wide" as const },
];

const comparisons = [
  { aspect: "Kepemilikan Pabrik", us: "Pabrik Milik Sendiri", them: "Sering pihak ketiga" },
  { aspect: "Formulasi", us: "Custom 500+ Formula", them: "Terbatas / template" },
  { aspect: "Legalitas", us: "BPOM + Halal + HKI", them: "Belum tentu lengkap" },
  { aspect: "MOQ", us: "Fleksibel", them: "Cenderung tinggi" },
  { aspect: "Pendampingan", us: "Konsultasi gratis", them: "Sering terbatas" },
];
---

<MainLayout
  title="Magna – Jasa Skincare Terpercaya"
  description={siteConfig.description}
>
  <main class="overflow-x-hidden">

    <!-- ================================================================== -->
    <!-- 1. HERO — Image Slider                                              -->
    <!-- ================================================================== -->
    <section id="hero" class="relative flex h-[65vh] min-h-[520px] items-center">
      <!-- Background Slides -->
      <div class="absolute inset-0 z-0">
        {heroSlides.map((slide, idx) => (
          <div
            class="hero-slide absolute inset-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000 ease-in-out"
            class:list={{ "opacity-100": idx === 0, "opacity-0": idx !== 0 }}
            style={`background-image: url('${slide.image}')`}
          ></div>
        ))}
        <!-- Dark overlay -->
        <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/55 to-black/65"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 mx-auto w-full max-w-7xl px-4 lg:px-8">
        <div class="max-w-2xl">
          <div class="relative min-h-[180px] md:min-h-[200px]">
            {heroSlides.map((slide, idx) => (
              <div
                class="hero-text absolute inset-0 transition-opacity duration-1000 ease-in-out"
                class:list={{ "opacity-100": idx === 0, "opacity-0 pointer-events-none": idx !== 0 }}
              >
                <h1 class="text-3xl font-black leading-[1.06] text-white md:text-4xl lg:text-5xl xl:text-6xl">
                  {slide.titleMain}<br />
                  <span class="bg-gradient-to-r from-emerald-300 via-green-200 to-white bg-clip-text text-transparent">
                    {slide.titleAccent}
                  </span>
                </h1>

                <p class="mt-3 max-w-lg text-sm leading-relaxed text-white/55 md:text-base">
                  {slide.description}
                </p>
              </div>
            ))}
          </div>

          <div class="mt-7 flex flex-wrap items-center gap-3">
            <WAButton
              text="Konsultasi Gratis"
              message="Halo, saya ingin konsultasi mengenai maklon skincare."
              variant="white"
              size="md"
              class="rounded-xl shadow-xl shadow-black/20"
            />
            <a href="/outsourcing-flow"
              class="group inline-flex h-11 items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-6 text-xs font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/40 hover:bg-white/10">
              Lihat Alur Maklon
              <Icon name="lucide:arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" />
            </a>
          </div>
        </div>
      </div>

      <!-- Slide indicators — tengah bawah -->
      <div class="absolute bottom-5 left-1/2 z-10 flex -translate-x-1/2 items-center gap-3">
        {heroSlides.map((_, idx) => (
          <button
            class="hero-dot rounded-full bg-white transition-all duration-500"
            class:list={{ "h-3 w-10 bg-white": idx === 0, "h-3 w-3 bg-white/35 hover:bg-white/55": idx !== 0 }}
            data-slide={idx}
            aria-label={`Slide ${idx + 1}`}
          ></button>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. CATEGORY — Grid minimalis sejajar                               -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader label="Kategori" variant="minimal" title="Jelajahi Rangkaian Produk Kami" />

        <div class="mt-12 grid grid-cols-2 gap-5 md:grid-cols-4 md:gap-6">
          {categories.map((cat) => {
            const waCat = createWhatsappLink(siteConfig.waNumber, `Halo, saya tertarik dengan produk kategori ${cat.name}. Bisa info lebih lanjut?`);
            return (
              <a href={waCat} target="_blank" rel="noopener noreferrer"
                class="group flex flex-col rounded-2xl border border-base-200/60 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-lg"
              >
                <div class="p-3 pb-0">
                  <div class="relative w-full overflow-hidden rounded-xl bg-gradient-to-br from-primary/5 to-primary/10" style="aspect-ratio: 4/3">
                    <img src={cat.image} alt={cat.name} class="h-full w-full object-cover transition-all duration-500 group-hover:scale-110" loading="lazy" />
                    <!-- Hover overlay konsultasi -->
                    <div class="absolute inset-0 flex items-center justify-center rounded-xl bg-black/50 opacity-0 backdrop-blur-[1px] transition-all duration-300 group-hover:opacity-100">
                      <span class="flex items-center gap-2 rounded-full bg-white px-6 py-2.5 text-sm font-bold text-primary shadow-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Konsultasi
                      </span>
                    </div>
                  </div>
                </div>
                <div class="px-4 pb-4 pt-3 text-center">
                  <h3 class="text-base font-bold text-base-content">{cat.name}</h3>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. STATS — Animated counters                                       -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-primary py-14 md:py-20">
      <!-- Decorative overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/80 via-primary to-primary/90"></div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid grid-cols-2 gap-5 md:grid-cols-4 md:gap-6">
          {[
            { value: 500, suffix: "+", label: "Formula Siap Pakai" },
            { value: 200, suffix: "+", label: "Brand Partner" },
            { value: 10, suffix: "+", label: "Tahun Pengalaman" },
            { value: 50, suffix: "+", label: "Tenaga Ahli" },
          ].map((stat) => (
            <div class="group relative overflow-hidden rounded-2xl border border-white/15 bg-white/10 p-6 text-center backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:border-white/25 hover:bg-white/15">
              <p class="text-3xl font-black text-white tabular-nums md:text-4xl">
                <span class="stat-counter" data-target={stat.value}>{stat.value}</span>{stat.suffix}
              </p>
              <p class="mt-1.5 text-xs font-semibold tracking-wider text-white/60 uppercase">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. LAYANAN — Service cards with image hover overlay                 -->
    <!-- ================================================================== -->
    <section id="layanan" class="bg-base-200/40 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader label="Layanan" variant="minimal" title="Solusi Lengkap untuk Brand Kecantikan Anda" />

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {services.map((svc) => {
            const waService = createWhatsappLink(siteConfig.waNumber, `Halo, saya tertarik dengan layanan ${svc.title}. Bisa info lebih lanjut?`);
            return (
              <a href={waService} target="_blank" rel="noopener noreferrer"
                class="group flex flex-col items-center rounded-2xl border border-base-200/60 bg-white p-4 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-md"
              >
                <div class="relative w-full overflow-hidden rounded-xl" style="aspect-ratio: 4/3">
                  <img src={svc.image} alt={svc.title} class="h-full w-full object-contain transition-all duration-500 group-hover:scale-105" loading="lazy" />
                  <!-- Hover overlay konsultasi -->
                  <div class="absolute inset-0 flex items-center justify-center rounded-xl bg-black/50 opacity-0 backdrop-blur-[1px] transition-all duration-300 group-hover:opacity-100">
                    <span class="flex items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-bold text-primary shadow-lg">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                      Konsultasi
                    </span>
                  </div>
                </div>
                <div class="mt-3 text-center">
                  <h3 class="text-sm font-bold text-base-content">{svc.title}</h3>
                  <p class="mt-1 text-xs text-base-content/50 line-clamp-2">{svc.desc}</p>
                </div>
              </a>
            );
          })}
        </div>

        <div class="mt-10 text-center">
          <a href="/layanan" class="btn btn-outline btn-primary">
            Lihat Semua Layanan
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. KEUNGGULAN — Split layout: image left + cards right              -->
    <!-- ================================================================== -->
    <section id="keunggulan" class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader label="Keunggulan" variant="minimal">
          <span slot="title">Kenapa <span class="text-primary">Magna?</span></span>
        </SectionHeader>

        <div class="mt-16 flex flex-col gap-8 lg:flex-row">
          <!-- Left: Featured image -->
          <div class="reveal-up relative overflow-hidden rounded-2xl lg:w-[42%]">
            <img src="/assets/hero-home/skincarelab.jpg" alt="Lab Magna" class="h-72 w-full object-cover lg:h-full lg:min-h-[480px]" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent lg:bg-gradient-to-r lg:from-black/30"></div>
            <div class="absolute bottom-5 left-5 lg:top-5 lg:left-5 lg:bottom-auto">
              <span class="inline-block rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-bold tracking-wider text-white backdrop-blur-md uppercase">Lab R&D Internal</span>
            </div>
          </div>

          <!-- Right: Advantages grid -->
          <div class="grid gap-4 sm:grid-cols-2 lg:w-[58%]">
            {advantages.map((adv) => (
              <div class="reveal-up group flex items-start gap-4 rounded-2xl border border-base-200/70 bg-white p-5 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-primary/15 hover:shadow-lg">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/8 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white group-hover:shadow-lg group-hover:shadow-primary/15">
                  <Icon name={adv.icon} class="h-5 w-5" />
                </div>
                <div class="min-w-0">
                  <h3 class="text-sm font-bold transition-colors duration-300 group-hover:text-primary">{adv.title}</h3>
                  <p class="mt-1 text-xs leading-relaxed text-base-content/50">{adv.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 6. PRODUCT SHOWCASE — Modern hover cards                            -->
    <!-- ================================================================== -->
    <section id="produk" class="bg-base-200/40 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader label="Produk" variant="minimal">
          <span slot="title">Produk yang Bisa <span class="text-primary">Kami Buat</span></span>
        </SectionHeader>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {topProducts.map((product) => {
            const waProduct = createWhatsappLink(siteConfig.waNumber, `Halo, saya tertarik dengan produk ${product.name}. Bisa info lebih lanjut?`);
            return (
            <div class="reveal-up">
              <!-- Card -->
              <a href={waProduct} target="_blank" rel="noopener noreferrer" class="group relative block aspect-square w-full overflow-hidden rounded-2xl border border-base-200/70 bg-base-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-md">
                <img src={product.image} alt={product.name} class="h-full w-full object-cover transition-all duration-500 group-hover:scale-105" loading="lazy" />
                <span class="absolute right-2 top-2 rounded-lg bg-primary px-2.5 py-1 text-[10px] font-bold text-white shadow-sm">{product.category}</span>
                <!-- Nama produk di dalam card bawah tengah -->
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent p-3 pt-8">
                  <h3 class="text-center text-xs font-semibold text-white drop-shadow-sm">{product.name}</h3>
                </div>
                <!-- Overlay hover/click: popup deskripsi -->
                <div class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl bg-black/55 p-4 opacity-0 backdrop-blur-[1px] transition-all duration-300 group-hover:opacity-100">
                  <p class="text-center text-sm leading-relaxed text-white/90">{product.desc}</p>
                  <span class="mt-4 inline-flex items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-bold text-primary shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Konsultasi
                  </span>
                </div>
              </a>
            </div>
            );
          })}
        </div>

        <div class="mt-10 text-center">
          <a href="/products" class="btn btn-outline btn-primary">
            Lihat Semua Produk
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 7. PROCESS — Interactive timeline + mobile carousel                 -->
    <!-- ================================================================== -->
    <section id="alur" class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader label="Alur" variant="minimal" title="Proses Mudah & Transparan" />

        <!-- DESKTOP: Interactive timeline -->
        <div class="mt-14 hidden gap-8 lg:flex">
          <div class="w-[42%] space-y-2">
            {processPreviewSteps.map((step, idx) => (
              <button
                class="process-btn group flex w-full items-center gap-4 rounded-xl border p-4 text-left transition-all duration-500"
                class:list={{
                  "border-primary/30 bg-primary/[0.04] shadow-md": idx === 0,
                  "border-base-200/70 bg-white shadow-sm hover:border-primary/20 hover:bg-primary/[0.02]": idx !== 0,
                }}
                data-step={idx}
              >
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/8 text-primary transition-all duration-500 group-[.border-primary/30]:bg-primary group-[.border-primary/30]:text-white group-[.border-primary/30]:shadow-md group-[.border-primary/30]:shadow-primary/20">
                  <Icon name={step.icon} class="h-5 w-5" />
                </div>
                <div class="text-left">
                  <span class="text-[10px] font-bold tracking-[0.15em] text-primary/50 uppercase">Tahap {step.step}</span>
                  <h3 class="text-sm font-bold">{step.title}</h3>
                </div>
                <div class="ml-auto h-2 w-2 shrink-0 rounded-full bg-transparent transition-all duration-500 group-[.border-primary/30]:bg-primary group-[.border-primary/30]:scale-100 scale-0"></div>
              </button>
            ))}
          </div>

          <div class="w-[58%]">
            <div class="sticky top-24 overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-lg">
              <div class="relative aspect-[4/3] bg-base-200">
                {processPreviewSteps.map((step, idx) => (
                  <img
                    id={`process-img-${idx}`}
                    class="process-img absolute inset-0 h-full w-full object-cover"
                    class:list={{ "opacity-100 scale-100": idx === 0, "opacity-0 scale-110": idx !== 0 }}
                    src={processImages[step.imageKey]}
                    alt={step.title}
                    loading={idx === 0 ? "eager" : "lazy"}
                  />
                ))}
                <div class="pointer-events-none absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-black/50 to-transparent"></div>
                <div class="absolute bottom-6 left-6 flex items-center gap-3">
                  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/20 text-white backdrop-blur-md">
                    <Icon id="process-slide-icon" name={processPreviewSteps[0].icon} class="h-5 w-5" />
                  </div>
                  <div>
                    <span id="process-step-label" class="text-[10px] font-bold tracking-wider text-white/60 uppercase">Tahap 1</span>
                    <h3 id="process-step-title" class="text-lg font-bold text-white">{processPreviewSteps[0].title}</h3>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- MOBILE: Card carousel -->
        <div class="mt-10 lg:hidden">
          <div class="relative">
            <div class="mb-4 flex items-center gap-3">
              <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-base-200">
                <div id="mobile-progress" class="h-full rounded-full bg-primary transition-all duration-500 ease-out" style="width: 20%"></div>
              </div>
              <span class="text-xs font-bold text-base-content/40">
                <span id="mobile-current">1</span>/<span>{processPreviewSteps.length}</span>
              </span>
            </div>
            <div class="overflow-hidden rounded-2xl shadow-md">
              <div class="relative aspect-[16/9] bg-base-200">
                {processPreviewSteps.map((step, idx) => (
                  <img
                    id={`mobile-img-${idx}`}
                    class="absolute inset-0 h-full w-full object-cover transition-all duration-600 ease-in-out"
                    class:list={{ "opacity-100 scale-100": idx === 0, "opacity-0 scale-110": idx !== 0 }}
                    src={processImages[step.imageKey]}
                    alt={step.title}
                    loading="lazy"
                  />
                ))}
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                <div class="absolute bottom-4 left-4 flex items-center gap-2">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/20 text-white backdrop-blur-md">
                    <Icon id="mobile-slide-icon" name={processPreviewSteps[0].icon} class="h-4 w-4" />
                  </div>
                  <span id="mobile-title" class="text-sm font-bold text-white">{processPreviewSteps[0].title}</span>
                </div>
              </div>
            </div>
            <div class="mt-3 overflow-hidden rounded-2xl">
              <div id="mobile-track" class="flex transition-transform duration-500 ease-out">
                {processPreviewSteps.map((step) => (
                  <div class="w-full shrink-0 px-0.5">
                    <div class="rounded-2xl border border-base-200 bg-white p-4 shadow-sm">
                      <div class="flex items-center gap-3">
                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                          <Icon name={step.icon} class="h-5 w-5" />
                        </div>
                        <div>
                          <span class="text-[10px] font-bold tracking-wider text-primary/50">TAHAP {step.step}</span>
                          <h3 class="text-sm font-bold">{step.title}</h3>
                        </div>
                      </div>
                      <p class="mt-2 text-sm leading-relaxed text-base-content/60">{step.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="mt-4 flex items-center justify-between">
              <button id="mobile-prev" class="btn btn-circle btn-ghost btn-sm" aria-label="Sebelumnya">
                <Icon name="lucide:chevron-left" class="h-4 w-4" />
              </button>
              <div class="flex gap-1.5">
                {processPreviewSteps.map((_, i) => (
                  <button class={`mobile-dot rounded-full transition-all duration-400 ${i === 0 ? "h-1.5 w-6 bg-primary" : "h-1.5 w-1.5 bg-base-300"}`} data-dot={i} aria-label={`Tahap ${i + 1}`}></button>
                ))}
              </div>
              <button id="mobile-next" class="btn btn-circle btn-ghost btn-sm" aria-label="Selanjutnya">
                <Icon name="lucide:chevron-right" class="h-4 w-4" />
              </button>
            </div>
          </div>
        </div>

        <div class="mt-10 text-center">
