---
interface Props {
  title: string;
  description?: string;
  badge?: string;
  breadcrumb?: string;
}

const { title, description: _description, badge, breadcrumb } = Astro.props;
const displayLabel = badge || breadcrumb || title;
---

<section class="relative overflow-hidden bg-gradient-to-b from-base-100 to-base-200 pb-16 pt-28 md:pt-36">
  <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-secondary/10 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center justify-center gap-2 text-sm text-base-content/50">
        <a href="/" class="transition-colors hover:text-primary">Home</a>
        <span>/</span>
        <span class="text-base-content/80 font-medium">{breadcrumb || title}</span>
      </nav>

      <div class="mb-6 flex items-center justify-center gap-3">
        <span class="block h-px w-8 bg-primary/30"></span>
        <span class="text-[11px] font-semibold tracking-[0.2em] text-primary/60 uppercase">{displayLabel}</span>
        <span class="block h-px w-8 bg-primary/30"></span>
      </div>

      <h1 class="text-4xl font-black md:text-5xl lg:text-6xl">{title}</h1>
    </div>
  </div>
</section>