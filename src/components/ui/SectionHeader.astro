---
interface Props {
  tag?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { tag, title, description, centered = true } = Astro.props;
---

<div class={`mb-8 ${centered ? "text-center" : ""}`}>
  {tag && (
    <p class="mb-2 font-semibold tracking-wide text-primary">{tag}</p>
  )}
  <h2 class="text-3xl font-black md:text-4xl">{title}</h2>
  {description && (
    <p class="mx-auto mt-3 max-w-2xl text-base-content/70 md:text-lg">
      {description}
    </p>
  )}
</div>