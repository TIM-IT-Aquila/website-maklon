---
import MainLayout from "../layouts/MainLayout.astro";
import { blogPosts } from "../data/blog";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";

const waLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi seputar bisnis maklon skincare.");
---

<MainLayout
  title="Blog | Aquila Magna"
  description="Baca artikel dan panduan seputar bisnis maklon skincare, kosmetik, tips branding, dan tren terkini."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. GRID 2 KOLOM — Foto lebar kotak-kotak                           -->
    <!-- ================================================================== -->
    <section class="mx-auto max-w-7xl px-4 pt-12 pb-20 lg:px-8 lg:pt-20 lg:pb-28">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:gap-8">
        {blogPosts.map((post, i) => {
          // Variasi tinggi gambar besar & sedang, kotak semua
          const heights = ["h-64", "h-80", "h-60", "h-96", "h-72", "h-56", "h-80", "h-64"];
          const imgH = heights[i % heights.length];

          return (
            <div class="blog-card">
              {/* ── Foto — lebar, rounded, kotak ── */}
              <a href={"/blog/" + post.slug} class="group block overflow-hidden rounded-2xl shadow-md transition-all duration-400 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-1">
                <figure class={imgH + " w-full overflow-hidden rounded-2xl"}>
                  <img
                    src={post.image}
                    alt={post.title}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                </figure>
              </a>

              {/* ── Teks / Deskripsi DI LUAR card ── */}
              <div class="mt-4 px-1">
                {/* Date & read time */}
                <div class="flex items-center gap-2 text-[11px] text-base-content/40">
                  <Icon name="lucide:calendar" size={12} />
                  <span>{post.date}</span>
                  <span>·</span>
                  <Icon name="lucide:clock" size={12} />
                  <span>{post.readTime}</span>
                </div>

                {/* Title */}
                <h3 class="mt-1.5 text-base font-bold leading-snug transition-colors duration-300 hover:text-primary lg:text-lg">
                  <a href={"/blog/" + post.slug}>
                    {post.title}
                  </a>
                </h3>

                {/* Short description */}
                <p class="mt-1.5 text-sm leading-relaxed text-base-content/55 line-clamp-2">
                  {post.excerpt}
                </p>

                {/* Read more */}
                <a href={"/blog/" + post.slug} class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-primary transition-all duration-300 hover:gap-2">
                  Baca Selengkapnya
                  <Icon name="lucide:arrow-right" size={13} />
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. CTA PREMIUM BANNER                                              -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-emerald-800"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image:radial-gradient(circle at 50% 50%, white 1px, transparent 1px);background-size:50px 50px"></div>

      <div class="relative mx-auto max-w-7xl px-4 text-center lg:px-8">
        <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm">
          <Icon name="lucide:message-circle" size={36} class="text-white" />
        </div>

        <h2 class="text-3xl font-black text-white md:text-4xl lg:text-5xl leading-tight">
          Ingin Konsultasi Langsung?
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base text-white/70 md:text-lg leading-relaxed">
          Punya pertanyaan seputar bisnis maklon? Tim kami siap membantu Anda melalui WhatsApp.
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={waLink} target="_blank" rel="noopener noreferrer"
            class="btn btn-lg h-14 min-h-14 rounded-xl border-2 border-white bg-white px-10 text-base font-bold text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl">
            <Icon name="mdi:whatsapp" size={20} />
            Konsultasi via WhatsApp
            <Icon name="lucide:arrow-right" size={18} />
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<script>
  // IntersectionObserver  staggered reveal on scroll
  const observerOptions = { threshold: 0.1, rootMargin: "0px 0px -30px 0px" };

  const reveal = (entries, obs) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target;
        const allCards = document.querySelectorAll(".blog-card");
        const realIdx = Array.from(allCards).indexOf(el);
        el.style.transition = "all 0.5s cubic-bezier(0.16, 1, 0.3, 1) " + (realIdx * 0.06) + "s";
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
        obs.unobserve(el);
      }
    });
  };

  const observer = new IntersectionObserver(reveal, observerOptions);
  document.querySelectorAll(".blog-card").forEach(el => {
    el.style.opacity = "0";
    el.style.transform = "translateY(20px)";
    observer.observe(el);
  });
</script>
