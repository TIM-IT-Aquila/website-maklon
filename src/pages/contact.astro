---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { companyImages } from "../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
---

<MainLayout
  title="Kontak | Aquila Maklon"
  description="Hubungi kami untuk konsultasi maklon skincare dan kosmetik. Kantor di Jakarta Pusat."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. CONSULTATION FORM — Compact, aligned to navbar                  -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/40 py-12 lg:py-20">
      <div class="pointer-events-none absolute -left-60 bottom-0 h-[300px] w-[300px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute -right-40 top-0 h-[250px] w-[250px] rounded-full bg-secondary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto max-w-lg text-center mb-8">
          <span class="badge badge-soft badge-primary mb-3 px-3 py-1.5 text-[11px] font-semibold tracking-wider">FORM KONSULTASI</span>
          <h2 class="text-2xl font-black md:text-3xl">Mulai Konsultasi Produk</h2>
          <p class="mt-2 text-sm text-base-content/55 md:text-base">
            Isi form di bawah — <span class="font-semibold text-primary">gratis & tanpa komitmen</span>. Tim kami akan merespon dalam 1×24 jam.
          </p>
        </div>

        <div class="card overflow-hidden border border-base-200 bg-base-100 shadow-md">
          <div class="card-body p-0">
            <form class="divide-y divide-base-200" data-wa-number={siteConfig.waNumber} id="consultForm">
              {/* ===== Row 1: Nama & WhatsApp ===== */}
              <div class="grid gap-0 p-5 sm:grid-cols-2 sm:gap-5 sm:p-6">
                <div class="form-control py-2 sm:py-0">
                  <label class="label p-0 mb-1.5">
                    <span class="text-sm font-semibold">Nama Lengkap <span class="text-error">*</span></span>
                  </label>
                  <input type="text" id="nama" name="nama" placeholder="Masukkan nama lengkap Anda" required
                    class="input input-bordered w-full h-11 rounded-lg bg-base-100 text-sm focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                </div>
                <div class="form-control py-2 sm:py-0">
                  <label class="label p-0 mb-1.5">
                    <span class="text-sm font-semibold">Nomor WhatsApp <span class="text-error">*</span></span>
                  </label>
                  <input type="tel" id="wa" name="wa" placeholder="Contoh: 0812-3456-7890" required
                    class="input input-bordered w-full h-11 rounded-lg bg-base-100 text-sm focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                </div>
              </div>

              {/* ===== Row 2: Email & Jenis Produk ===== */}
              <div class="grid gap-0 p-5 sm:grid-cols-2 sm:gap-5 sm:p-6">
                <div class="form-control py-2 sm:py-0">
                  <label class="label p-0 mb-1.5">
                    <span class="text-sm font-semibold">Email</span>
                  </label>
                  <input type="email" id="email" name="email" placeholder="contoh@email.com"
                    class="input input-bordered w-full h-11 rounded-lg bg-base-100 text-sm focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" />
                </div>
                <div class="form-control py-2 sm:py-0">
                  <label class="label p-0 mb-1.5">
                    <span class="text-sm font-semibold">Jenis Produk <span class="text-error">*</span></span>
                  </label>
                  <select id="produk" name="produk" required
                    class="select select-bordered w-full h-11 rounded-lg bg-base-100 text-sm focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
                    <option value="" disabled selected>Pilih jenis produk</option>
                    <option value="Skincare">Skincare</option>
                    <option value="Bodycare">Bodycare</option>
                    <option value="Haircare">Haircare</option>
                    <option value="Parfum">Parfum / Fragrance</option>
                    <option value="Makeup">Makeup / Kosmetik</option>
                    <option value="Baby Care">Baby Care</option>
                    <option value="Lainnya">Lainnya</option>
                  </select>
                </div>
              </div>

              {/* ===== Row 3: Estimasi Produksi & Kategori Bisnis ===== */}
              <div class="grid gap-0 p-5 sm:grid-cols-2 sm:gap-5 sm:p-6">
                <div class="form-control py-2 sm:py-0">
                  <label class="label p-0 mb-1.5">
                    <span class="text-sm font-semibold">Estimasi Jumlah Produksi</span>
                  </label>
                  <select id="estimasi" name="estimasi"
                    class="select select-bordered w-full h-11 rounded-lg bg-base-100 text-sm focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
                    <option value="" disabled selected>Pilih estimasi jumlah produksi</option>
                    <option value="500-1000 pcs">500 – 1.000 pcs</option>
                    <option value="1000-5000 pcs">1.000 – 5.000 pcs</option>
                    <option value="5000-10000 pcs">5.000 – 10.000 pcs</option>
                    <option value="10000+ pcs">10.000+ pcs</option>
                    <option value="Belum tahu">Belum tahu</option>
                  </select>
                </div>
                <div class="form-control py-2 sm:py-0">
                  <label class="label p-0 mb-1.5">
                    <span class="text-sm font-semibold">Kategori Bisnis</span>
                  </label>
                  <select id="kategori" name="kategori"
                    class="select select-bordered w-full h-11 rounded-lg bg-base-100 text-sm focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
                    <option value="" disabled selected>Pilih kategori bisnis</option>
                    <option value="Brand Baru">Brand Baru (Startup)</option>
                    <option value="Brand Existing">Brand Sudah Berjalan</option>
                    <option value="Reseller">Reseller / Dropshipper</option>
                    <option value="Klinik">Klinik Kecantikan</option>
                    <option value="Personal">Personal / Perorangan</option>
                    <option value="Lainnya">Lainnya</option>
                  </select>
                </div>
              </div>

              {/* ===== Row 4: Pesan Tambahan ===== */}
              <div class="p-5 sm:p-6 bg-base-200/30">
                <div class="form-control">
                  <label class="label p-0 mb-1.5">
                    <span class="text-sm font-bold">Pesan Tambahan</span>
                    <span class="text-[11px] font-normal text-base-content/35">Opsional</span>
                  </label>
                  <textarea
                    id="pesan" name="pesan"
                    class="textarea textarea-bordered w-full min-h-24 rounded-lg bg-base-100 p-4 text-sm leading-relaxed placeholder:text-base-content/30 focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all resize-y"
                    placeholder="Ceritakan tentang ide produk Anda..."
                  ></textarea>
                  <div class="mt-1.5 flex items-center justify-between">
                    <p class="text-[11px] text-base-content/35 flex items-center gap-1">
                      <Icon name="lucide:info" size={12} />
                      Semakin detail, semakin cepat kami bisa membantu
                    </p>
                    <p class="text-[11px] text-base-content/30" id="char-count">0 / 500 karakter</p>
                  </div>
                </div>
              </div>

              {/* ===== Row 5: Submit ===== */}
              <div class="p-5 sm:p-6">
                <button type="submit"
                  class="btn btn-primary btn-lg w-full h-12 min-h-12 rounded-lg text-base font-bold text-white shadow-md shadow-primary/15 transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5">
                  <Icon name="mdi:whatsapp" size={18} />
                  Kirim via WhatsApp
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. MAP INTERAKTIF + LOKASI (MEWAH)                                -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-b from-base-200/40 to-base-100 py-16 lg:py-24">
      <!-- Decorative blobs -->
      <div class="pointer-events-none absolute -left-40 top-20 h-[500px] w-[500px] rounded-full bg-primary/[0.04] blur-[80px]"></div>
      <div class="pointer-events-none absolute -right-40 bottom-0 h-[400px] w-[400px] rounded-full bg-secondary/[0.03] blur-[80px]"></div>

      <div class="relative mx-auto max-w-6xl px-4 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto max-w-xl text-center mb-10">
          <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs font-semibold tracking-wider">LOKASI KAMI</span>
          <h2 class="text-3xl font-black md:text-4xl lg:text-5xl">Kunjungi Kantor Kami</h2>
          <p class="mt-3 text-base text-base-content/55 md:text-lg">
            Berlokasi strategis di <span class="font-semibold text-primary">Jakarta Pusat</span>. Silakan datang langsung atau hubungi kami untuk janji temu.
          </p>
        </div>

        <!-- Map card — premium glassmorphism -->
        <div class="card overflow-hidden border border-base-200/60 bg-base-100/80 backdrop-blur-sm shadow-xl transition-all duration-500 hover:shadow-2xl">
          <div class="card-body p-0">
            <div class="grid lg:grid-cols-5">
              <!-- LEFT: Info panel -->
              <div class="lg:col-span-2 flex flex-col justify-between bg-gradient-to-br from-base-200/60 via-base-100 to-base-200/40 p-6 md:p-8 border-b lg:border-b-0 lg:border-r border-base-200/60">
                <div>
                  <!-- Logo / Icon -->
                  <div class="mb-6 flex items-center gap-3">
                    <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
                      <Icon name="lucide:building-2" size={24} class="text-primary" />
                    </div>
                    <div>
                      <p class="text-xs font-semibold tracking-wider text-primary uppercase">Aquila Maklon</p>
                      <p class="text-[11px] text-base-content/50">Kantor Pusat</p>
                    </div>
                  </div>

                  <!-- Address info -->
                  <div class="space-y-5">
                    <div class="flex gap-3">
                      <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                        <Icon name="lucide:map-pin" size={16} class="text-primary" />
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-0.5">Alamat</p>
                        <p class="text-sm font-bold leading-relaxed">{siteConfig.address}</p>
                      </div>
                    </div>

                    <div class="flex gap-3">
                      <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-green-100">
                        <Icon name="mdi:whatsapp" size={16} class="text-green-600" />
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-0.5">WhatsApp</p>
                        <p class="text-sm font-bold">{siteConfig.waNumber}</p>
                      </div>
                    </div>

                    <div class="flex gap-3">
                      <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-blue-100">
                        <Icon name="lucide:mail" size={16} class="text-blue-600" />
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-0.5">Email</p>
                        <p class="text-sm font-bold">{siteConfig.email}</p>
                      </div>
                    </div>

                    <div class="flex gap-3">
                      <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-amber-100">
                        <Icon name="lucide:clock" size={16} class="text-amber-600" />
                      </div>
                      <div>
                        <p class="text-xs font-semibold text-base-content/50 uppercase tracking-wider mb-0.5">Jam Operasional</p>
                        <p class="text-sm font-bold">{siteConfig.operationalHours}</p>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Action buttons -->
                <div class="mt-8 space-y-3">
                  <a
                    href="https://maps.google.com/?q=Jl.+Industri+Raya+No.+45+Jakarta+Pusat"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-primary btn-sm w-full rounded-xl text-white gap-2 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
                  >
                    <Icon name="lucide:external-link" size={16} />
                    Buka di Google Maps
                  </a>
                  <a
                    href={waLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-soft btn-sm w-full rounded-xl gap-2 transition-all duration-300 hover:-translate-y-0.5"
                  >
                    <Icon name="mdi:whatsapp" size={16} />
                    Buat Janji Temu
                  </a>
                </div>
              </div>

              <!-- RIGHT: Interactive Google Map -->
              <div class="lg:col-span-3 relative min-h-[300px] lg:min-h-[500px]">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.598457548407!2d106.82654237480395!3d-6.184877693800212!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69f43d20d35917%3A0x909b6a19419db25!2sMonas%2C%20Jakarta%20Pusat!5e0!3m2!1sid!2sid!4v1719705600000"
                  width="100%"
                  height="100%"
                  style="border:0; min-height: 300px;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Lokasi Kantor Aquila Maklon"
                  class="absolute inset-0 h-full w-full"
                ></iframe>
                <!-- Map overlay gradient for premium feel -->
                <div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-base-content/[0.04]"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick info cards below map -->
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="flex items-center gap-3 rounded-2xl border border-base-200/60 bg-base-100/60 backdrop-blur-sm px-4 py-3.5 transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-green-100">
              <Icon name="lucide:car" size={18} class="text-green-600" />
            </div>
            <div>
              <p class="text-[10px] font-semibold text-base-content/40 uppercase tracking-wider">Akses Mudah</p>
              <p class="text-xs font-bold">Parkir Luas & Gratis</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-2xl border border-base-200/60 bg-base-100/60 backdrop-blur-sm px-4 py-3.5 transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-blue-100">
              <Icon name="lucide:train" size={18} class="text-blue-600" />
            </div>
            <div>
              <p class="text-[10px] font-semibold text-base-content/40 uppercase tracking-wider">Transportasi</p>
              <p class="text-xs font-bold">Dekat Stasiun KAI</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-2xl border border-base-200/60 bg-base-100/60 backdrop-blur-sm px-4 py-3.5 transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-purple-100">
              <Icon name="lucide:coffee" size={18} class="text-purple-600" />
            </div>
            <div>
              <p class="text-[10px] font-semibold text-base-content/40 uppercase tracking-wider">Area Sekitar</p>
              <p class="text-xs font-bold">Dekat Pusat Kuliner</p>
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-2xl border border-base-200/60 bg-base-100/60 backdrop-blur-sm px-4 py-3.5 transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-amber-100">
              <Icon name="lucide:shield-check" size={18} class="text-amber-600" />
            </div>
            <div>
              <p class="text-[10px] font-semibold text-base-content/40 uppercase tracking-wider">Keamanan</p>
              <p class="text-xs font-bold">Area 24 Jam Security</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. CTA BANNER                                                     -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-secondary"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image:radial-gradient(circle at 50% 50%, white 1px, transparent 1px);background-size:50px 50px"></div>

      <div class="relative mx-auto max-w-5xl px-4 text-center lg:px-8">
        <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm animate-bounce">
          <Icon name="lucide:handshake" size={48} class="text-white" />
        </div>

        <h2 class="text-4xl font-black text-white md:text-5xl lg:text-6xl leading-tight">
          Siap Bangun Brand Impian Anda?
        </h2>
        <p class="mx-auto mt-6 max-w-3xl text-lg text-white/75 md:text-xl leading-relaxed">
          Hubungi kami untuk konsultasi gratis dan mulai perjalanan brand Anda bersama Aquila Maklon. Tim kami siap mendampingi dari awal hingga produk siap jual!
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={waLink} target="_blank" rel="noopener noreferrer"
            class="btn btn-lg h-14 min-h-14 rounded-xl border-2 border-white bg-white px-10 text-base text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl">
            <Icon name="mdi:whatsapp" size={20} />
            Konsultasi via WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<!-- ==================================================================== -->
<!-- Client-side: form submission + character counter                      -->
<!-- ==================================================================== -->
<script>
  import { createConsultationMessage, createWhatsappLink } from "../lib/whatsapp";

  document.addEventListener('DOMContentLoaded', function () {
    // --- Character counter for textarea ---
    const pesanTextarea = document.getElementById('pesan');
    const charCount = document.getElementById('char-count');

    if (pesanTextarea && charCount) {
      pesanTextarea.addEventListener('input', function () {
        const len = (pesanTextarea as HTMLTextAreaElement).value.length;
        charCount.textContent = `${len} / 500 karakter`;
        if (len > 450) {
          charCount.style.color = '#c76b6b';
        } else {
          charCount.style.color = '';
        }
      });
    }

    // --- Form submission ---
    const form = document.getElementById('consultForm');
    if (!form) return;
    const waNumber = form.getAttribute('data-wa-number');
    if (!waNumber) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const getValue = (id: string) => {
        const field = document.getElementById(id);
        return field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement ? field.value : '';
      };
      const nama = getValue('nama');
      const wa = getValue('wa');
      const email = getValue('email');
      const produk = getValue('produk');
      const estimasi = getValue('estimasi');
      const kategori = getValue('kategori');
      const pesan = getValue('pesan');

      const message = createConsultationMessage({ nama, wa, email, produk, estimasi, kategori, pesan });
      window.open(createWhatsappLink(waNumber, message), '_blank', 'noopener,noreferrer');
    });
  });
</script>
