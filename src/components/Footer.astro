---
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { navItems } from "../data/nav";

const waLink = createWhatsappLink(
  siteConfig.waNumber,
  siteConfig.waText
);

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-base-300 bg-base-200/50">
  <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
    <div class="grid gap-8 md:grid-cols-4">
      <!-- Brand Premium -->
      <div class="md:col-span-1">
        <a href="/" class="group flex items-center gap-3 transition-all duration-500 hover:opacity-85">
          <div class="relative flex h-10 w-10 items-center justify-center">
            <div class="absolute inset-0 rounded-xl bg-primary opacity-15 blur-md transition-all duration-500 group-hover:opacity-30"></div>
            <div class="relative flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-primary via-primary/90 to-primary/80 shadow-md ring-1 ring-white/30">
              <svg class="h-5 w-5 text-white drop-shadow-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
          </div>
          <div class="leading-tight">
            <p class="text-lg font-extrabold tracking-tight text-primary">
              Aquila<span class="text-primary/70">Maklon</span>
            </p>
          </div>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-primary/50">
          {siteConfig.description}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="mb-4 text-sm font-bold uppercase tracking-wider text-base-content/50">Navigasi</h4>
        <ul class="space-y-2">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-base-content/60 transition-colors hover:text-primary">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="mb-4 text-sm font-bold uppercase tracking-wider text-base-content/50">Kontak</h4>
        <ul class="space-y-3 text-sm text-base-content/60">
          <li>
            <a href={waLink} target="_blank" class="transition-colors hover:text-primary">
              WhatsApp: {siteConfig.waNumber}
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="transition-colors hover:text-primary">
              {siteConfig.email}
            </a>
          </li>
          <li>{siteConfig.address}</li>
          <li>{siteConfig.operationalHours}</li>
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h4 class="mb-4 text-sm font-bold uppercase tracking-wider text-base-content/50">Mulai Sekarang</h4>
        <p class="mb-4 text-sm text-base-content/60">
          Konsultasikan ide produk Anda secara gratis. Tim kami siap membantu.
        </p>
        <a
          href={waLink}
          target="_blank"
          class="btn btn-primary bg-primary border-primary rounded-full px-6 text-white shadow-md hover:brightness-110"
        >
          Konsultasi Gratis
        </a>
      </div>
    </div>

    <div class="mt-10 border-t border-base-300 pt-6 text-center text-sm text-base-content/40">
      &copy; {currentYear} {siteConfig.name}. All rights reserved.
    </div>
  </div>
</footer>