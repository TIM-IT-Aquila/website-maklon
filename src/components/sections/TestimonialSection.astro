---
import SectionHeader from "../ui/SectionHeader.astro";
import { testimonials } from "../../data/testimonials";

const testimonialGridClass =
  testimonials.length === 1
    ? "mx-auto max-w-xl grid-cols-1"
    : testimonials.length === 2
      ? "mx-auto max-w-4xl grid-cols-1 md:grid-cols-2"
      : testimonials.length === 3
        ? "grid-cols-1 md:grid-cols-3"
        : "grid-cols-1 sm:grid-cols-2 xl:grid-cols-4";
---

<section id="testimonial" class="bg-base-200/50 py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <SectionHeader
      label="Testimonial"
      variant="minimal"
      title="Apa Kata Brand Partner Kami?"
    />

    <div class:list={["mt-8 grid gap-5", testimonialGridClass]}>
      {testimonials.map((item) => (
        <div class="card h-full border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="card-body h-full p-6">
            <!-- Text -->
            <p class="text-sm italic leading-relaxed text-base-content/70">
              "{item.text}"
            </p>
            <!-- Divider -->
            <div class="mt-auto border-t border-base-200 pt-4">
              <div class="flex items-center gap-3">
                {item.avatar ? (
                  <img src={item.avatar} alt={item.name} class="h-10 w-10 rounded-full object-cover" />
                ) : (
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">
                    {item.name.charAt(0)}
                  </div>
                )}
                <div>
                  <p class="text-sm font-semibold">{item.name}</p>
                  <p class="text-xs text-primary">{item.brand}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
