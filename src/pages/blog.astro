---
import MainLayout from "../layouts/MainLayout.astro";
import { blogPosts } from "../data/blog";
import Icon from "../components/ui/Icon.astro";
---

<MainLayout
  title="Blog | Magna"
  description="Baca artikel dan panduan seputar bisnis maklon skincare, tips branding, dan tren terkini."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. GRID 2 KOLOM — Foto lebar kotak-kotak                           -->
    <!-- ================================================================== -->
    <section class="mx-auto max-w-7xl px-4 pt-8 pb-14 lg:px-8 lg:pt-14 lg:pb-20">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:gap-8">
        {blogPosts.map((post, i) => {
          // Variasi tinggi gambar besar & sedang, kotak semua
          const heights = ["h-64", "h-80", "h-60", "h-96", "h-72", "h-56", "h-80", "h-64"];
          const imgH = heights[i % heights.length];

          return (
            <div class="blog-card">
              {/* ── Foto — lebar, rounded, kotak ── */}
              <a href={"/blog/" + post.slug} class="group block overflow-hidden rounded-2xl shadow-md transition-all duration-400 hover:shadow-xl hover:shadow-primary/10 hover:-translate-y-1">
                <figure class={imgH + " w-full overflow-hidden rounded-2xl"}>
                  <img
                    src={post.image}
                    alt={post.title}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                </figure>
              </a>

              {/* ── Teks / Deskripsi DI LUAR card ── */}
              <div class="mt-4 px-1">
                {/* Date & read time */}
                <div class="flex items-center gap-2 text-[11px] text-base-content/40">
                  <Icon name="lucide:calendar" size={12} />
                  <span>{post.date}</span>
                  <span>·</span>
                  <Icon name="lucide:clock" size={12} />
                  <span>{post.readTime}</span>
                </div>

                {/* Title */}
                <h3 class="mt-1.5 text-base font-bold leading-snug transition-colors duration-300 hover:text-primary lg:text-lg">
                  <a href={"/blog/" + post.slug}>
                    {post.title}
                  </a>
                </h3>

                {/* Short description */}
                <p class="mt-1.5 text-sm leading-relaxed text-base-content/55 line-clamp-2">
                  {post.excerpt}
                </p>

                {/* Read more */}
                <a href={"/blog/" + post.slug} class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-primary transition-all duration-300 hover:gap-2">
                  Baca Selengkapnya
                  <Icon name="lucide:arrow-right" size={13} />
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </main>
</MainLayout>

<script>
  // IntersectionObserver  staggered reveal on scroll
  const observerOptions = { threshold: 0.1, rootMargin: "0px 0px -30px 0px" };

  const reveal = (entries, obs) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target;
        const allCards = document.querySelectorAll(".blog-card");
        const realIdx = Array.from(allCards).indexOf(el);
        el.style.transition = "all 0.5s cubic-bezier(0.16, 1, 0.3, 1) " + (realIdx * 0.06) + "s";
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
        obs.unobserve(el);
      }
    });
  };

  const observer = new IntersectionObserver(reveal, observerOptions);
  document.querySelectorAll(".blog-card").forEach(el => {
    el.style.opacity = "0";
    el.style.transform = "translateY(20px)";
    observer.observe(el);
  });
</script>
