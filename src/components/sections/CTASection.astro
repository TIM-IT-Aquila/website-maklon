---
import WAButton from "../ui/WAButton.astro";

interface Props {
  title?: string;
  buttonText?: string;
  waMessage?: string;
  showCompanyProfile?: boolean;
}

const {
  title = "Saatnya Wujudkan Brand Impian Anda",
  buttonText = "Konsultasi via WhatsApp",
  waMessage,
  showCompanyProfile = true,
} = Astro.props;
---

<section class="relative overflow-hidden py-16 md:py-20">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/90 via-primary to-primary/80"></div>
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <div class="relative mx-auto max-w-3xl px-4 text-center lg:px-8">
    <h2 class="text-4xl font-black text-white md:text-5xl lg:text-6xl">
      {title}
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-white/55 md:text-lg">
      Mulai dari <span class="font-semibold text-white/80">konsultasi gratis</span> — kami siap bantu
      dari nol sampai produk jadi.
    </p>

    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <WAButton
        text={buttonText}
        message={waMessage}
        variant="white"
        size="lg"
        class="rounded-xl shadow-2xl shadow-black/20"
      />
      {
        showCompanyProfile && (
          <a
            href="/company-profile.pdf"
            target="_blank"
            class="inline-flex h-14 items-center gap-2.5 rounded-xl border-2 border-white/20 bg-white/5 px-8 text-base font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/35 hover:bg-white/10"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <>
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </>
            </svg>
            Download Company Profile
          </a>
        )
      }
    </div>
  </div>
</section>
