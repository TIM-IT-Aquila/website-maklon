---
import SectionHeader from "../ui/SectionHeader.astro";
import ProductCard from "../cards/ProductCard.astro";
import { products } from "../../data/products";
---

<section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
  <SectionHeader
    tag="Produk Maklon"
    title="Produk yang Bisa Dibuat"
    description="Berbagai produk skincare, bodycare, haircare, dan kosmetik siap diproduksi untuk brand Anda."
  />

  <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {products.slice(0, 6).map((product) => (
      <ProductCard product={product} />
    ))}
  </div>

  <div class="mt-10 text-center">
    <a href="/produk-maklon" class="btn btn-soft rounded-full px-8">
      Lihat Produk Maklon
    </a>
  </div>
</section>