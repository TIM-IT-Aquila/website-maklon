---
import Container from "../components/ui/Container.astro";
import Icon from "../components/ui/Icon.astro";
import ModalShell from "../components/ui/ModalShell.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { siteConfig } from "../data/site";
import { products } from "../data/products";
import { createWhatsappLink } from "../lib/whatsapp";
import MainLayout from "../layouts/MainLayout.astro";

const categories = [...new Set(products.map((p) => p.category))];
const defaultWaLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
---

<MainLayout
  title="Produk Maklon | Magna"
  description="Berbagai produk skincare, bodycare, dan haircare yang bisa dibuat melalui jasa maklon Magna."
>
  <main class="overflow-hidden">
    <section id="products-catalog" class="overflow-hidden bg-base-100" data-products-section>
      <div class="pt-20 pb-14 lg:pt-24 lg:pb-16">
        <Container>
          <SectionHeader label="Produk">
            <span slot="title">Produk yang Bisa <span class="text-primary">Kami Buat</span></span>
          </SectionHeader>

          <div class="reveal-up mt-8 flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap gap-2" data-product-filters>
              <button
                type="button"
                class="btn btn-sm btn-primary rounded-full"
                data-product-filter="all">Semua</button
              >
              {
                categories.map((cat) => (
                  <button
                    type="button"
                    class="btn btn-sm btn-ghost rounded-full border border-base-200"
                    data-product-filter={cat}
                  >
                    {cat}
                  </button>
                ))
              }
            </div>
            <span class="text-sm text-base-content/50">
              <span class="font-bold text-base-content" data-product-count>{products.length}</span> produk
            </span>
          </div>

          <div
            class="mt-8 grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
            data-product-grid
          >
            {
              products.map((p) => (
                <button
                  type="button"
                  class="reveal-up group overflow-hidden rounded-2xl border border-base-200 bg-white text-left shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-md"
                  data-product-card={p.id}
                  data-product-category={p.category}
                >
                  <figure class="relative h-56 overflow-hidden sm:h-64">
                    <img
                      src={p.image}
                      alt={p.name}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                    <span class="badge badge-sm absolute left-3 top-3 border-0 bg-white/90 text-primary shadow-sm">
                      {p.category}
                    </span>
                  </figure>
                  <div class="p-4">
                    <h3 class="text-sm font-bold text-base-content">{p.name}</h3>
                    <p class="mt-1 line-clamp-2 text-xs text-base-content/50">{p.desc}</p>
                    <span class="mt-2 inline-flex items-center gap-1 text-[11px] font-semibold text-primary opacity-0 transition-opacity group-hover:opacity-100">
                      Lihat detail
                      <Icon name="lucide:arrow-right" size={12} />
                    </span>
                  </div>
                </button>
              ))
            }
          </div>
        </Container>
      </div>

      <ModalShell boxClass="border border-base-200" data-product-modal>
          <div class="rounded-t-3xl bg-gradient-to-br from-primary/10 via-white to-base-200/30 p-6">
            <div class="flex items-start justify-between gap-3">
              <div>
                <span class="badge badge-primary badge-outline badge-xs" data-product-modal-category
                ></span>
                <h3 class="mt-1 text-lg font-black text-base-content" data-product-modal-title></h3>
              </div>
              <form method="dialog">
                <button type="submit" class="btn btn-sm btn-circle btn-ghost" aria-label="Tutup">
                  <Icon name="lucide:x" size={16} />
                </button>
              </form>
            </div>
          </div>
          <div class="space-y-4 p-6">
            <p class="text-sm leading-relaxed text-base-content/65" data-product-modal-desc></p>
            <a
              href={defaultWaLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-soft btn-primary btn-block rounded-xl"
              data-product-modal-wa
            >
              <Icon name="lucide:message-circle" size={16} />
              Konsultasi Maklon Produk Ini
            </a>
          </div>
      </ModalShell>
    </section>
  </main>
</MainLayout>

<script>
  import { products } from "../data/products";
  import { createWhatsappLink } from "../lib/whatsapp";
  import { observeReveal } from "../scripts/reveal";
  import { siteConfig } from "../data/site";

  function initProductsCatalog() {
    const root = document.querySelector<HTMLElement>("[data-products-section]");
    if (!root) return;

    const modal = root.querySelector<HTMLDialogElement>("[data-product-modal]");
    const modalTitle = root.querySelector<HTMLElement>("[data-product-modal-title]");
    const modalCategory = root.querySelector<HTMLElement>("[data-product-modal-category]");
    const modalDesc = root.querySelector<HTMLElement>("[data-product-modal-desc]");
    const modalWa = root.querySelector<HTMLAnchorElement>("[data-product-modal-wa]");
    const countEl = root.querySelector<HTMLElement>("[data-product-count]");
    const filterBtns = root.querySelectorAll<HTMLButtonElement>("[data-product-filter]");
    const cards = root.querySelectorAll<HTMLElement>("[data-product-card]");

    function openModal(id: string) {
      const product = products.find((p) => p.id === id);
      if (!product || !modal || !modalTitle || !modalDesc) return;
      modalTitle.textContent = product.name;
      if (modalCategory) modalCategory.textContent = product.category;
      modalDesc.textContent = product.detail;
      if (modalWa) {
        modalWa.href = createWhatsappLink(
          siteConfig.waNumber,
          `Halo, saya ingin konsultasi maklon untuk produk ${product.name} (${product.category}).`,
        );
      }
      modal.showModal();
    }

    cards.forEach((card) => {
      card.addEventListener("click", () => openModal(card.dataset.productCard ?? ""));
    });

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.productFilter ?? "all";
        filterBtns.forEach((b) => {
          const active = b === btn;
          b.classList.toggle("btn-primary", active);
          b.classList.toggle("btn-ghost", !active);
          b.classList.toggle("border", !active);
          b.classList.toggle("border-base-200", !active);
        });
        let visible = 0;
        cards.forEach((card) => {
          const show = cat === "all" || card.dataset.productCategory === cat;
          card.classList.toggle("hidden", !show);
          if (show) visible++;
        });
        if (countEl) countEl.textContent = String(visible);
      });
    });

    const initialCategory = new URLSearchParams(window.location.search).get("category");
    filterBtns.find((btn) => btn.dataset.productFilter === initialCategory)?.click();

    observeReveal(root.querySelectorAll<HTMLElement>(".reveal-up"), {
      duration: 500,
      easing: "ease",
      threshold: 0.1,
      translateY: "16px",
    });
  }

  initProductsCatalog();
  document.addEventListener("astro:page-load", initProductsCatalog);
</script>
