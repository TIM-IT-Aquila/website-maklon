---
import Icon from "../ui/Icon.astro";

interface Feature {
  icon?: string;
  title: string;
  desc: string;
  image?: string;
}

interface Props {
  feature: Feature;
}

const { feature } = Astro.props;
---

<div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20 overflow-hidden">
  {feature.image && (
    <figure class="h-40 overflow-hidden">
      <img
        src={feature.image}
        alt={feature.title}
        class="h-full w-full object-cover transition-transform duration-500 hover:scale-110"
        loading="lazy"
      />
    </figure>
  )}
  <div class="card-body items-center text-center">
    {feature.icon && !feature.image && (
      <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-3xl text-primary">
        <Icon name={feature.icon} size={32} />
      </div>
    )}
    <h3 class="card-title mt-2">{feature.title}</h3>
    <p class="text-base-content/70">{feature.desc}</p>
  </div>
</div>