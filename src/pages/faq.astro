---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { faqs } from "../data/faqs";
---

<MainLayout
  title="FAQ | Magna"
  description="Pertanyaan yang sering diajukan seputar layanan maklon skincare."
>
  <main class="overflow-hidden bg-base-100">
    <section class="pt-20 pb-14 md:pt-24 md:pb-16">
      <div class="mx-auto max-w-3xl px-4 lg:px-8">
        <SectionHeader label="FAQ" variant="minimal">
          <span slot="title">Pertanyaan <span class="text-primary">Umum</span></span>
        </SectionHeader>

        <div class="mt-10 space-y-3">
          {
            faqs.map((faq, i) => (
              <details
                class="group rounded-2xl border border-base-200/70 bg-white shadow-sm transition-all duration-300 open:border-primary/15 open:shadow-md [&_summary::-webkit-details-marker]:hidden"
                open={i === 0}
              >
                <summary class="flex cursor-pointer items-center gap-3 px-5 py-4 list-none">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-xs font-bold text-primary">
                    {i + 1}
                  </span>
                  <span class="flex-1 text-sm font-bold text-base-content/80">{faq.q}</span>
                  <Icon
                    name="lucide:chevron-down"
                    size={16}
                    class="shrink-0 text-base-content/25 transition-transform duration-300 group-open:rotate-180"
                  />
                </summary>
                <p class="px-5 pb-5 pl-14 text-sm leading-relaxed text-base-content/55">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</MainLayout>
