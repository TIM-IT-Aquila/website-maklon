---
import Icon from "../ui/Icon.astro";

interface Service {
  title: string;
  desc: string;
  examples: string;
  icon?: string;
  image?: string;
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<div
  class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20 overflow-hidden"
>
  {
    service.image && (
      <figure class="h-48 overflow-hidden">
        <img
          src={service.image}
          alt={service.title}
          class="h-full w-full object-cover transition-transform duration-500 hover:scale-110"
          loading="lazy"
        />
      </figure>
    )
  }
  <div class="card-body">
    {
      service.icon && !service.image && (
        <div class="mb-2 flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-2xl">
          <Icon name={service.icon} size={28} />
        </div>
      )
    }
    <h3 class="card-title text-xl">{service.title}</h3>
    <p class="text-base-content/70">{service.desc}</p>
    {
      service.examples && (
        <div class="mt-3 rounded-xl bg-base-200/50 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">Contoh produk:</p>
          <p class="mt-1 text-sm text-base-content/60">{service.examples}</p>
        </div>
      )
    }
  </div>
</div>
