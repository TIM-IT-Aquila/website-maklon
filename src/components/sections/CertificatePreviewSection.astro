---
import SectionHeader from "../ui/SectionHeader.astro";
import { trustBadges } from "../../data/site";
---

<section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
  <SectionHeader
    label="Sertifikasi"
    variant="minimal"
    title="Legalitas & Sertifikasi"
  />

  <div class="mt-8 grid gap-5 sm:grid-cols-2 md:grid-cols-4">
    {trustBadges.map((badge) => (
      <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20">
        <div class="card-body items-center text-center p-6">
          <div class="flex h-16 w-16 items-center justify-center rounded-xl bg-primary/10 text-2xl font-black text-primary">
            {badge.label}
          </div>
          <p class="mt-3 text-sm text-base-content/70">{badge.desc}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="mt-4 text-center">
    <p class="text-sm text-base-content/60">
      Kami membantu pengurusan BPOM, Halal, CPKB, ISO, dan HKI untuk produk Anda.
    </p>
  </div>

  <div class="mt-3 text-center">
    <a href="/certification" class="btn btn-soft rounded-full px-8">
      Lihat Sertifikasi
    </a>
  </div>
</section>