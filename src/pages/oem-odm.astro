---
import Container from "../components/ui/Container.astro";
import FAQItem from "../components/ui/FAQItem.astro";
import Icon from "../components/ui/Icon.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import WAButton from "../components/ui/WAButton.astro";
import { oemOdmHero } from "../data/oem-odm";
import {
  materialConcepts,
  odmServiceOptions,
  oemOdmFaqs,
} from "../data/oem-odm-page";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="OEM / ODM | Magna"
  description="Konsultasi layanan OEM dan ODM skincare bersama Magna melalui WhatsApp."
>
  <main class="overflow-hidden">
    <PageHero
      image={oemOdmHero.image}
      alt={oemOdmHero.alt}
      titleMain="Magna Manufacture menyediakan layanan OEM & ODM yang fleksibel"
      titleAccent=""
      class="oem-hero"
    >
      <p slot="description" class="mt-3 max-w-xl text-sm leading-relaxed text-white/70 md:text-base">
        Kami membantu setiap tahapan, mulai dari pengembangan produk, pengadaan bahan baku, desain
        kemasan, registrasi BPOM, sertifikasi Halal, hingga proses produksi.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <WAButton
          text="Konsultasi via WhatsApp"
          message="Halo, saya ingin konsultasi layanan OEM/ODM untuk brand skincare saya."
          variant="white"
          size="md"
        />
        <a href="#layanan" class="inline-flex h-11 items-center justify-center rounded-xl border border-white/25 px-5 text-xs font-bold text-white transition hover:bg-white/10">
          Lihat layanan
        </a>
      </div>
    </PageHero>

    <section class="bg-base-100 py-12 md:py-16">
      <Container>
        <SectionHeader label="OEM-ODM" title="OEM & ODM untuk brand Anda." />
        <div class="mt-8 grid gap-5 lg:grid-cols-2">
          <article class="rounded-3xl border border-primary bg-primary p-6 md:p-8">
            <p class="text-xs font-bold tracking-[0.18em] text-white/65 uppercase">OEM</p>
            <h2 class="mt-2 text-2xl font-black text-white">Produk sesuai formula Anda.</h2>
            <ul class="mt-6 space-y-3">
              {
                [
                  "Produksi berdasarkan formula atau konsep yang dimiliki pelanggan.",
                  "Cocok untuk brand yang sudah memiliki formula sendiri.",
                  "Fleksibilitas tinggi.",
                ].map((point) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-white/85 md:text-base">
                    <Icon name="lucide:check" size={18} class="mt-0.5 shrink-0 text-white" />
                    {point}
                  </li>
                ))
              }
            </ul>
          </article>
          <article class="rounded-3xl border border-primary bg-primary p-6 md:p-8">
            <p class="text-xs font-bold tracking-[0.18em] text-white/65 uppercase">ODM</p>
            <h2 class="mt-2 text-2xl font-black text-white">Produk siap untuk brand Anda.</h2>
            <ul class="mt-6 space-y-3">
              {
                [
                  "Menyediakan konsep produk yang siap jual sehingga bisa cepat dipasarkan.",
                  "Cocok bagi brand yang ingin memulai dengan lebih cepat menggunakan produk yang telah teruji.",
                  "Proses lebih efisien dengan opsi modifikasi sesuai kebutuhan.",
                ].map((point) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-white/85 md:text-base">
                    <Icon name="lucide:check" size={18} class="mt-0.5 shrink-0 text-white" />
                    {point}
                  </li>
                ))
              }
            </ul>
          </article>
        </div>
      </Container>
    </section>

    <section id="layanan" class="bg-base-100 py-16 md:py-20">
      <Container>
        <SectionHeader label="Pilihan konsep bisnis">
          <span slot="title"><span class="text-primary">ODM</span> untuk memulai lebih cepat.</span>
        </SectionHeader>
        <p class="mx-auto mt-5 max-w-3xl text-center text-sm leading-relaxed text-base-content/60 md:text-base">
          Layanan ODM memungkinkan Anda menggunakan produk yang telah dikembangkan oleh tim R&D
          Aquila Magna. Formula siap diproduksi dan dapat disesuaikan dengan identitas merek Anda.
        </p>
        <p class="mt-10 text-center text-xs font-bold tracking-[0.18em] text-primary uppercase">
          Pilihan layanan
        </p>
        <div class="mx-auto mt-5 grid max-w-6xl gap-4 lg:grid-cols-3">
          {
            odmServiceOptions.map((tier, index) => (
              <details
                class="group rounded-3xl border border-base-200 bg-white shadow-sm transition duration-300 open:border-primary/25 open:shadow-lg"
                open={index === 0}
              >
                <summary class="cursor-pointer list-none p-6 marker:hidden md:p-7">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                      <Icon name={tier.icon} size={21} />
                    </div>
                  </div>
                  <h2 class="mt-6 text-2xl font-black text-base-content">{tier.title}</h2>
                  <p class="mt-3 text-sm leading-relaxed text-base-content/60">{tier.description}</p>
                  <span class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-primary">
                    Lihat detail layanan
                    <Icon name="lucide:chevron-down" size={16} class="transition-transform duration-300 group-open:rotate-180" />
                  </span>
                </summary>
                <div class="border-t border-base-200 px-6 pb-6 pt-5 md:px-7 md:pb-7">
                  <ul class="space-y-3">
                    {
                      tier.highlights.map((highlight) => (
                        <li class="flex gap-2 text-sm leading-relaxed text-base-content/65">
                          <Icon name="lucide:check" size={16} class="mt-0.5 shrink-0 text-primary" />
                          {highlight}
                        </li>
                      ))
                    }
                  </ul>
                  <WAButton
                    text={`Konsultasi ${tier.title}`}
                    message={`Halo, saya ingin konsultasi layanan ${tier.title} untuk brand skincare saya.`}
                    size="sm"
                    class="mt-6 w-full"
                  />
                </div>
              </details>
            ))
          }
        </div>
      </Container>
    </section>

    <section class="bg-primary py-16 md:py-20">
      <Container>
        <div class="grid items-start gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
          <div>
            <SectionHeader align="left" label="Konsep bahan baku" tone="light">
              <span slot="title">Pilih konsep yang <span class="text-white/70">sesuai brand</span>.</span>
            </SectionHeader>
            <p class="mt-5 text-sm leading-relaxed text-white/75 md:text-base">
              Tentukan konsep bahan baku yang selaras dengan karakter produk dan target pasar brand Anda.
            </p>
            <WAButton
              text="Diskusikan konsep bahan baku"
              message="Halo, saya ingin mendiskusikan konsep bahan baku untuk brand skincare saya."
              variant="white"
              size="lg"
              class="mt-7"
            />
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            {
              materialConcepts.map((option, index) => (
                <article class="group rounded-3xl border border-primary/10 bg-white p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-primary/25 hover:shadow-md md:p-6">
                  <span class="text-xs font-bold tracking-widest text-primary/45">0{index + 1}</span>
                  <div class="mt-5 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white">
                    <Icon name={option.icon} size={19} />
                  </div>
                  <h2 class="mt-5 text-lg font-black text-base-content">{option.title}</h2>
                  <p class="mt-3 text-sm leading-relaxed text-base-content/60">{option.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </Container>
    </section>

    <section class="bg-base-200/45 py-16 md:py-20">
      <Container maxWidth="4xl">
        <SectionHeader label="Pertanyaan umum" title="Sebelum memulai, ini yang sering ditanyakan." />
        <div class="mt-10 space-y-3">
          {
            oemOdmFaqs.map((faq, index) => (
              <FAQItem question={faq.q} answer={faq.a} index={index + 1} tone="primary" />
            ))
          }
        </div>
      </Container>
    </section>

  </main>
<style>
  .oem-hero h1 {
    font-size: 0.625rem;
    line-height: 1.2;
    white-space: pre-line;
  }
  @media (min-width: 640px) {
    .oem-hero h1 {
      font-size: 0.75rem;
    }
  }
  @media (min-width: 1024px) {
    .oem-hero h1 {
      font-size: 0.875rem;
    }
  }
</style>

</MainLayout>
