---
import { siteConfig } from "../data/site";
import { navItems } from "../data/nav";
import Icon from "./ui/Icon.astro";
import WAButton from "./ui/WAButton.astro";

const currentPath = Astro.url.pathname;

function isActivePath(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}

function isChildActive(children: { href: string }[] | undefined): boolean {
  if (!children) return false;
  return children.some((child) => currentPath.startsWith(child.href));
}
---

<header class="sticky top-0 z-50 border-b border-base-300/40 bg-white/90 backdrop-blur-2xl transition-all duration-300">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="navbar">
      <!-- ================================================================== -->
      <!-- KIRI: LOGO ICON                                                    -->
      <!-- ================================================================== -->
      <div class="navbar-start">
      <a href="/" class="group flex items-center transition-all duration-500 hover:opacity-90" aria-label="Aquila Magna">
        <img src="/assets/Logo.svg" alt="Aquila Magna" class="h-7 w-auto sm:h-8" />
      </a>
    </div>
    <!-- ================================================================== -->
    <!-- TENGAH: DESKTOP NAV MENU                                           -->
    <!-- ================================================================== -->
    <div class="navbar-center hidden lg:flex">
      <nav class="flex items-center gap-0.5">
        {navItems.map((item) => {
          if (item.children) {
            const hasActiveChild = isChildActive(item.children);
            return (
              <div class="dropdown dropdown-hover relative">
                <a
                  role="button"
                  class={`group relative flex cursor-pointer items-center gap-1 rounded-full px-4 py-2 text-sm font-semibold tracking-wide transition-all duration-300 ${
                    hasActiveChild
                      ? "text-primary"
                      : "text-base-content/70 hover:text-primary"
                  }`}
                >
                  {hasActiveChild && (
                    <span class="absolute inset-0 rounded-full bg-primary/8"></span>
                  )}
                  <span class="relative z-10">{item.label}</span>
                  <Icon
                    name="chevron-down"
                    class={`relative z-10 h-3 w-3 transition-transform duration-300 ${hasActiveChild ? "rotate-180" : ""}`}
                  />
                </a>

                <!-- Dropdown -->
                <ul class="dropdown-content menu-vertical invisible absolute -left-4 top-full mt-2 w-72 gap-0.5 rounded-2xl border border-base-200/80 bg-white p-2 opacity-0 shadow-xl shadow-black/5 transition-all duration-300 [.dropdown:hover_&]:visible [.dropdown:hover_&]:opacity-100">
                  {item.children.map((child) => {
                    const childActive = isActivePath(child.href);
                    return (
                      <li>
                        <a
                          href={child.href}
                          class={`group flex items-start gap-3 rounded-xl px-4 py-3 transition-all duration-200 ${
                            childActive
                              ? "bg-primary/10 text-primary"
                              : "text-base-content/70 hover:bg-primary/5 hover:text-primary"
                          }`}
                        >
                          {child.icon && (
                            <div class={`mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg ${
                              childActive
                                ? "bg-primary/15 text-primary"
                                : "bg-base-200/60 text-base-content/50 group-hover:bg-primary/10 group-hover:text-primary"
                            } transition-all duration-200`}>
                              <Icon name={child.icon} class="h-4 w-4" />
                            </div>
                          )}
                          <div class="flex flex-col items-start">
                            <span class="flex items-center gap-2 text-sm font-semibold transition-colors">
                              {childActive && (
                                <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
                              )}
                              {child.label}
                            </span>
                            {child.description && (
                              <span class="mt-0.5 text-[11px] font-normal leading-snug text-base-content/40 transition-colors group-hover:text-base-content/60">
                                {child.description}
                              </span>
                            )}
                          </div>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            );
          }

          const active = isActivePath(item.href!);
          return (
            <a
              href={item.href}
              class={`group relative rounded-full px-4 py-2 text-sm font-semibold tracking-wide transition-all duration-300 ${
                active
                  ? "text-primary"
                  : "text-base-content/70 hover:text-primary"
              }`}
            >
              {active && (
                <span class="absolute inset-0 rounded-full bg-primary/8"></span>
              )}
              <span class="relative z-10">{item.label}</span>
              {active && (
                <span class="absolute -bottom-px left-1/2 h-0.5 w-5 -translate-x-1/2 rounded-full bg-primary"></span>
              )}
            </a>
          );
        })}
      </nav>
    </div>

    <!-- ================================================================== -->
    <!-- KANAN: DESKTOP CTA + MOBILE HAMBURGER                              -->
    <!-- ================================================================== -->
    <div class="navbar-end flex items-center gap-2">
      <!-- Desktop CTA - hanya tampil di desktop -->
      <div class="hidden lg:block">
        <WAButton
          text="Konsultasi Gratis"
          size="sm"
          variant="primary"
          class="rounded-full"
        />
      </div>

      <!-- Hamburger Mobile -->
      <button id="mobile-menu-btn" class="btn btn-ghost btn-sm lg:hidden" aria-label="Buka menu" type="button">
        <span id="menu-icon-open"><Icon name="lucide:menu" class="h-5 w-5 text-base-content/70" /></span>
        <span id="menu-icon-close" class="hidden"><Icon name="lucide:x" class="h-5 w-5 text-base-content/70" /></span>
      </button>
    </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="mobile-menu-hidden fixed top-16 left-0 z-40 h-[calc(100vh-4rem)] w-full bg-black/40 backdrop-blur-sm lg:hidden" style="display:none;">
    <nav class="h-full overflow-y-auto bg-white shadow-xl">
      <ul class="flex flex-col gap-0.5 px-4 pb-10 pt-4">
        {navItems.map((item) => {
          if (item.children) {
            const hasActiveChild = isChildActive(item.children);
            return (
              <li>
                <details class="mobile-submenu" open={hasActiveChild}>
                  <summary class={`flex cursor-pointer items-center justify-between rounded-xl px-4 py-3 ${hasActiveChild ? "font-semibold text-primary bg-primary/5" : "font-medium text-base-content/80"}`}>
                    <span class="text-sm">{item.label}</span>
                  </summary>
                  <ul class="ml-2 mt-1 rounded-xl bg-base-200/40 p-2">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class={`flex items-start gap-3 rounded-xl px-4 py-2.5 transition-all duration-200 ${isActivePath(child.href) ? "bg-primary/10 font-semibold text-primary" : "text-base-content/70 hover:bg-primary/5 hover:text-primary"}`}
                        >
                          {child.icon && (
                            <div class={`mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg ${
                              isActivePath(child.href)
                                ? "bg-primary/15 text-primary"
                                : "bg-base-200/60 text-base-content/50"
                            } transition-all duration-200`}>
                              <Icon name={child.icon} class="h-3.5 w-3.5" />
                            </div>
                          )}
                          <div>
                            <span class="text-sm font-semibold">{child.label}</span>
                            {child.description && (
                              <span class="mt-0.5 block text-xs font-normal text-base-content/40">{child.description}</span>
                            )}
                          </div>
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            );
          }
          const active = isActivePath(item.href!);
          return (
            <li>
              <a
                href={item.href}
                class={`block rounded-xl px-4 py-3 transition-all duration-200 ${active ? "bg-primary/10 font-semibold text-primary" : "text-base-content/70 hover:bg-primary/5 hover:text-primary"}`}
              >
                <span class="text-sm">{item.label}</span>
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  /* Smooth submenu expand/collapse animation */
  details > ul {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.3s ease;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

  details[open] > ul {
    max-height: 600px;
    opacity: 1;
  }

  /* Style the summary arrow nicely */
  details > summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::after {
    content: '';
    width: 0.5rem;
    height: 0.5rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 0.5rem;
    opacity: 0.4;
  }

  details[open] > summary::after {
    transform: rotate(-135deg);
  }

  /* Mobile menu entrance animation */
  .mobile-menu-hidden {
    transition: opacity 0.3s ease;
  }

  .mobile-menu-visible {
    display: block !important;
    animation: menuFadeIn 0.3s ease forwards;
  }

  @keyframes menuFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (menuBtn && mobileMenu && iconOpen && iconClose) {
    let isOpen = false;

    function openMenu() {
      isOpen = true;
      mobileMenu!.style.display = 'block';
      mobileMenu!.classList.add('mobile-menu-visible');
      iconOpen!.classList.add('hidden');
      iconClose!.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      mobileMenu!.style.display = 'none';
      mobileMenu!.classList.remove('mobile-menu-visible');
      iconOpen!.classList.remove('hidden');
      iconClose!.classList.add('hidden');
      document.body.style.overflow = '';
    }

    menuBtn.addEventListener('click', () => {
      if (isOpen) closeMenu();
      else openMenu();
    });

    // Close on overlay click
    mobileMenu.addEventListener('click', (e) => {
      if (e.target === mobileMenu) closeMenu();
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });

    // Close on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });
  }
</script>
