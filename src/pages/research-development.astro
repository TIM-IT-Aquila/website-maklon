---
import Icon from "../components/ui/Icon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { rdStats, rdPhases, rdFacilities, rdInnovations } from "../data/research-development";
import { factoryImages } from "../data/images";

const waLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi layanan R&D produk.");
const waLongLink = createWhatsappLink(siteConfig.waNumber, "Halo, saya ingin konsultasi dengan tim R&D Aquila Maklon untuk pengembangan produk baru.");
---

<MainLayout
  title="R&D | Aquila Maklon"
  description="Research & Development produk skincare & kosmetik. Tim R&D berpengalaman siap bantu inovasi produk Anda."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. R&D SECTION — Image left, text right, highlights + step tabs      -->
    <!-- ================================================================== -->
    <section id="rd" class="bg-base-100 pt-16 pb-0 lg:pt-24">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">

        {/* ── R&D Header Badge ── */}
        <div class="mb-10 flex flex-col items-center text-center lg:mb-14">
          <div class="inline-flex items-center gap-3 rounded-full border border-primary/20 bg-primary/5 px-5 py-2">
            <Icon name="lucide:flask-conical" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">RESEARCH & DEVELOPMENT</span>
          </div>
          <h1 class="mt-4 text-2xl font-black md:text-3xl lg:text-4xl tracking-tight">
            Inovasi & Riset <span class="text-primary">Produk Skincare</span>
          </h1>
        </div>

        {/* ── R&D Content: Image + Text side by side ── */}
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
          {/* Image — left on desktop */}
          <div class="reveal-left">
            <div class="relative overflow-hidden rounded-2xl shadow-xl lg:rounded-3xl">
              <img src={factoryImages.labResearch} alt="R&D Laboratory" class="h-64 w-full object-cover sm:h-80 lg:h-96" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/30 to-transparent"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-white/20 backdrop-blur-md px-3 py-1 text-xs font-semibold text-white">
                  <span class="h-1.5 w-1.5 rounded-full bg-green-400"></span>
                  Laboratorium R&D
                </span>
              </div>
            </div>
          </div>

          {/* Text — right on desktop */}
          <div class="reveal-right">
            <h3 class="text-xl font-bold text-base-content lg:text-2xl">Formula Inovatif dari Tim Ahli</h3>
            <p class="mt-3 leading-relaxed text-base-content/60">
              Tim R&D kami menciptakan formula inovatif yang aman, efektif, dan sesuai tren pasar — didukung laboratorium modern, tenaga ahli farmasi & kimia, serta database 2000+ bahan baku terkurasi.
            </p>

            {/* Highlights */}
            <div class="mt-6 space-y-3">
              {[
                { icon: "lucide:microscope", text: "Laboratorium riset dengan peralatan analisis terkini — homogenizer, pH meter, viskometer" },
                { icon: "lucide:leaf", text: "Formula bahan aktif alami — Centella, Niacinamide, Ceramide, Peptide teruji klinis" },
                { icon: "lucide:shield-check", text: "Formula bebas 70+ bahan berbahaya — sesuai BPOM & EU Cosmetic Directive" },
                { icon: "lucide:droplets", text: "Teknologi enkapsulasi liposom — perlindungan & penyerapan bahan aktif optimal" },
              ].map((h) => (
                <div class="flex items-start gap-3 rounded-xl border border-base-200 bg-base-200/30 p-3 transition-all duration-300 hover:border-primary/15 hover:bg-primary/[0.03]">
                  <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-primary/10">
                    <Icon name={h.icon} size={15} class="text-primary" />
                  </div>
                  <p class="text-sm leading-relaxed text-base-content/70">{h.text}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* ── R&D Phases — Horizontal interactive tabs with hover popup ── */}
        <div class="mt-14 lg:mt-20 pb-16 lg:pb-24">
          <p class="mb-6 text-center text-sm font-semibold uppercase tracking-[0.2em] text-base-content/40">Tahapan R&D</p>

          {/* Desktop: Horizontal step tabs with hover popup */}
          <div class="hidden lg:block">
            <div class="relative grid grid-cols-6 gap-3">
              {rdPhases.map((s) => (
                <div
                  class="rd-phase-tab group relative flex flex-col items-center gap-3 rounded-2xl border border-base-200 bg-base-100 p-4 text-center transition-all duration-400 hover:border-primary/20 hover:shadow-md hover:-translate-y-1"
                >
                  <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-sm font-black text-primary transition-all duration-400 group-hover:bg-primary group-hover:text-white group-hover:scale-110">
                    {s.step}
                  </div>
                  <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-primary/5 transition-all duration-400 group-hover:bg-primary/15">
                    <Icon name={s.icon} size={16} class="text-primary" />
                  </div>
                  <span class="text-xs font-semibold text-base-content/70 leading-tight">{s.title}</span>

                  {/* ── POPUP ABOVE on hover ── */}
                  <div class="pointer-events-none absolute bottom-full left-1/2 z-[999] mb-3 w-64 -translate-x-1/2 rounded-2xl border-2 border-primary/25 bg-white p-4 opacity-0 shadow-2xl transition-all duration-300 group-hover:opacity-100 group-hover:mb-4">
                    <div class="absolute -bottom-2.5 left-1/2 h-5 w-5 -translate-x-1/2 rotate-45 border-b-2 border-r-2 border-primary/25 bg-white"></div>
                    <p class="text-xs leading-relaxed text-base-content/65">{s.detail}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Mobile: Vertical accordion */}
          <div class="space-y-3 lg:hidden">
            {rdPhases.map((s) => (
              <details class="group rounded-2xl border border-base-200 bg-base-100 shadow-sm transition-all duration-400 open:border-primary/15 open:shadow-md [&_summary::-webkit-details-marker]:hidden">
                <summary class="flex cursor-pointer items-center gap-3 p-4 list-none">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-black text-primary">
                    {s.step}
                  </div>
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/5">
                    <Icon name={s.icon} size={15} class="text-primary" />
                  </div>
                  <span class="text-sm font-semibold text-base-content flex-1">{s.title}</span>
                  <Icon name="lucide:chevron-down" size={16} class="text-base-content/30 transition-transform duration-300 group-open:rotate-180" />
                </summary>
                <div class="px-4 pb-4 pl-[68px]">
                  <p class="text-xs leading-relaxed text-base-content/60">{s.detail}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. STATS — Gradient bar                                            -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary to-emerald-900 py-16">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 50px 50px;"></div>
      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
          {rdStats.map(function(stat) {
            return (
              <div class="stat-card text-center" style="opacity:0;transform:translateY(20px)">
                <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-2xl border border-white/[0.08] bg-white/[0.05] shadow-lg backdrop-blur-sm transition-all duration-500 hover:scale-110 hover:border-white/[0.15]">
                  <span class="text-3xl font-black text-white">{stat.value}</span>
                </div>
                <p class="mt-3 text-sm font-medium text-white/60">{stat.label}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. FASILITAS — Clean grid cards                                    -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/40 py-20 lg:py-28">
      <div class="pointer-events-none absolute -left-60 bottom-0 h-[400px] w-[400px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute -right-40 top-0 h-[350px] w-[350px] rounded-full bg-primary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-base-200/40 px-5 py-2">
            <Icon name="lucide:building-2" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">FASILITAS & TEKNOLOGI</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Laboratorium Modern</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Didukung peralatan riset terkini dan sistem mutu berstandar internasional.
          </p>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {rdFacilities.map(function(facility) {
            return (
              <div class="adv-card group relative overflow-hidden rounded-2xl border border-base-200 bg-base-100 p-6 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 lg:p-7" style="opacity:0;transform:translateY(30px)">
                <div class={`mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br ${facility.color} text-white shadow-lg transition-all duration-500 group-hover:scale-110 group-hover:shadow-xl`}>
                  <Icon name={facility.icon} size={26} />
                </div>
                <h3 class="text-lg font-bold text-base-content transition-colors duration-300 group-hover:text-primary">{facility.title}</h3>
                <p class="mt-2.5 text-sm leading-relaxed text-base-content/55">{facility.detail}</p>
                <div class="mt-5 h-0.5 w-0 rounded-full bg-gradient-to-r from-primary to-primary/60 transition-all duration-700 group-hover:w-20"></div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. INOVASI — Cards with gradient icons                              -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="flex flex-col items-center text-center">
          <div class="inline-flex items-center gap-3 rounded-full border border-base-200 bg-base-200/40 px-5 py-2">
            <Icon name="lucide:lightbulb" size={16} class="text-primary" />
            <span class="text-[11px] font-semibold tracking-[0.25em] text-primary">INOVASI UNGGULAN</span>
          </div>
          <h2 class="mt-5 text-3xl font-black md:text-4xl tracking-tight">Inovasi & Pengembangan</h2>
          <p class="mt-3 max-w-xl text-base-content/55 md:text-lg">
            Kami terus berinovasi menciptakan formula aman, efektif, dan sesuai regulasi terkini.
          </p>
        </div>

        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {rdInnovations.map(function(item) {
            return (
              <div class="adv-card group relative overflow-hidden rounded-2xl border border-base-200 bg-base-100 p-6 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/5 lg:p-7" style="opacity:0;transform:translateY(30px)">
                <div class={`mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br ${item.color} text-white shadow-lg transition-all duration-500 group-hover:scale-110 group-hover:shadow-xl`}>
                  <Icon name={item.icon} size={26} />
                </div>
                <h3 class="text-lg font-bold text-base-content transition-colors duration-300 group-hover:text-primary">{item.title}</h3>
                <p class="mt-2.5 text-sm leading-relaxed text-base-content/55">{item.detail}</p>
                <div class="mt-5 h-0.5 w-0 rounded-full bg-gradient-to-r from-primary to-primary/60 transition-all duration-700 group-hover:w-20"></div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. CTA PREMIUM BANNER                                              -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden py-24">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-emerald-800"></div>
      <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute inset-0 opacity-5" style="background-image:radial-gradient(circle at 50% 50%, white 1px, transparent 1px);background-size:50px 50px"></div>

      <div class="relative mx-auto max-w-7xl px-4 text-center lg:px-8">
        <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full bg-white/10 backdrop-blur-sm">
          <Icon name="lucide:flask-conical" size={36} class="text-white" />
        </div>

        <h2 class="text-3xl font-black text-white md:text-4xl lg:text-5xl leading-tight">
          Kembangkan Produk Bersama Tim R&D Kami
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base text-white/70 md:text-lg leading-relaxed">
          Konsultasikan ide produk Anda. Tim R&D Aquila Maklon siap mewujudkannya dengan formula inovatif, aman, dan sesuai standar regulasi terkini.
        </p>

        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={waLongLink} target="_blank" rel="noopener noreferrer"
            class="btn btn-lg h-14 min-h-14 rounded-xl border-2 border-white bg-white px-10 text-base font-bold text-primary shadow-xl transition-all duration-300 hover:scale-105 hover:shadow-2xl">
            <Icon name="mdi:whatsapp" size={20} />
            Konsultasi R&D
            <Icon name="lucide:arrow-right" size={18} />
          </a>
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<script>
  // ═══════════════════════════════════════════════════════════════════
  // IntersectionObserver — staggered reveal for stats & cards
  // ═══════════════════════════════════════════════════════════════════
  const observerOptions = { threshold: 0.2, rootMargin: "0px 0px -40px 0px" };

  const reveal = (entries: IntersectionObserverEntry[], obs: IntersectionObserver) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const siblings = Array.from(el.parentElement?.children || []);
        const realIdx = siblings.indexOf(el);
        el.style.transition = `all 0.5s cubic-bezier(0.16, 1, 0.3, 1) ${realIdx * 0.08}s`;
        el.style.opacity = "1";
        el.style.transform = "translateY(0)";
        obs.unobserve(el);
      }
    });
  };

  const observer = new IntersectionObserver(reveal, observerOptions);
  document.querySelectorAll(".stat-card").forEach(el => observer.observe(el));
  document.querySelectorAll(".adv-card").forEach(el => observer.observe(el));
  document.querySelectorAll(".reveal-left").forEach(el => {
    (el as HTMLElement).style.opacity = "0";
    (el as HTMLElement).style.transform = "translateX(-24px)";
    observer.observe(el);
  });
  document.querySelectorAll(".reveal-right").forEach(el => {
    (el as HTMLElement).style.opacity = "0";
    (el as HTMLElement).style.transform = "translateX(24px)";
    observer.observe(el);
  });
</script>
