---
import { siteConfig } from "../../data/site";
import { createWhatsappLink } from "../../lib/whatsapp";

const waLink = createWhatsappLink(
  siteConfig.waNumber,
  siteConfig.waText
);
---

<section class="relative overflow-hidden bg-gradient-to-b from-base-100 to-base-200 pb-24 pt-20 md:pt-28">
  <!-- Background Decorations -->
  <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/5 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-40 h-[400px] w-[400px] rounded-full bg-secondary/10 blur-3xl"></div>
  <div class="pointer-events-none absolute left-1/2 top-1/2 h-[300px] w-[300px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/3 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid items-center gap-12 md:grid-cols-2">
      <!-- Left: Text Content -->
      <div class="animate-fade-in">
        <span class="badge badge-soft badge-primary mb-4 px-4 py-2 text-xs tracking-wider">
          ✨ Jasa Maklon Profesional
        </span>

        <h1 class="text-4xl font-black leading-tight md:text-5xl lg:text-6xl">
          Bangun Brand Skincare Kamu
          <span class="text-primary">Bersama Partner Maklon Terpercaya</span>
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-base-content/70 md:text-xl">
          Kami membantu dari konsep, formula, sampling, produksi, quality control, 
          sampai produk siap jual. Tanpa repot, tanpa ribet.
        </p>

        <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row">
          <a
            href={waLink}
            target="_blank"
            class="btn btn-primary btn-lg rounded-full px-8 text-base text-white shadow-lg transition-all duration-300 hover:shadow-xl hover:scale-105"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="mr-1">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Konsultasi WhatsApp
          </a>
          <a
            href="#layanan"
            class="btn btn-soft btn-lg rounded-full px-8 text-base transition-all duration-300 hover:shadow-md"
          >
            Lihat Layanan
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-10 grid grid-cols-3 gap-4">
          <div class="rounded-2xl border border-base-200 bg-base-100/80 p-4 text-center shadow-sm backdrop-blur-sm">
            <p class="text-2xl font-black text-primary md:text-3xl">Custom</p>
            <p class="mt-1 text-xs text-base-content/60">Formula</p>
          </div>
          <div class="rounded-2xl border border-base-200 bg-base-100/80 p-4 text-center shadow-sm backdrop-blur-sm">
            <p class="text-2xl font-black text-primary md:text-3xl">Support</p>
            <p class="mt-1 text-xs text-base-content/60">Brand Baru</p>
          </div>
          <div class="rounded-2xl border border-base-200 bg-base-100/80 p-4 text-center shadow-sm backdrop-blur-sm">
            <p class="text-2xl font-black text-primary md:text-3xl">Siap</p>
            <p class="mt-1 text-xs text-base-content/60">Produk Jual</p>
          </div>
        </div>
      </div>

      <!-- Right: Visual / Floating Card -->
      <div class="relative hidden md:block">
        <!-- Main floating card -->
        <div class="animate-float mx-auto max-w-sm">
          <div class="rounded-3xl bg-gradient-to-br from-primary/10 to-secondary/10 p-1 shadow-2xl">
            <div class="rounded-[calc(1.5rem-4px)] bg-base-100 p-8">
              <!-- Product illustration placeholder -->
              <div class="mx-auto mb-6 flex h-48 w-48 items-center justify-center rounded-full bg-gradient-to-br from-primary/20 to-secondary/20">
                <span class="text-7xl">🧴</span>
              </div>
              <h3 class="text-center text-xl font-black">Produk Skincare</h3>
              <p class="mt-2 text-center text-sm text-base-content/60">
                Dari konsep hingga siap jual
              </p>
              <div class="mt-4 flex justify-center gap-2">
                <span class="badge badge-soft badge-primary badge-sm">BPOM</span>
                <span class="badge badge-soft badge-secondary badge-sm">Halal</span>
                <span class="badge badge-soft badge-accent badge-sm">Custom</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative floating elements -->
        <div class="absolute -bottom-4 -left-8 animate-float-delayed rounded-2xl bg-base-100 p-4 shadow-xl">
          <span class="text-3xl">✨</span>
          <p class="mt-1 text-xs font-semibold">Quality</p>
          <p class="text-xs text-base-content/50">Terjamin</p>
        </div>
        <div class="absolute -right-4 -top-4 animate-float-slow rounded-2xl bg-base-100 p-4 shadow-xl">
          <span class="text-3xl">🔬</span>
          <p class="mt-1 text-xs font-semibold">R&D</p>
          <p class="text-xs text-base-content/50">Berpengalaman</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }
  @keyframes floatSlow {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }
  @keyframes floatDelayed {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
  .animate-float-slow {
    animation: floatSlow 5s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: floatDelayed 3.5s ease-in-out infinite;
  }
</style>