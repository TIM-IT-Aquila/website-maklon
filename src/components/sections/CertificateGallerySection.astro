---
// CertificateGallerySection.astro — Clean, simple certificate gallery
// Just image + description, tight spacing, staggered scroll animation.

import { certifications } from "../../data/certifications";
import SectionHeader from "../ui/SectionHeader.astro";

// Prepare certs data as JSON string for client-side script
const certsJson = JSON.stringify(
  certifications.map(c => ({
    name: c.name,
    fullName: c.fullName,
    desc: c.desc,
    image: c.image || '',
  }))
);
---

<section id="sertifikat" class="relative bg-base-100 py-16 lg:py-20">
  <!-- Subtle ambient -->
  <div class="pointer-events-none absolute right-0 top-0 h-[400px] w-[400px] rounded-full bg-primary/[0.03] blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
    <SectionHeader label="Sertifikat & Lisensi" variant="minimal" class="mb-8">
      <span slot="title">Sertifikasi <span class="text-primary">Resmi</span> yang Kami Miliki</span>
    </SectionHeader>

    <!-- CERTIFICATE CARDS — Clean: image + description only -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="cert-gallery">
      {certifications.map((cert, i) => (
        <div
          class="cert-card group cursor-pointer"
          data-cert-index={i}
          style={`--delay: ${i * 100}ms`}
        >
          <div class="flex h-full flex-col overflow-hidden rounded-xl border border-base-200 bg-base-100 shadow-sm transition-all duration-400 hover:-translate-y-1 hover:shadow-lg hover:border-primary/15">
            {/* Certificate image */}
            <div class="relative h-44 overflow-hidden sm:h-48">
              {cert.image ? (
                <img
                  src={cert.image}
                  alt={`Sertifikat ${cert.name} - ${cert.fullName}`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center bg-base-200/50 text-sm text-base-content/30">Sertifikat {cert.name}</div>
              )}
            </div>

            {/* Description */}
            <div class="flex flex-1 flex-col p-5">
              <h3 class="text-lg font-bold text-base-content transition-colors duration-300 group-hover:text-primary">
                {cert.name}
              </h3>
              <p class="mt-0.5 text-xs font-medium text-primary/60">
                {cert.fullName}
              </p>
              <p class="mt-2 text-sm leading-relaxed text-base-content/60">
                {cert.desc}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CLIENT-SIDE: Lightbox + Scroll Animation -->
<script define:vars={{ certsJson }}>
  const certsJs = JSON.parse(certsJson);

  // --- SCROLL-TRIGGERED STAGGERED ANIMATION ---
  const certCards = document.querySelectorAll('.cert-card');
  const animatedEls = document.querySelectorAll('[data-animate]');

  const staggerObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target;
        const delay = el.style.getPropertyValue('--delay') || '0ms';
        el.style.animation = 'certFadeInUp 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) ' + delay + ' forwards';
        staggerObserver.unobserve(el);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });

  certCards.forEach((card) => staggerObserver.observe(card));

  // Generic data-animate
  const genericObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-in');
        genericObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  animatedEls.forEach((el) => genericObserver.observe(el));
</script>

<style is:global>
  @keyframes certFadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .cert-card {
    opacity: 0;
    transform: translateY(30px);
  }

  [data-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 0.6s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  [data-animate].animate-in {
    opacity: 1;
    transform: translateY(0);
  }
</style>
