---
import SectionHeader from "../ui/SectionHeader.astro";
import Icon from "../ui/Icon.astro";
import { companyPurpose } from "../../data/company";
---

<section id="tujuan" class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
  <SectionHeader
    tag="Company Profile"
    title="Tujuan Website Ini"
    description="Website company profile ini hadir untuk memperkenalkan perusahaan maklon secara profesional dan membangun kepercayaan calon customer."
  />

  <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
    {companyPurpose.map((item) => (
      <div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20">
        <div class="card-body items-center text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-3xl text-primary">
            <Icon name={item.icon} size={32} />
          </div>
          <h3 class="card-title mt-3 text-lg">{item.title}</h3>
          <p class="text-sm text-base-content/70">{item.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>
