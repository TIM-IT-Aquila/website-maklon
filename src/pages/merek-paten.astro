---
import Icon from "../components/ui/Icon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import CTASection from "../components/sections/CTASection.astro";
import WAButton from "../components/ui/WAButton.astro";

const whyCards = [
  {
    icon: "lucide:shield-check",
    title: "Perlindungan Legal",
    desc: "Merek terdaftar mendapat perlindungan hukum penuh dari pemalsuan, pembajakan, dan penggunaan tanpa izin oleh pihak lain.",
  },
  {
    icon: "lucide:gem",
    title: "Aset Bisnis Bernilai",
    desc: "Merek adalah aset tak berwujud yang nilainya terus bertumbuh seiring kesuksesan brand Anda di pasaran.",
  },
  {
    icon: "lucide:heart-handshake",
    title: "Trust Konsumen",
    desc: "Merek terdaftar membangun kredibilitas dan kepercayaan konsumen bahwa produk Anda aman dan legal.",
  },
  {
    icon: "lucide:trending-up",
    title: "Skala Bisnis Lebih Luas",
    desc: "Merek terdaftar membuka peluang ekspansi, franchise, lisensi, dan investasi yang tidak tersedia bagi merek tak terdaftar.",
  },
];

const processSteps = [
  {
    step: "01",
    title: "Konsultasi",
    desc: "Kami diskusikan merek Anda, kelas yang dibutuhkan, dan strategi pendaftaran yang tepat.",
    icon: "lucide:messages-square",
  },
  {
    step: "02",
    title: "Cek Ketersediaan Nama",
    desc: "Tim kami melakukan pengecekan nama merek di database DJKI untuk memastikan nama tersedia dan tidak melanggar merek lain.",
    icon: "lucide:search",
  },
  {
    step: "03",
    title: "Pengajuan Dokumen",
    desc: "Kami siapkan dan ajukan seluruh dokumen yang dibutuhkan ke Direktorat Jenderal Kekayaan Intelektual (DJKI).",
    icon: "lucide:file-text",
  },
  {
    step: "04",
    title: "Review & Monitoring DJKI",
    desc: "Kami pantau setiap tahapan di DJKI — dari pemeriksaan formalitas, pengumuman, hingga pemeriksaan substantif.",
    icon: "lucide:eye",
  },
  {
    step: "05",
    title: "Sertifikat Terbit",
    desc: "Sertifikat merek resmi terbit atas nama Anda. Merek Anda kini terlindungi secara hukum selama 10 tahun.",
    icon: "lucide:award",
  },
];

const serviceCoverages = [
  "Konsultasi HKI menyeluruh untuk brand skincare Anda",
  "Pengecekan ketersediaan nama merek (name search DJKI)",
  "Persiapan & penyusunan dokumen pendaftaran lengkap",
  "Pendaftaran merek ke DJKI hingga tanda terima resmi",
  "Monitoring berkala status permohonan Anda",
  "Pendampingan hukum bila ada keberatan atau sanggahan",
];

const faqItems = [
  {
    q: "Berapa lama proses pendaftaran merek?",
    a: "Proses pendaftaran merek di DJKI umumnya memakan waktu 9–18 bulan, tergantung pada antrian dan ada tidaknya keberatan dari pihak lain. Kami akan memonitor setiap tahapannya untuk Anda.",
  },
  {
    q: "Berapa biaya pendaftaran merek?",
    a: "Biaya pendaftaran merek terdiri dari biaya resmi DJKI dan biaya jasa profesional. Biaya bervariasi tergantung jumlah kelas merek. Konsultasikan dengan kami untuk estimasi yang sesuai kebutuhan Anda.",
  },
  {
    q: "Apakah pendaftaran merek wajib?",
    a: "Tidak wajib secara hukum, namun sangat direkomendasikan. Tanpa pendaftaran, Anda tidak memiliki hak eksklusif atas merek Anda dan rentan terhadap klaim atau pembajakan oleh pihak lain.",
  },
  {
    q: "Bisakah dibantu full process?",
    a: "Tentu! Kami menangani seluruh proses dari konsultasi awal, cek nama, persiapan dokumen, pengajuan ke DJKI, monitoring, hingga sertifikat terbit. Anda tinggal terima beres.",
  },
];
---

<MainLayout
  title="Pendaftaran Merek & HKI | Aquila Magna"
  description="Lindungi brand skincare Anda dengan pendaftaran merek resmi. Konsultasi gratis, proses transparan, didampingi tim legal berpengalaman."
>

  <main class="overflow-x-hidden">

    <!-- ================================================================== -->
    <!-- 1. HERO — Premium, clean, trust-focused                            -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-gradient-to-b from-base-200/30 via-base-100 to-base-100 pb-14 pt-20 md:pb-20 md:pt-28">
      <!-- Subtle bg decoration -->
      <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/[0.04] blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-20 -left-20 h-[350px] w-[350px] rounded-full bg-primary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">

          {/* LEFT — Text */}
          <div class="text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-4 py-1.5 text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">
              <Icon name="lucide:scroll-text" size={14} />
              Merek & HKI
            </div>

            <h1 class="mt-6 text-4xl font-black leading-tight tracking-tight md:text-5xl lg:text-5xl/xl">
              Lindungi Brand Anda dengan <span class="text-primary">Pendaftaran Merek Resmi</span>
            </h1>

            <p class="mt-5 max-w-lg text-base leading-relaxed text-base-content/55 md:text-lg lg:mx-0">
              Kami membantu proses pendaftaran merek dari pengecekan nama hingga sertifikat resmi terbit — transparan, terpercaya, dan bebas ribet.
            </p>

            {/* CTA Buttons */}
            <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row lg:justify-start">
              <WAButton
                text="Konsultasi Gratis"
                message="Halo, saya ingin konsultasi pendaftaran merek untuk produk skincare saya."
                variant="primary"
                size="md"
                class="shadow-lg shadow-primary/20"
              />
              <WAButton
                text="Cek Nama Merek"
                message="Halo, saya ingin cek ketersediaan nama merek saya."
                variant="primary-outline"
                size="md"
                hideIcon
                iconName="lucide:search"
              />
            </div>
          </div>

          {/* RIGHT — Visual: Certificate + Shield + TM */}
          <div class="relative flex items-center justify-center">
            <div class="relative">
              {/* Main card visual */}
              <div class="relative overflow-hidden rounded-3xl border border-base-200/60 bg-white p-8 shadow-xl shadow-base-300/40 md:p-10">
                <!-- Decorative top bar -->
                <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-primary via-primary/80 to-primary"></div>

                <div class="flex flex-col items-center text-center">
                  <!-- Shield icon -->
                  <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-primary/10">
                    <Icon name="lucide:shield-check" size={40} class="text-primary" />
                  </div>

                  <h3 class="mt-5 text-xl font-bold text-base-content">Sertifikat Merek</h3>
                  <p class="mt-2 text-sm text-base-content/50 leading-relaxed max-w-xs">
                    Merek Anda terdaftar secara resmi di DJKI dengan perlindungan hukum penuh
                  </p>

                  <!-- TM badge -->
                  <div class="mt-5 inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/5 px-4 py-2">
                    <span class="text-lg font-black text-primary">&trade;</span>
                    <span class="text-xs font-semibold text-primary">Trademark Protected</span>
                  </div>

                  <!-- Small check items -->
                  <div class="mt-5 grid w-full grid-cols-2 gap-3 text-left">
                    <div class="flex items-center gap-2 rounded-lg border border-base-200/60 bg-base-100 px-3 py-2">
                      <div class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success/10">
                        <Icon name="lucide:check" size={10} class="text-success" />
                      </div>
                      <span class="text-[11px] font-medium text-base-content/60">Resmi DJKI</span>
                    </div>
                    <div class="flex items-center gap-2 rounded-lg border border-base-200/60 bg-base-100 px-3 py-2">
                      <div class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success/10">
                        <Icon name="lucide:check" size={10} class="text-success" />
                      </div>
                      <span class="text-[11px] font-medium text-base-content/60">10 Tahun Berlaku</span>
                    </div>
                    <div class="flex items-center gap-2 rounded-lg border border-base-200/60 bg-base-100 px-3 py-2">
                      <div class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success/10">
                        <Icon name="lucide:check" size={10} class="text-success" />
                      </div>
                      <span class="text-[11px] font-medium text-base-content/60">Hak Eksklusif</span>
                    </div>
                    <div class="flex items-center gap-2 rounded-lg border border-base-200/60 bg-base-100 px-3 py-2">
                      <div class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-success/10">
                        <Icon name="lucide:check" size={10} class="text-success" />
                      </div>
                      <span class="text-[11px] font-medium text-base-content/60">Perlindungan Legal</span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Floating decorative element */}
              <div class="absolute -right-4 -top-4 hidden h-14 w-14 items-center justify-center rounded-2xl bg-primary shadow-lg shadow-primary/30 md:flex">
                <span class="text-xl font-black text-white">&reg;</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. WHY TRADEMARK MATTERS — 4 premium cards                         -->
    <!-- ================================================================== -->
    <section class="bg-base-100 pb-14 md:pb-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        {/* Section header */}
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary">Mengapa Merek Penting</p>
          <h2 class="mt-3 text-3xl font-black md:text-4xl">Merek Anda adalah Aset Paling Berharga</h2>
          <p class="mt-3 text-base text-base-content/50 md:text-lg">
            Tanpa perlindungan merek, brand Anda rentan dicuri, ditiru, atau diklaim pihak lain.
          </p>
        </div>

        {/* Cards grid */}
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {whyCards.map((card, i) => (
            <div
              class="why-card group relative overflow-hidden rounded-2xl border border-base-200/60 bg-white p-6 shadow-sm transition-all duration-500 hover:-translate-y-1.5 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5"
              style={`opacity:0;transform:translateY(30px);transition-delay:${i * 100}ms`}
              data-reveal-card
            >
              {/* Subtle top accent line */}
              <div class="absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r from-primary/0 via-primary/30 to-primary/0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 transition-all duration-500 group-hover:bg-primary group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-primary/20">
                <Icon name={card.icon} size={24} class="text-primary transition-colors duration-500 group-hover:text-white" />
              </div>

              <h3 class="text-lg font-bold text-base-content">{card.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-base-content/55">{card.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. REGISTRATION PROCESS — Interactive timeline (5 steps)           -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/30 pb-14 md:pb-20">
      <div class="pointer-events-none absolute -left-40 -top-20 h-[400px] w-[400px] rounded-full bg-primary/[0.03] blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-30 -right-30 h-[350px] w-[350px] rounded-full bg-primary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl px-4 lg:px-8">
        {/* Section header */}
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary">Proses Pendaftaran</p>
          <h2 class="mt-3 text-3xl font-black md:text-4xl">Langkah Mudah, Hasil Pasti</h2>
          <p class="mt-3 text-base text-base-content/50 md:text-lg">
            Proses transparan dari awal hingga sertifikat di tangan Anda.
          </p>
        </div>

        {/* ── Desktop: Horizontal timeline with connecting line ── */}
        <div class="relative mt-10 hidden lg:block">
          {/* Connecting line */}
          <div class="absolute left-[10%] right-[10%] top-9 h-0.5 bg-gradient-to-r from-primary/20 via-primary/30 to-primary/20"></div>

          <div class="relative grid grid-cols-5 gap-4">
            {processSteps.map((s, i) => (
              <div
                class="process-step group relative flex flex-col items-center text-center"
                style={`opacity:0;transform:translateY(30px)`}
                data-reveal-process
              >
                {/* Step circle */}
                <div class="relative z-10 flex h-[72px] w-[72px] items-center justify-center rounded-full bg-white border-2 border-primary/20 shadow-sm shadow-primary/5 transition-all duration-500 group-hover:border-primary group-hover:bg-primary group-hover:shadow-lg group-hover:shadow-primary/20 group-hover:scale-110">
                  <Icon name={s.icon} size={28} class="text-primary transition-colors duration-500 group-hover:text-white" />
                </div>

                {/* Content */}
                <div class="mt-5">
                  <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-primary/50">Langkah {s.step}</span>
                  <h4 class="mt-1 text-sm font-bold text-base-content">{s.title}</h4>
                  <p class="mt-2 text-xs leading-relaxed text-base-content/50 max-w-[180px] mx-auto">{s.desc}</p>
                </div>

                {/* Hover indicator */}
                <div class="mt-3 h-0.5 w-8 rounded-full bg-primary/0 transition-all duration-500 group-hover:w-16 group-hover:bg-primary/40"></div>
              </div>
            ))}
          </div>
        </div>

        {/* ── Mobile: Vertical numbered list ── */}
        <div class="relative mt-10 space-y-0 lg:hidden">
          {processSteps.map((s, i) => (
            <div class="process-mobile-step relative flex gap-4 pb-8 last:pb-0" data-reveal-mobile>
              {/* Vertical line */}
              {i < processSteps.length - 1 && (
                <div class="absolute left-[23px] top-[52px] bottom-0 w-0.5 bg-gradient-to-b from-primary/20 to-primary/5"></div>
              )}

              {/* Step number */}
              <div class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-black text-primary shadow-sm transition-all duration-300 hover:bg-primary hover:text-white hover:scale-110">
                {s.step}
              </div>

              {/* Content */}
              <div class="pt-1.5">
                <h4 class="text-base font-bold text-base-content">{s.title}</h4>
                <p class="mt-1 text-sm leading-relaxed text-base-content/55">{s.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 4. SERVICE COVERAGE — Elegant checklist grid                       -->
    <!-- ================================================================== -->
    <section class="bg-base-100 pb-14 md:pb-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-10">

          {/* LEFT — Text */}
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary">Cakupan Layanan</p>
            <h2 class="mt-3 text-3xl font-black md:text-4xl">Semua Yang Anda Butuhkan, Kami Tangani</h2>
            <p class="mt-3 text-base text-base-content/50 md:text-lg max-w-lg">
              Dari konsultasi awal hingga pemantauan berkala, kami dampingi penuh setiap langkah Anda.
            </p>

            {/* Checklist */}
            <div class="mt-8 space-y-3">
              {serviceCoverages.map((item) => (
                <div class="flex items-start gap-3 rounded-xl border border-base-200/60 bg-base-100 p-3.5 transition-all duration-300 hover:border-primary/15 hover:bg-primary/[0.02] hover:shadow-sm">
                  <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10">
                    <Icon name="lucide:check" size={12} class="text-primary" />
                  </div>
                  <span class="text-sm leading-relaxed text-base-content/65">{item}</span>
                </div>
              ))}
            </div>
          </div>

          {/* RIGHT — Decorative visual */}
          <div class="relative hidden lg:flex items-center justify-center">
            <div class="relative">
              {/* Main certificate card */}
              <div class="rounded-3xl border-2 border-base-200/60 bg-white p-10 shadow-xl shadow-base-300/30">
                <div class="flex flex-col items-center text-center">
                  <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10">
                    <Icon name="lucide:scroll-text" size={32} class="text-primary" />
                  </div>
                  <h3 class="mt-4 text-lg font-bold text-base-content">Layanan Satu Pintu</h3>
                  <p class="mt-2 text-sm text-base-content/45 max-w-[240px]">
                    Kami siap membantu seluruh kebutuhan legal brand Anda dalam satu tempat.
                  </p>

                  {/* Checklist mini */}
                  <div class="mt-6 w-full space-y-2 text-left">
                    <div class="flex items-center gap-2 rounded-lg bg-success/5 px-3 py-2">
                      <Icon name="lucide:check-circle" size={14} class="text-success" />
                      <span class="text-xs font-medium text-base-content/60">Konsultasi HKI</span>
                    </div>
                    <div class="flex items-center gap-2 rounded-lg bg-success/5 px-3 py-2">
                      <Icon name="lucide:check-circle" size={14} class="text-success" />
                      <span class="text-xs font-medium text-base-content/60">Cek Ketersediaan Nama</span>
                    </div>
                    <div class="flex items-center gap-2 rounded-lg bg-success/5 px-3 py-2">
                      <Icon name="lucide:check-circle" size={14} class="text-success" />
                      <span class="text-xs font-medium text-base-content/60">Pendaftaran DJKI</span>
                    </div>
                    <div class="flex items-center gap-2 rounded-lg bg-success/5 px-3 py-2">
                      <Icon name="lucide:check-circle" size={14} class="text-success" />
                      <span class="text-xs font-medium text-base-content/60">Legal Assistance</span>
                    </div>
                  </div>
                </div>
              </div>

              {/* Decorative trademark circle */}
              <div class="absolute -right-3 -top-3 flex h-10 w-10 items-center justify-center rounded-full bg-primary text-lg font-black text-white shadow-lg shadow-primary/30">
                &reg;
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. FAQ — Modern accordion                                           -->
    <!-- ================================================================== -->
    <section class="relative overflow-hidden bg-base-200/30 pb-14 md:pb-20">
      <div class="pointer-events-none absolute -right-40 top-0 h-[350px] w-[350px] rounded-full bg-primary/[0.03] blur-3xl"></div>

      <div class="relative mx-auto max-w-3xl px-4 lg:px-8">
        {/* Section header */}
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary">FAQ</p>
          <h2 class="mt-3 text-3xl font-black md:text-4xl">Pertanyaan Umum</h2>
          <p class="mt-3 text-base text-base-content/50 md:text-lg">
            Hal yang sering ditanyakan seputar pendaftaran merek.
          </p>
        </div>

        {/* Accordion */}
        <div class="mt-10 space-y-3">
          {faqItems.map((faq, i) => (
            <details class="group rounded-2xl border border-base-200/60 bg-white shadow-sm transition-all duration-300 hover:border-base-300 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 md:px-6">
                <span class="text-sm font-semibold text-base-content/80 md:text-base">{faq.q}</span>
                <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-base-200/80 transition-all duration-300 group-open:bg-primary group-open:text-white">
                  <Icon name="lucide:plus" size={14} class="transition-transform duration-300 group-open:rotate-45" />
                </div>
              </summary>
              <div class="px-5 pb-5 md:px-6 md:pb-6">
                <p class="text-sm leading-relaxed text-base-content/55 md:text-base">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 6. FINAL CTA                                                       -->
    <!-- ================================================================== -->
    <CTASection
      title="Siap Amankan Brand Anda?"
      description="Jangan tunggu sampai merek Anda diklaim orang lain. Konsultasikan pendaftaran merek Anda sekarang — gratis dan tanpa komitmen."
      buttonText="Chat WhatsApp Sekarang"
      waMessage="Halo, saya ingin konsultasi pendaftaran merek untuk produk skincare saya."
    />

  </main>
</MainLayout>

<script>
  // ── Scroll reveal for cards ──
  const cardObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.transition = "all 0.6s cubic-bezier(0.16, 1, 0.3, 1)";
          el.style.opacity = "1";
          el.style.transform = "translateY(0)";
          cardObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.15, rootMargin: "0px 0px -30px 0px" }
  );

  document.querySelectorAll("[data-reveal-card]").forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = `${i * 100}ms`;
    cardObserver.observe(el);
  });

  // ── Scroll reveal for process steps ──
  document.querySelectorAll("[data-reveal-process]").forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = `${i * 120}ms`;
    cardObserver.observe(el);
  });

  // ── Scroll reveal for mobile process ──
  document.querySelectorAll("[data-reveal-mobile]").forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = `${i * 100}ms`;
    cardObserver.observe(el);
  });

  // ── Accordion: close others on open ──
  document.querySelectorAll("details").forEach((detail) => {
    detail.addEventListener("toggle", () => {
      if (detail.hasAttribute("open")) {
        const parent = detail.parentElement;
        if (parent) {
          parent.querySelectorAll("details[open]").forEach((other) => {
            if (other !== detail) other.removeAttribute("open");
          });
        }
      }
    });
  });
</script>
