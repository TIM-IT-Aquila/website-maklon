---
import SectionHeader from "../ui/SectionHeader.astro";
import { visionMission } from "../../data/company";
---

<section id="visimisi" class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
  <SectionHeader
    tag="Visi & Misi"
    title="Komitmen Kami untuk Brand Kecantikan"
    description="Visi dan misi yang menjadi fondasi dalam setiap layanan maklon yang kami berikan."
  />

  <div class="mt-10 grid gap-8 md:grid-cols-2">
    <!-- Vision -->
    <div class="card rounded-3xl border border-secondary/30 bg-secondary/10 shadow-sm backdrop-blur-sm">
      <div class="card-body p-8">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/20 text-3xl">
          🔭
        </div>
        <h3 class="card-title mt-4 text-2xl">Visi</h3>
        <p class="mt-3 text-base leading-relaxed text-base-content/80">
          {visionMission.vision}
        </p>
      </div>
    </div>

    <!-- Mission -->
    <div class="card rounded-3xl border border-secondary/30 bg-secondary/10 shadow-sm backdrop-blur-sm">
      <div class="card-body p-8">
        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/20 text-3xl">
          🎯
        </div>
        <h3 class="card-title mt-4 text-2xl">Misi</h3>
        <ul class="mt-3 space-y-3">
          {visionMission.missions.map((mission) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/20 text-xs text-primary">✓</span>
              <span class="text-base text-base-content/80">{mission}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
