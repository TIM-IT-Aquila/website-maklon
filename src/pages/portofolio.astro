---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import CTASection from "../components/sections/CTASection.astro";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import { portfolioItems, portfolioCategories } from "../data/portofolio";
import { Icon } from "astro-icon/components";

const waLink = createWhatsappLink(siteConfig.waNumber, siteConfig.waText);
---

<MainLayout
  title="Portofolio | Aquila Maklon"
  description="Lihat portofolio brand-brand yang telah bekerja sama dengan Aquila Maklon dalam produksi skincare dan kosmetik."
>
  <main>
    <!-- ================================================================== -->
    <!-- 1. PAGE HEADER                                                     -->
    <!-- ================================================================== -->
    <PageHeader
      title="Portofolio Brand Binaan"
      description="Berbagai brand telah percaya kepada Aquila Maklon untuk mewujudkan produk kecantikan mereka. Berikut adalah portofolio brand binaan kami."
      badge="Portofolio"
      breadcrumb="Portofolio"
    />

    <!-- ================================================================== -->
    <!-- 2. FILTER KATEGORI                                                 -->
    <!-- ================================================================== -->
    <section class="mx-auto max-w-7xl px-4 pt-12 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-3">
        <button class="category-filter btn btn-sm rounded-full btn-primary text-white" data-category="all">
          Semua
        </button>
        {portfolioCategories.map((cat) => (
          <button class="category-filter btn btn-sm rounded-full btn-soft btn-primary" data-category={cat}>
            {cat}
          </button>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 3. GRID PORTOFOLIO                                                 -->
    <!-- ================================================================== -->
    <section class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
      <div id="portfolio-grid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {portfolioItems.map((item) => (
          <div
            class="portfolio-card group card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20"
            data-category={item.category}
          >
            <!-- Header with gradient icon -->
            <div class={`flex h-44 items-center justify-center overflow-hidden rounded-t-2xl bg-gradient-to-br ${item.color}`}>
              <div class="flex h-24 w-24 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm shadow-lg">
                <span class="text-5xl transition-transform duration-500 group-hover:scale-110">{item.icon}</span>
              </div>
            </div>

            <div class="card-body">
              <!-- Badge kategori -->
              <div class="flex items-center justify-between">
                <span class="badge badge-soft badge-primary badge-sm">{item.category}</span>
              </div>

              <!-- Nama Brand -->
              <h3 class="card-title mt-2 text-xl transition-colors duration-300 group-hover:text-primary">
                {item.brandName}
              </h3>

              <!-- Deskripsi -->
              <p class="text-sm leading-relaxed text-base-content/70">
                {item.description}
              </p>

              <!-- Produk yang dibuat -->
              <div class="mt-3">
                <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-primary">Produk yang diproduksi:</p>
                <div class="flex flex-wrap gap-1.5">
                  {item.products.map((product) => (
                    <span class="badge badge-soft badge-ghost badge-sm text-xs">{product}</span>
                  ))}
                </div>
              </div>

              <!-- Highlights -->
              <div class="mt-4 space-y-2">
                {item.highlights.map((highlight) => (
                  <div class="flex items-start gap-2">
                    <Icon name="check" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-primary" />
                    <span class="text-xs text-base-content/70">{highlight}</span>
                  </div>
                ))}
              </div>

              <!-- CTA -->
              <div class="card-actions mt-5">
                <a
                  href={createWhatsappLink(
                    siteConfig.waNumber,
                    `Halo, saya tertarik dengan portofolio ${item.brandName}. Saya ingin konsultasi untuk membuat produk serupa.`
                  )}
                  target="_blank"
                  class="btn btn-primary btn-sm rounded-full w-full text-white"
                >
                  Konsultasi Buat Produk Serupa
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- 5. CTA SECTION                                                     -->
    <!-- ================================================================== -->
    <CTASection
      title="Jadilah Brand Selanjutnya!"
      description="Bergabunglah dengan brand-brand sukses lainnya. Mulai perjalanan brand Anda bersama Aquila Maklon sekarang."
      buttonText="Konsultasi via WhatsApp"
      waMessage="Halo, saya tertarik untuk memulai brand skincare bersama Aquila Maklon."
    />
  </main>
</MainLayout>

<script>
  // Filter portfolio by category
  const filters = document.querySelectorAll(".category-filter");
  const cards = document.querySelectorAll(".portfolio-card");

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      const category = btn.dataset.category;

      // Update button active state
      filters.forEach((b) => {
        b.classList.remove("btn-primary", "text-white");
        b.classList.add("btn-soft");
      });
      btn.classList.remove("btn-soft");
      btn.classList.add("btn-primary", "text-white");

      // Filter cards
      cards.forEach((card) => {
        if (category === "all" || card.dataset.category === category) {
          card.style.display = "";
          card.style.opacity = "0";
          card.style.transform = "translateY(10px)";
          requestAnimationFrame(() => {
            card.style.transition = "opacity 0.3s ease, transform 0.3s ease";
            card.style.opacity = "1";
            card.style.transform = "translateY(0)";
          });
        } else {
          card.style.display = "none";
        }
      });
    });
  });
</script>
