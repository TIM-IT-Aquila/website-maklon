---
interface Feature {
  icon?: string;
  title: string;
  desc: string;
}

interface Props {
  feature: Feature;
}

const { feature } = Astro.props;
---

<div class="card border border-base-200 bg-base-100 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20">
  <div class="card-body items-center text-center">
    {feature.icon && (
      <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-3xl">
        {feature.icon}
      </div>
    )}
    <h3 class="card-title mt-2">{feature.title}</h3>
    <p class="text-base-content/70">{feature.desc}</p>
  </div>
</div>