---
import Container from "../components/ui/Container.astro";
import FAQItem from "../components/ui/FAQItem.astro";
import Icon from "../components/ui/Icon.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import WAButton from "../components/ui/WAButton.astro";
import { oemOdmHero } from "../data/oem-odm";
import { consultationFocus, consultationSteps, oemOdmFaqs, serviceOptions } from "../data/oem-odm-page";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="OEM / ODM | Magna"
  description="Konsultasi layanan OEM dan ODM skincare bersama Magna melalui WhatsApp."
>
  <main class="overflow-hidden">
    <PageHero
      image={oemOdmHero.image}
      alt={oemOdmHero.alt}
      titleMain="Mulai Brand Skincare"
      titleAccent="Dari Percakapan yang Tepat"
    >
      <p slot="description" class="mt-4 max-w-xl text-sm leading-relaxed text-white/70 md:text-base">
        Ceritakan ide, target pasar, dan kebutuhan brand Anda. Tim Magna akan membantu menentukan
        arah OEM atau ODM yang paling sesuai melalui konsultasi WhatsApp.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <WAButton
          text="Konsultasi via WhatsApp"
          message="Halo, saya ingin konsultasi layanan OEM/ODM untuk brand skincare saya."
          variant="white"
          size="lg"
        />
        <a href="#layanan" class="inline-flex h-13 items-center justify-center rounded-xl border border-white/25 px-6 text-sm font-bold text-white transition hover:bg-white/10">
          Lihat layanan
        </a>
      </div>
    </PageHero>

    <section id="layanan" class="bg-base-100 py-16 md:py-20">
      <Container>
        <SectionHeader label="Pilih arah yang tepat" title="OEM atau ODM, mulainya tetap dari konsultasi." />
        <div class="mx-auto mt-10 grid max-w-5xl gap-5 md:grid-cols-2">
          {
            serviceOptions.map((service) => (
              <article class="rounded-3xl border border-base-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:border-primary/25 hover:shadow-lg md:p-8">
                <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                  <Icon name={service.icon} size={21} />
                </div>
                <h2 class="mt-5 text-2xl font-black">{service.title}</h2>
                <p class="mt-3 text-sm leading-relaxed text-base-content/60">{service.description}</p>
                <p class="mt-5 border-t border-base-200 pt-4 text-sm font-semibold text-primary">{service.suitableFor}</p>
              </article>
            ))
          }
        </div>
      </Container>
    </section>

    <section class="bg-base-200/45 py-16 md:py-20">
      <Container>
        <div class="grid items-center gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
          <SectionHeader align="left" label="Brief awal" title="Tidak perlu memilih produk terlebih dahulu." />
          <div class="rounded-3xl border border-primary/10 bg-white p-6 shadow-sm md:p-8">
            <p class="text-base leading-relaxed text-base-content/65">
              Saat konsultasi, Anda cukup menyampaikan kebutuhan brand. Kami dapat mendiskusikan
              kategori bahan aktif, karakter formula, kemasan, dan tujuan produk sebelum masuk ke
              detail produksi.
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              {
                consultationFocus.map((focus) => (
                  <span class="rounded-full border border-primary/15 bg-primary/[0.05] px-3 py-2 text-xs font-semibold text-primary">
                    {focus}
                  </span>
                ))
              }
            </div>
            <WAButton
              text="Sampaikan kebutuhan brand"
              message="Halo, saya ingin mendiskusikan kebutuhan formula dan konsep brand skincare saya."
              size="lg"
              class="mt-7"
            />
          </div>
        </div>
      </Container>
    </section>

    <section class="bg-base-100 py-16 md:py-20">
      <Container maxWidth="5xl">
        <SectionHeader label="Cara memulai" title="Tiga langkah menuju konsultasi yang jelas." />
        <ol class="mt-10 grid gap-5 md:grid-cols-3">
          {
            consultationSteps.map((step, index) => (
              <li class="relative rounded-2xl border border-base-200 bg-white p-6 shadow-sm">
                <span class="text-4xl font-black text-primary/15">0{index + 1}</span>
                <div class="mt-5 flex h-10 w-10 items-center justify-center rounded-xl bg-primary text-white">
                  <Icon name={step.icon} size={18} />
                </div>
                <h2 class="mt-4 text-lg font-bold">{step.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-base-content/55">{step.description}</p>
              </li>
            ))
          }
        </ol>
      </Container>
    </section>

    <section class="bg-base-200/45 py-16 md:py-20">
      <Container maxWidth="4xl">
        <SectionHeader label="Pertanyaan umum" title="Sebelum memulai, ini yang sering ditanyakan." />
        <div class="mt-10 space-y-3">
          {
            oemOdmFaqs.map((faq, index) => (
              <FAQItem question={faq.q} answer={faq.a} index={index + 1} tone="primary" />
            ))
          }
        </div>
      </Container>
    </section>

  </main>
</MainLayout>
