---
import Container from "../components/ui/Container.astro";
import Icon from "../components/ui/Icon.astro";
import PageHero from "../components/ui/PageHero.astro";
import {
  badgeVariantClass,
  legalPillars,
  patenBrandHero,
} from "../data/paten-brand-legal";
import { siteConfig } from "../data/site";
import { createWhatsappLink } from "../lib/whatsapp";
import MainLayout from "../layouts/MainLayout.astro";

const waMessages: Record<string, string> = {
  haki: "Halo, saya ingin konsultasi pendaftaran HAKI / merek untuk produk skincare saya.",
  bpom: "Halo, saya ingin konsultasi pengurusan izin edar BPOM (Nomor NA) untuk produk skincare saya.",
  halal: "Halo, saya ingin konsultasi sertifikasi halal untuk produk skincare saya.",
};
---

<MainLayout
  title="Pendaftaran Merek & HKI | Magna"
  description="Layanan legalitas brand skincare Magna."
>
  <main class="overflow-hidden">
    <section class="relative overflow-hidden bg-base-100">
      <PageHero
        image={patenBrandHero.image}
        alt={patenBrandHero.alt}
        titleMain="Legalitas Brand"
        titleAccent="Aman & Terpercaya"
      >
        <p slot="description" class="mt-3 max-w-lg text-sm leading-relaxed text-white/55 md:text-base">
          Kami mengurus HAKI, izin edar BPOM, dan sertifikasi halal — Anda fokus membangun dan
          memasarkan brand skincare Anda.
        </p>
      </PageHero>

      <!-- 3 PILAR LEGALITAS -->
      <Container class="relative py-16 lg:py-20">
        <div class="mx-auto mb-10 max-w-xl text-center">
          <span class="inline-flex items-center gap-2 rounded-full bg-info/8 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-info">
            <Icon name="lucide:scale" size={14} />
            3 Pilar Legalitas
          </span>
          <h2 class="mt-4 text-2xl font-bold text-base-content lg:text-3xl">
            Kami Urus <span class="text-primary">Seluruh Legalitas</span> Brand Anda
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-base-content/55">
            Dari pendaftaran merek hingga sertifikasi halal — tim legal kami dampingi setiap prosesnya.
          </p>
        </div>

        <div class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-3">
          {
            legalPillars.map((pillar) => {
              const waLink = createWhatsappLink(siteConfig.waNumber, waMessages[pillar.id] ?? siteConfig.waText);
              return (
                <a
                  href={waLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block rounded-2xl border-2 border-slate-100 bg-white px-5 pb-5 pt-6 text-left shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/20 hover:shadow-lg"
                >
                  <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/8 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-white">
                    <Icon name={pillar.icon} size={22} />
                  </div>
                  <h3 class="text-sm font-bold text-base-content">{pillar.shortTitle}</h3>
                  <p class="mt-2 text-xs leading-relaxed text-base-content/50">{pillar.description}</p>
                  <div class="mt-4 flex items-center gap-3">
                    <span class="text-xl font-bold text-primary">{pillar.statValue}</span>
                    <span class="text-xs text-base-content/45">{pillar.statDesc}</span>
                  </div>
                  <span class={`badge badge-sm mt-4 gap-1.5 border-primary/20 bg-primary/8 px-3 py-2 text-primary transition-all duration-300 group-hover:bg-primary group-hover:text-white ${badgeVariantClass[pillar.badgeVariant]}`}>
                    <Icon name="mdi:whatsapp" size={14} />
                    {pillar.statusLabel}
                  </span>
                </a>
              );
            })
          }
        </div>
      </Container>
    </section>
  </main>
</MainLayout>
