---
import MainLayout from "../layouts/MainLayout.astro";
import Icon from "../components/ui/Icon.astro";
import WAButton from "../components/ui/WAButton.astro";
import { csrItems } from "../data/csr";
---

<MainLayout
  title="CSR & Sustainability | Magna"
  description="Komitmen Magna terhadap lingkungan, sosial, dan tata kelola perusahaan yang berkelanjutan."
>
  <main class="overflow-x-hidden">

    <!-- ================================================================== -->
    <!-- HERO CSR                                                            -->
    <!-- ================================================================== -->
    <section class="relative flex min-h-[50vh] items-center overflow-hidden bg-primary">
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div class="pointer-events-none absolute -left-32 -top-32 h-[400px] w-[400px] rounded-full bg-white/5 blur-3xl"></div>
      <div class="pointer-events-none absolute -right-32 -bottom-32 h-[400px] w-[400px] rounded-full bg-white/5 blur-3xl"></div>

      <div class="relative z-10 mx-auto w-full max-w-4xl px-4 py-20 text-center lg:px-8">
        <div class="mx-auto mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-5 py-2 backdrop-blur-xl">
          <Icon name="lucide:leaf" class="h-4 w-4 text-emerald-300" />
          <span class="text-xs font-bold tracking-[0.15em] text-white/70 uppercase">CSR & Sustainability</span>
        </div>

        <h1 class="text-4xl font-black text-white md:text-5xl lg:text-6xl">
          Komitmen Kami untuk<br />
          <span class="text-white/70">Masa Depan</span>
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/55 md:text-lg">
          Kami percaya bahwa bisnis yang baik harus membawa dampak positif — bagi lingkungan, masyarakat, dan generasi mendatang.
        </p>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- CSR GRID                                                            -->
    <!-- ================================================================== -->
    <section class="bg-base-100 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-black md:text-4xl leading-tight">
            Tanggung Jawab <span class="text-primary">Kami</span>
          </h2>
          <p class="mt-4 text-base leading-relaxed text-base-content/50">
            Dari lingkungan hingga sosial — berikut komitmen nyata yang kami jalankan.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {csrItems.map((item, i) => (
            <div class="reveal-up group relative overflow-hidden rounded-2xl border border-base-200/60 bg-white shadow-sm transition-all duration-500 hover:-translate-y-1.5 hover:border-primary/20 hover:shadow-xl"
              class:list={{ "md:col-span-2 lg:col-span-2": i === 0, "lg:col-span-1": i !== 0 }}
            >
              <!-- Image -->
              <div class="relative h-44 overflow-hidden">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-all duration-700 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
              </div>
              <!-- Content -->
              <div class="p-6">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/8 text-primary transition-all duration-500 group-hover:bg-primary group-hover:text-white">
                    <Icon name={item.icon} class="h-5 w-5" />
                  </div>
                  <h3 class="text-base font-bold text-base-content">{item.title}</h3>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-base-content/50">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ================================================================== -->
    <!-- CTA                                                                 -->
    <!-- ================================================================== -->
    <section class="bg-base-200/40 py-16">
      <div class="mx-auto max-w-3xl px-4 text-center lg:px-8">
        <h2 class="text-2xl font-black md:text-3xl">
          Ingin Tahu Lebih Lanjut?
        </h2>
        <p class="mt-4 text-base leading-relaxed text-base-content/50">
          Kami dengan senang hati berbagi informasi lebih detail tentang praktik keberlanjutan kami.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <WAButton
            text="Hubungi Kami"
            variant="primary"
            size="lg"
            class="rounded-xl"
          />
        </div>
      </div>
    </section>

  </main>
</MainLayout>
