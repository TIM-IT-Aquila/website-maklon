---
interface Props {
  as?: "div" | "section" | "article";
  maxWidth?: "3xl" | "4xl" | "5xl" | "6xl" | "7xl";
  class?: string;
}

const {
  as = "div",
  maxWidth = "7xl",
  class: className,
} = Astro.props as Props;

const Tag = as;

const maxWidthClasses = {
  "3xl": "max-w-3xl",
  "4xl": "max-w-4xl",
  "5xl": "max-w-5xl",
  "6xl": "max-w-6xl",
  "7xl": "max-w-7xl",
};
---

<Tag
  class:list={["mx-auto px-4 lg:px-8", maxWidthClasses[maxWidth], className]}
>
  <slot />
</Tag>
