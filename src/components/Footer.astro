---
import { siteConfig } from "../data/site";
import WAButton from "../components/ui/WAButton.astro";
import { navItems } from "../data/nav";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-base-300 bg-base-200/50">
  <div class="mx-auto max-w-7xl px-4 py-10 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-5">
      <!-- Brand Premium -->
      <div class="lg:col-span-1">
        <a href="/" class="group flex items-center gap-3 transition-all duration-500 hover:opacity-85">
          <img src="/assets/Logo-magna.svg" alt="Magna" class="h-10 w-auto" />
          <div class="leading-tight">
            <p class="text-lg font-extrabold tracking-tight text-primary">
              Magna<span class="text-primary/70"></span>
            </p>
          </div>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-base-content">
          {siteConfig.description}
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">Halaman</h4>
        <ul class="space-y-2.5">
          {navItems.filter((item) => item.href).map((item) => (
            <li>
              <a href={item.href} class="text-sm text-base-content/60 transition-colors hover:text-primary">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Perusahaan -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">Perusahaan</h4>
        <ul class="space-y-2.5">
          {navItems
            .filter((item) => item.label === "About us")
            .flatMap((item) => item.children || [])
            .map((child) => (
              <li>
                <a href={child.href} class="text-sm text-base-content/60 transition-colors hover:text-primary">
                  {child.label}
                </a>
              </li>
            ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">Layanan</h4>
        <ul class="space-y-2.5">
          {navItems
            .filter((item) => item.label === "Services")
            .flatMap((item) => item.children || [])
            .map((child) => (
              <li>
                <a href={child.href} class="text-sm text-base-content/60 transition-colors hover:text-primary">
                  {child.label}
                </a>
              </li>
            ))}
        </ul>
      </div>

      <!-- Kontak & CTA -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-base-content/40">Kontak</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <WAButton
              text={`WhatsApp: ${siteConfig.waNumber}`}
              variant="text-link-black"
              size="sm"
              hideIcon
              class="!p-0 !h-auto !text-sm !font-normal"
            />
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="text-base-content transition-colors hover:text-primary">
              {siteConfig.email}
            </a>
          </li>
        </ul>
        <div class="mt-6">
          <WAButton
            text="Konsultasi Gratis"
            variant="primary"
            size="sm"
            class="rounded-full"
          />
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-base-300 pt-6 text-center text-sm text-base-content/40">
      &copy; {currentYear} {siteConfig.name}. All rights reserved.
    </div>
  </div>
</footer>