---
import Container from "../components/ui/Container.astro";
import Icon from "../components/ui/Icon.astro";
import PageHero from "../components/ui/PageHero.astro";
import {
  badgeVariantClass,
  defaultActivePillarId,
  legalPillars,
  patenBrandHero,
} from "../data/paten-brand-legal";
import MainLayout from "../layouts/MainLayout.astro";

const defaultPillar = legalPillars.find((p) => p.id === defaultActivePillarId) ?? legalPillars[0];
---

<MainLayout
  title="Pendaftaran Merek & HKI | Magna"
  description="Layanan legalitas brand skincare Magna."
>
  <main class="overflow-hidden">
    <section id="paten-brand-legal" class="relative overflow-hidden bg-base-100" data-paten-brand-legal>
      <PageHero
        image={patenBrandHero.image}
        alt={patenBrandHero.alt}
        titleMain="Legalitas Brand"
        titleAccent="Aman & Terpercaya"
      >
        <p slot="description" class="mt-3 max-w-lg text-sm leading-relaxed text-white/55 md:text-base">
          Kami mengurus HAKI, izin edar BPOM, dan sertifikasi halal - Anda fokus membangun dan
          memasarkan brand skincare Anda.
        </p>
      </PageHero>

      <Container class="relative py-10 lg:py-20">
        <div class="mb-4 flex items-center justify-center gap-2">
          <Icon name="lucide:scale" size={18} class="text-info" />
          <h2 class="text-base font-bold text-base-content">3 Pilar Legalitas yang Kami Urus</h2>
        </div>

        <div class="stats stats-vertical w-full overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-sm lg:stats-horizontal">
          {
            legalPillars.map((pillar, index) => (
              <button
                type="button"
                class:list={[
                  "stat cursor-pointer border-slate-100 text-left transition-all duration-300 hover:bg-info/[0.03]",
                  index < legalPillars.length - 1 && "border-b lg:border-b-0 lg:border-r",
                  pillar.id === defaultActivePillarId && "bg-info/[0.04] ring-2 ring-inset ring-info/20",
                ]}
                data-pillar-tab={pillar.id}
                aria-pressed={pillar.id === defaultActivePillarId}
              >
                <div class="stat-figure text-info"><Icon name={pillar.icon} size={22} /></div>
                <div class="stat-title text-xs font-medium text-base-content/50">{pillar.shortTitle}</div>
                <div class="stat-value text-2xl text-primary">{pillar.statValue}</div>
                <div class="stat-desc text-xs">{pillar.statDesc}</div>
                <span class={`badge badge-xs mt-2 ${badgeVariantClass[pillar.badgeVariant]}`}>
                  {pillar.statusLabel}
                </span>
              </button>
            ))
          }
        </div>

        <div class="mt-4 rounded-2xl border border-info/15 bg-gradient-to-br from-info/[0.04] to-primary/[0.03] p-5 shadow-sm lg:p-6" data-pillar-detail>
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h3 class="text-base font-bold text-base-content" data-pillar-title>{defaultPillar.title}</h3>
              <p class="mt-2 max-w-2xl text-sm leading-relaxed text-base-content/55" data-pillar-desc>
                {defaultPillar.description}
              </p>
            </div>
            <span class={`badge shrink-0 ${badgeVariantClass[defaultPillar.badgeVariant]}`} data-pillar-badge>
              {defaultPillar.statusLabel}
            </span>
          </div>
          <ul class="mt-4 grid gap-2 sm:grid-cols-2" data-pillar-services>
            {
              defaultPillar.services.map((service) => (
                <li class="flex items-center gap-2 rounded-lg border border-white/60 bg-white/70 px-3 py-2 text-sm text-base-content/65">
                  <Icon name="lucide:check" size={14} class="shrink-0 text-primary" />
                  {service}
                </li>
              ))
            }
          </ul>
        </div>
      </Container>

      <script is:inline type="application/json" id="mp-pillars" set:html={JSON.stringify(legalPillars)} />
    </section>
  </main>
</MainLayout>

<script>
  import type { LegalPillar } from "../lib/paten-brand-legal";

  const root = document.querySelector<HTMLElement>("[data-paten-brand-legal]");
  const pillars = JSON.parse(root?.querySelector("#mp-pillars")?.textContent ?? "[]") as LegalPillar[];
  let activePillarId = pillars[0]?.id ?? "haki";

  function renderPillarDetail(pillarId: string): void {
    const pillar = pillars.find((item) => item.id === pillarId);
    if (!root || !pillar) return;

    const titleEl = root.querySelector<HTMLElement>("[data-pillar-title]");
    const descEl = root.querySelector<HTMLElement>("[data-pillar-desc]");
    const badgeEl = root.querySelector<HTMLElement>("[data-pillar-badge]");
    const servicesEl = root.querySelector<HTMLElement>("[data-pillar-services]");
    if (titleEl) titleEl.textContent = pillar.title;
    if (descEl) descEl.textContent = pillar.description;
    if (badgeEl) badgeEl.textContent = pillar.statusLabel;
    if (servicesEl) servicesEl.innerHTML = pillar.services.map((service) => `<li class="flex items-center gap-2 rounded-lg border border-white/60 bg-white/70 px-3 py-2 text-sm text-base-content/65">${service}</li>`).join("");

    root.querySelectorAll<HTMLButtonElement>("[data-pillar-tab]").forEach((tab) => {
      const isActive = tab.dataset.pillarTab === pillarId;
      tab.setAttribute("aria-pressed", String(isActive));
      tab.classList.toggle("bg-info/[0.04]", isActive);
      tab.classList.toggle("ring-2", isActive);
      tab.classList.toggle("ring-inset", isActive);
      tab.classList.toggle("ring-info/20", isActive);
    });
  }

  root?.querySelectorAll<HTMLButtonElement>("[data-pillar-tab]").forEach((tab) => {
    tab.addEventListener("click", () => {
      activePillarId = tab.dataset.pillarTab ?? activePillarId;
      renderPillarDetail(activePillarId);
    });
  });
</script>
