---
import SectionHeader from "../ui/SectionHeader.astro";
import { faqs } from "../../data/faqs";
---

<section class="mx-auto max-w-7xl px-4 py-16 lg:px-8">
  <SectionHeader
    label="FAQ"
    variant="minimal"
    title="Pertanyaan yang Sering Diajukan"
  />

  <div class="mx-auto mt-8 max-w-3xl">
    <div class="join join-vertical w-full">
      {faqs.map((faq) => (
        <div class="collapse collapse-arrow join-item border border-base-200 bg-base-100">
          <input type="radio" name="faq-accordion" />
          <div class="collapse-title text-lg font-medium">{faq.q}</div>
          <div class="collapse-content">
            <p class="text-base-content/70">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>