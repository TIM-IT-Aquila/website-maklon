---
import Container from "../components/ui/Container.astro";
import FAQItem from "../components/ui/FAQItem.astro";
import Icon from "../components/ui/Icon.astro";
import PageHero from "../components/ui/PageHero.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import WAButton from "../components/ui/WAButton.astro";
import { oemOdmHero } from "../data/oem-odm";
import {
  consultationSteps,
  odmFlexibilities,
  oemOdmFaqs,
  oemServiceTiers,
} from "../data/oem-odm-page";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="OEM / ODM | Magna"
  description="Konsultasi layanan OEM dan ODM skincare bersama Magna melalui WhatsApp."
>
  <main class="overflow-hidden">
    <PageHero
      image={oemOdmHero.image}
      alt={oemOdmHero.alt}
      titleMain="Mulai Brand Skincare"
      titleAccent="Dari Percakapan yang Tepat"
    >
      <p slot="description" class="mt-4 max-w-xl text-sm leading-relaxed text-white/70 md:text-base">
        Ceritakan ide, target pasar, dan kebutuhan brand Anda. Tim Magna akan membantu menentukan
        arah OEM atau ODM yang paling sesuai melalui konsultasi WhatsApp.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <WAButton
          text="Konsultasi via WhatsApp"
          message="Halo, saya ingin konsultasi layanan OEM/ODM untuk brand skincare saya."
          variant="white"
          size="lg"
        />
        <a href="#layanan" class="inline-flex h-13 items-center justify-center rounded-xl border border-white/25 px-6 text-sm font-bold text-white transition hover:bg-white/10">
          Lihat layanan
        </a>
      </div>
    </PageHero>

    <section id="layanan" class="bg-base-100 py-16 md:py-20">
      <Container>
        <SectionHeader label="Sistem layanan maklon fleksibel">
          <span slot="title">Tiga tingkat layanan <span class="text-primary">OEM</span> untuk brand Anda.</span>
        </SectionHeader>
        <p class="mx-auto mt-5 max-w-3xl text-center text-sm leading-relaxed text-base-content/60 md:text-base">
          Setiap beautypreneur memiliki kesiapan modal dan konsep yang berbeda. Pilih sistem
          manufaktur yang paling sesuai dengan kebutuhan bisnis Anda.
        </p>
        <div class="mx-auto mt-10 grid max-w-6xl gap-4 lg:grid-cols-3">
          {
            oemServiceTiers.map((tier, index) => (
              <details
                class="group rounded-3xl border border-base-200 bg-white shadow-sm transition duration-300 open:border-primary/25 open:shadow-lg"
                open={index === 0}
              >
                <summary class="cursor-pointer list-none p-6 marker:hidden md:p-7">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                      <Icon name={tier.icon} size={21} />
                    </div>
                    <span class="font-mono text-xs font-bold tracking-widest text-primary/45">
                      {tier.level}
                    </span>
                  </div>
                  <p class="mt-6 text-xs font-bold tracking-[0.18em] text-primary uppercase">
                    {tier.subtitle}
                  </p>
                  <h2 class="mt-1 text-2xl font-black text-base-content">{tier.title}</h2>
                  <p class="mt-3 text-sm leading-relaxed text-base-content/60">{tier.description}</p>
                  <span class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-primary">
                    Lihat detail layanan
                    <Icon name="lucide:chevron-down" size={16} class="transition-transform duration-300 group-open:rotate-180" />
                  </span>
                </summary>
                <div class="border-t border-base-200 px-6 pb-6 pt-5 md:px-7 md:pb-7">
                  <ul class="space-y-3">
                    {
                      tier.highlights.map((highlight) => (
                        <li class="flex gap-2 text-sm leading-relaxed text-base-content/65">
                          <Icon name="lucide:check" size={16} class="mt-0.5 shrink-0 text-primary" />
                          {highlight}
                        </li>
                      ))
                    }
                  </ul>
                  {
                    "categories" in tier && (
                      <div class="mt-5 rounded-2xl bg-base-200/55 p-4">
                        <p class="text-xs font-bold tracking-wider text-base-content/55 uppercase">
                          Kategori produk tersedia
                        </p>
                        <ul class="mt-3 space-y-2">
                          {tier.categories.map((category) => <li class="text-xs leading-relaxed text-base-content/60">{category}</li>)}
                        </ul>
                      </div>
                    )
                  }
                  <WAButton
                    text={`Konsultasi ${tier.title}`}
                    message={`Halo, saya ingin konsultasi layanan ${tier.title} untuk brand skincare saya.`}
                    size="sm"
                    class="mt-6 w-full"
                  />
                </div>
              </details>
            ))
          }
        </div>
      </Container>
    </section>

    <section class="bg-base-200/45 py-16 md:py-20">
      <Container>
        <div class="grid items-start gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
          <div>
            <SectionHeader align="left" label="ODM fleksibel">
              <span slot="title">Kebebasan <span class="text-primary">konsep & material</span>.</span>
            </SectionHeader>
            <p class="mt-5 text-sm leading-relaxed text-base-content/65 md:text-base">
              Layanan ODM memberi ruang untuk mengembangkan produk sesuai idealisme Anda, baik
              saat memulai dengan sumber daya terbatas maupun saat sudah memiliki material khusus.
            </p>
            <WAButton
              text="Diskusikan konsep ODM"
              message="Halo, saya ingin mendiskusikan konsep ODM untuk brand skincare saya."
              size="lg"
              class="mt-7"
            />
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            {
              odmFlexibilities.map((option, index) => (
                <article class="group rounded-3xl border border-primary/10 bg-white p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-primary/25 hover:shadow-md md:p-6">
                  <span class="text-xs font-bold tracking-widest text-primary/45">0{index + 1}</span>
                  <div class="mt-5 flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white">
                    <Icon name={option.icon} size={19} />
                  </div>
                  <h2 class="mt-5 text-lg font-black text-base-content">{option.title}</h2>
                  <p class="mt-3 text-sm leading-relaxed text-base-content/60">{option.description}</p>
                </article>
              ))
            }
          </div>
        </div>
      </Container>
    </section>

    <section class="bg-base-100 py-16 md:py-20">
      <Container maxWidth="5xl">
        <SectionHeader label="Cara memulai" title="Tiga langkah menuju konsultasi yang jelas." />
        <ol class="mt-10 grid gap-5 md:grid-cols-3">
          {
            consultationSteps.map((step, index) => (
              <li class="relative rounded-2xl border border-base-200 bg-white p-6 shadow-sm">
                <span class="text-4xl font-black text-primary/15">0{index + 1}</span>
                <div class="mt-5 flex h-10 w-10 items-center justify-center rounded-xl bg-primary text-white">
                  <Icon name={step.icon} size={18} />
                </div>
                <h2 class="mt-4 text-lg font-bold">{step.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-base-content/55">{step.description}</p>
              </li>
            ))
          }
        </ol>
      </Container>
    </section>

    <section class="bg-base-200/45 py-16 md:py-20">
      <Container maxWidth="4xl">
        <SectionHeader label="Pertanyaan umum" title="Sebelum memulai, ini yang sering ditanyakan." />
        <div class="mt-10 space-y-3">
          {
            oemOdmFaqs.map((faq, index) => (
              <FAQItem question={faq.q} answer={faq.a} index={index + 1} tone="primary" />
            ))
          }
        </div>
      </Container>
    </section>

  </main>
</MainLayout>
